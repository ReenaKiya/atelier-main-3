<!doctype html>
<html
  class="no-js{% if request.design_mode %} shopify-design-mode{% endif %}"
  lang="{{ request.locale.iso_code }}"
>
  <head>
    {%- render 'stylesheets' -%}

    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {% comment %} This a way to wait for main content to load when navigating to a new page so that the view transitions can work consistently {% endcomment %}
    <link
      rel="expect"
      href="#MainContent"
      blocking="render"
      id="view-transition-render-blocker"
    >
    <link href="https://fonts.googleapis.com/css2?family=Allura&display=swap" rel="stylesheet">



    {%- render 'meta-tags' -%}
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    {{ content_for_header }}
  </head>

  <body class="page-width-{{ settings.page_width }} card-hover-effect-{{ settings.card_hover_effect }}">
    {% render 'skip-to-content-link', href: '#MainContent', text: 'accessibility.skip_to_text' %}
    <div id="header-group">
      {% sections 'header-group' %}
    </div>

    <main
      id="MainContent"
      class="content-for-layout"
      role="main"
      data-page-transition-enabled="{{ settings.page_transition_enabled }}"
      data-product-transition="{{ settings.transition_to_main_product }}"
      data-template="{{ template }}"
    >
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    {% # theme-check-disable ParserBlockingScript %}
    <script src="{{ 'critical.js' | asset_url }}"></script>
    {% # theme-check-enable ParserBlockingScript %}

    <script src="{{ 'judgeme-cards-enhance.js' | asset_url }}" defer></script>




    {% render 'search-modal' %}

    {% if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add-modal' %}
    {% endif %}


  {% comment %} new js added by me {% endcomment %}
  {% comment %}this  jawascript added by me for show product stock inventory like 3left product    {% endcomment %}

    <script>
document.addEventListener('DOMContentLoaded', () => {
  const form = document.querySelector('form[action*="/cart/add"]');
  if (!form) return;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const inventoryEl = document.querySelector('.product-inventory__text');
    const qtyInput = form.querySelector('input[name="quantity"]');

    if (!inventoryEl || !qtyInput) return;

    const currentInventory = parseInt(inventoryEl.dataset.inventoryQty, 10);
    const selectedQty = parseInt(qtyInput.value, 10);

    if (isNaN(currentInventory) || isNaN(selectedQty)) return;

    const newInventory = Math.max(currentInventory - selectedQty, 0);

    /* --- ADD TO CART REQUEST --- */
    const formData = new FormData(form);

    const response = await fetch('/cart/add.js', {
      method: 'POST',
      body: formData,
      headers: {
        'Accept': 'application/json'
      }
    });

    if (!response.ok) return;

    /* --- UPDATE INVENTORY UI --- */
    inventoryEl.dataset.inventoryQty = newInventory;
    inventoryEl.textContent = `${newInventory} left`;
  });
});
</script>




<script>
document.querySelectorAll('.mega-menu__child').forEach(item => {
  item.addEventListener('mouseenter', () => {
    const img = item.dataset.image;
    const target = document.getElementById('megaHoverImg');

    if (img && target) {
      target.src = img;
      target.parentElement.classList.add('active');
    }
  });

  item.addEventListener('mouseleave', () => {
    document.querySelector('.mega-menu-hover-image')?.classList.remove('active');
  });
});
</script>



    {% render 'newsletter-popup' %}

    <!-- Global: Auto-open cart drawer on any add-to-cart -->
    <script>
    (function() {
      var originalFetch = window.fetch;
      window.fetch = function() {
        var url = arguments[0];
        var isCartAdd = (typeof url === 'string' && url.indexOf('/cart/add') !== -1);

        var result = originalFetch.apply(this, arguments);

        if (isCartAdd) {
          result.then(function(response) {
            // Clone so the original .then() chain still works
            return response.clone().json();
          }).then(function() {
            // Fetch fresh cart and open drawer
            return originalFetch('/cart.js').then(function(r) { return r.json(); });
          }).then(function(cartData) {
            openCartDrawerWithData(cartData);
          }).catch(function() {});
        }

        return result;
      };

      function openCartDrawerWithData(cartData) {
        var drawer = document.getElementById('custom-cart-drawer');
        var overlay = document.getElementById('custom-cart-overlay');
        if (!drawer || !overlay) return;

        // Update cart count badges everywhere
        document.querySelectorAll('[data-cart-count]').forEach(function(el) {
          el.textContent = cartData.item_count;
        });

        // Update total price
        var totalEl = document.querySelector('.custom-cart-drawer__total-price');
        if (totalEl && typeof formatMoney === 'function') {
          totalEl.textContent = formatMoney(cartData.total_price);
        }

        // Rebuild cart items HTML
        var contentEl = document.querySelector('.custom-cart-drawer__content');
        if (contentEl && cartData.items.length > 0) {
          var itemsHtml = '<form action="/cart" method="post" id="custom-cart-form">';
          cartData.items.forEach(function(item, index) {
            var variantOptions = '';
            if (item.variant_title) {
              variantOptions = '<p class="custom-cart-drawer__item-variant">' + item.variant_title + '</p>';
            }
            itemsHtml += '<div class="custom-cart-drawer__item" data-line-key="' + item.key + '" data-line-index="' + (index + 1) + '">' +
              '<div class="custom-cart-drawer__item-image">' +
                (item.image ? '<a href="' + item.url + '"><img src="' + item.image + '" loading="lazy" width="150"></a>' : '') +
              '</div>' +
              '<div class="custom-cart-drawer__item-details">' +
                '<a href="' + item.url + '" class="custom-cart-drawer__item-title">' + item.title + '</a>' +
                variantOptions +
                '<div class="custom-cart-drawer__item-price">' + formatMoney(item.final_price) + '</div>' +
                '<div class="custom-cart-drawer__quantity">' +
                  '<button type="button" class="custom-cart-drawer__qty-btn" aria-label="Decrease quantity" onclick="updateCartQty(this, -1)">−</button>' +
                  '<span class="custom-cart-drawer__qty-value">' + item.quantity + '</span>' +
                  '<button type="button" class="custom-cart-drawer__qty-btn" aria-label="Increase quantity" onclick="updateCartQty(this, 1)">+</button>' +
                '</div>' +
              '</div>' +
              '<div class="custom-cart-drawer__item-line-price">' + formatMoney(item.final_line_price) + '</div>' +
            '</div>';
          });
          itemsHtml += '</form>';
          contentEl.innerHTML = itemsHtml;

          // Show footer if it was hidden (cart was empty before)
          var footer = document.querySelector('.custom-cart-drawer__footer');
          if (footer) footer.style.display = '';
          var shipping = document.querySelector('.custom-cart-drawer__shipping-banner');
          if (shipping) shipping.style.display = '';

          // Update total
          if (totalEl) totalEl.textContent = formatMoney(cartData.total_price);
        }

        // Open the drawer
        drawer.classList.add('is-open');
        overlay.classList.add('is-open');
      }
    })();
    </script>
  </body>
</html>
