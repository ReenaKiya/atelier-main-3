{%- liquid
  if template == 'collection' and current_tags.size > 0
    # Sorted handles for a stable combined lookup
    assign tag_handles_joined = ''
    for t in current_tags
      assign t_handle = t | handleize
      if tag_handles_joined == ''
        assign tag_handles_joined = t_handle
      else
        assign tag_handles_joined = tag_handles_joined | append: '|' | append: t_handle
      endif
    endfor
    assign sorted_tag_handles = tag_handles_joined | split: '|' | sort

    # 1) Try combined handle: collection-handle--tag1--tag2--...
    assign combo_handle = collection.handle
    for h in sorted_tag_handles
      assign combo_handle = combo_handle | append: '--' | append: h
    endfor
    assign tag_seo = shop.metaobjects.tag_collection_seo[combo_handle]

    # 2) Fall back to the first single-tag entry that exists
    unless tag_seo
      for t in current_tags
        assign t_handle = t | handleize
        assign single_handle = collection.handle | append: '--' | append: t_handle
        assign found_single = shop.metaobjects.tag_collection_seo[single_handle]
        if found_single
          assign tag_seo = found_single
          break
        endif
      endfor
   endunless


    # Build the multi-tag URL path (preserves URL order, joined with '+')
    assign tag_url_path = ''
    for t in current_tags
      assign t_handle = t | handleize
      if tag_url_path == ''
        assign tag_url_path = t_handle
      else
        assign tag_url_path = tag_url_path | append: '+' | append: t_handle
      endif
    endfor
  endif
-%}




<meta charset="utf-8">
<meta
  http-equiv="X-UA-Compatible"
  content="IE=edge"
>
<meta
  name="viewport"
  content="width=device-width,initial-scale=1"
>
<meta
  name="view-transition"
  content="same-origin"
>
<meta
  name="theme-color"
  content=""
>

{%- liquid
  assign og_title = page_title | default: shop.name
  assign og_url = canonical_url | default: request.origin
  assign og_type = 'website'
  assign og_description = page_description | default: shop.description | default: shop.name

  if request.page_type == 'product'
    assign og_type = 'product'
  elsif request.page_type == 'article'
    assign og_type = 'article'
  elsif request.page_type == 'password'
    assign og_url = request.origin
  endif

  if tag_seo and tag_seo.seo_title.value != blank
    assign og_title = tag_seo.seo_title.value
  endif
  if tag_seo and tag_seo.seo_description.value != blank
    assign og_description = tag_seo.seo_description.value
  endif
  if tag_seo
    assign og_url = shop.url | append: '/collections/' | append: collection.handle | append: '/' | append: tag_url_path
  endif
%}

<meta
  property="og:site_name"
  content="{{ shop.name }}"
>
<meta
  property="og:url"
  content="{{ og_url }}"
>
<meta
  property="og:title"
  content="{{ og_title | escape }}"
>
<meta
  property="og:type"
  content="{{ og_type }}"
>
<meta
  property="og:description"
  content="{{ og_description | escape }}"
>

{%- if page_image -%}
  <meta
    property="og:image"
    content="http:{{ page_image | image_url }}"
  >
  <meta
    property="og:image:secure_url"
    content="https:{{ page_image | image_url }}"
  >
  <meta
    property="og:image:width"
    content="{{ page_image.width }}"
  >
  <meta
    property="og:image:height"
    content="{{ page_image.height }}"
  >
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <meta
    property="og:price:amount"
    content="{{ product.price | money_without_currency | strip_html }}"
  >
  <meta
    property="og:price:currency"
    content="{{ cart.currency.iso_code }}"
  >
{%- endif -%}

{%- if settings.social_twitter_link != blank -%}
  <meta
    name="twitter:site"
    content="{{ settings.social_twitter_link | split: 'twitter.com/' | last | prepend: '@' }}"
  >
{%- endif -%}
<meta
  name="twitter:card"
  content="summary_large_image"
>
<meta
  name="twitter:title"
  content="{{ og_title | escape }}"
>
<meta
  name="twitter:description"
  content="{{ og_description | escape }}"
>









{% if tag_seo and tag_seo.seo_title.value != blank %}
  <title>{{ tag_seo.seo_title.value }}</title>
{% else %}
  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>
{% endif %}

{% if tag_seo and tag_seo.seo_description.value != blank %}
  <meta
    name="description"
    content="{{ tag_seo.seo_description.value | escape }}"
  >
{% elsif page_description %}
  <meta
    name="description"
    content="{{ page_description | escape }}"
  >
{% endif %}

{% if tag_seo %}
  <link
    rel="canonical"
    href="{{ shop.url }}/collections/{{ collection.handle }}/{{ tag_url_path }}"
  >
{% else %}
  <link
    rel="canonical"
    href="{{ canonical_url }}"
  >
{% endif %}





