{%- doc -%}
  Renders filter remove buttons.

  Accepts:

  @param {object} filters - The filters to render
  @param {boolean} show_filter_label - Whether to show the filter label
  @param {string} results_url - The results URL
  @param {boolean} should_show_clear_all - Whether to show the clear all button
{%- enddoc -%}

<div class="facets-remove facets-remove--mobile-and-vertical">
  {%- liquid
    # Capture preserved query (sort + price) once so each remove pill keeps them.
    assign preserved_query = ''
    if request.path contains '/collections/'
      capture preserved_query
        if collection.sort_by != blank and collection.sort_by != collection.default_sort_by
          echo 'sort_by=' | append: collection.sort_by
        endif
      endcapture
    endif
  -%}
  {%- for filter in filters -%}
    {%- liquid
      assign is_first_filter = forloop.first

      # Determine if this filter resolves to a tag-based URL. Only on collection pages —
      # search results don't have current_tags routing.
      assign filter_is_tag = false
      assign filter_tag_prefix = ''
      if collection.url != blank
        if filter.param_name contains 'filter.p.m.'
          assign param_parts = filter.param_name | split: '.'
          assign last_part = param_parts | last
          assign filter_tag_prefix = last_part | replace: '_', '-' | downcase
          assign filter_is_tag = true
        elsif filter.param_name == 'filter.p.tag'
          assign filter_is_tag = true
        endif
      endif
    -%}
    {% if filter.type == 'price_range' and filter.min_value.value != null or filter.max_value.value != null %}
      {%- liquid
        assign is_active = true
      -%}
      <facet-remove-component
        class="
          pills__pill
          pills__pill--desktop-small
          facets-remove__pill
        "
        data-url="{{ filter.url_to_remove }}"
        tabindex="0"
        role="button"
        on:click="/removeFilter?form="
        on:keydown="/removeFilter?form="
        {% if is_first_filter and forloop.first %}
          autofocus
        {% endif %}
      >
        {%- if filter.min_value.value != null and filter.max_value.value != null %}
          {{- filter.min_value.value | money -}}
          –
          {{- filter.max_value.value | money -}}
        {%- elsif filter.min_value.value != null -%}
          {{ filter.min_value.value | money }}–{{ filter.range_max | money }}
        {%- elsif filter.max_value.value != null -%}
          {{- 0 | money -}}
          –
          {{- filter.max_value.value | money -}}
        {%- endif -%}
        <span class="svg-wrapper svg-wrapper--smaller">
          {{- 'icon-filters-close.svg' | inline_asset_content -}}
        </span>
        <span class="visually-hidden">{{ 'actions.remove' | t }}</span>
      </facet-remove-component>
    {% else %}
      {%- liquid
        # For tag-based filters, iterate filter.values and skip those not in current_tags
        # (Shopify's own filter.active_values doesn't see tag-routed filters). For non-tag
        # filters, iterate filter.active_values as before.
        if filter_is_tag
          assign iter_source = filter.values
        else
          assign iter_source = filter.active_values
        endif
      -%}
      {%- for value in iter_source -%}
        {%- liquid
          assign skip_value = false
          if filter_is_tag
            if filter.param_name == 'filter.p.tag'
              assign vt = value.value | handleize
              assign vt_alt = value.label | handleize
            else
              assign vt = filter_tag_prefix | append: '-' | append: value.label | handleize
              assign vt_alt = filter_tag_prefix | append: '-' | append: value.value | handleize
            endif
            assign tag_match = false
            for ct in current_tags
              assign ct_norm = ct | handleize
              if ct_norm == vt or ct_norm == vt_alt
                assign tag_match = true
                break
              endif
            endfor
            unless tag_match
              assign skip_value = true
            endunless
          endif
        -%}
        {%- if skip_value -%}{%- continue -%}{%- endif -%}
        {%- liquid
          assign is_active = true

          # Compute tag-based remove URL: rebuild path from current_tags minus this value's tag.
          assign value_remove_url = value.url_to_remove
          if filter_is_tag
            if filter.param_name == 'filter.p.tag'
              assign this_tag = value.value | handleize
              assign this_tag_alt = value.label | handleize
            else
              assign this_tag = filter_tag_prefix | append: '-' | append: value.label | handleize
              assign this_tag_alt = filter_tag_prefix | append: '-' | append: value.value | handleize
            endif

            assign remaining_tags = ''
            for ct in current_tags
              assign ct_norm = ct | handleize
              if ct_norm != this_tag and ct_norm != this_tag_alt
                if remaining_tags == ''
                  assign remaining_tags = ct_norm
                else
                  assign remaining_tags = remaining_tags | append: '+' | append: ct_norm
                endif
              endif
            endfor

            capture value_remove_url
              echo collection.url
              if remaining_tags != ''
                echo '/' | append: remaining_tags
              endif
              if preserved_query != ''
                echo '?' | append: preserved_query
              endif
            endcapture
          endif
        -%}
        <facet-remove-component
          class="
            pills__pill
            pills__pill--desktop-small
            facets-remove__pill
            {% if value.swatch %}pills__pill--swatch{% endif %}
          "
          data-url="{{ value_remove_url }}"
          tabindex="0"
          role="button"
          on:click="/removeFilter?form="
          on:keydown="/removeFilter?form="
          {% if is_first_filter and forloop.first %}
            autofocus
          {% endif %}
        >
          {% if value.swatch %}
            {% render 'swatch', swatch: value.swatch, mode: 'pill' %}
          {% endif %}

          {% if filter.type == 'boolean' or show_filter_label %}
            {{ filter.label | escape }}: {{ value.label | escape }}
          {% else %}
            {{ value.label | escape }}
          {% endif %}

          <span class="svg-wrapper svg-wrapper--smaller">
            {{- 'icon-filters-close.svg' | inline_asset_content -}}
          </span>
          <span class="visually-hidden">{{ 'actions.remove' | t }}</span>
        </facet-remove-component>
      {%- endfor -%}
    {% endif %}
  {%- endfor -%}
  {% if should_show_clear_all and is_active %}
    <facet-remove-component
      data-url="{{ results_url }}"
    >
      <button
        type="button"
        class="button-unstyled facets__clear-all-link facets__clear-all{% if is_active %} active{% endif %}"
        ref="clearButton"
        on:click="/removeFilter?form="
        on:keydown="/removeFilter?form="
      >
        {{- 'actions.clear_all' | t -}}
      </button>
    </facet-remove-component>
  {% endif %}
</div>

{% stylesheet %}
  /* Facets - Remove buttons */
  .facets-remove {
    --variant-picker-swatch-width: 20px;
    --variant-picker-swatch-height: 20px;

    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--gap-xs);
    padding: 0 var(--drawer-padding);
    margin-block-start: var(--margin-2xs);
    margin-block-end: var(--margin-md);

    @media screen and (min-width: 750px) {
      --variant-picker-swatch-width: 16px;
      --variant-picker-swatch-height: 16px;

      gap: var(--gap-2xs);
    }
  }

  .facets__clear-all-link {
    --button-color: var(--color-primary);

    border: none;
    background-color: transparent;
    padding: var(--padding-xs);
    min-width: fit-content;
    color: var(--button-color);
    transition: text-decoration-color var(--animation-speed) var(--animation-easing),
      color var(--animation-speed) var(--animation-easing);
  }

  .facets__clear-all-link:hover {
    --button-color: var(--color-primary-hover);

    color: var(--button-color);
    text-decoration-color: var(--button-color);
  }

  .facets:not(.facets--drawer) .facets-remove--mobile-and-vertical {
    @media screen and (min-width: 750px) {
      padding: 0;
    }
  }

  .facets--horizontal .facets-remove--mobile-and-vertical {
    @media screen and (min-width: 750px) {
      display: none;
    }
  }

  .facets-remove:not(:has(facet-remove-component)) {
    display: none;
    margin: 0;
  }

  .facets-remove__pill {
    background: #db1e37;
    color: #fff;

    .svg-wrapper,
    .swatch {
      flex-shrink: 0;
      color: #fff;
    }

    &:hover {
      background: #b9162c;
    }
  }

  .facets--horizontal .facets-remove {
    @media screen and (min-width: 750px) {
      display: none;
    }
  }
{% endstylesheet %}
