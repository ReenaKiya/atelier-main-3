{%- comment -%}
  Tag-based filter sidebar — groups product tags by "Group-Value" pattern.

  Example tags on products:
    Type-Flat Back Studs
    Material-14K, Material-14K/Bioflex, Material-9K
    Thread Type-Internally Threaded, Thread Type-Push Fit
    Stone-Amethyst, Stone-Cubic Zirconia, Stone-Lab Grown Diamond

  URLs use Shopify's native tag filter: /collections/{handle}/{tag1}+{tag2}
  Clicking a tag adds it to the URL; clicking an active tag removes it.

  Renders alongside (or instead of) the modern storefront filters block.
{%- endcomment -%}

{%- liquid
  assign group_order = 'Type,Material,Thread Type,Stone,Color,Colour,Size,Length,Thickness,Gauge'
  assign group_order_arr = group_order | split: ','

  comment
    Pass 1: collect all tags, parse "Group-Value" format.
    Use remove_first to strip the prefix (no `shift` filter exists in Liquid).
  endcomment
  assign all_tag_pairs = ''
  for tag in collection.all_tags
    if tag contains '-'
      assign group_name = tag | split: '-' | first
      assign value_name = tag | remove_first: group_name | remove_first: '-'
      assign all_tag_pairs = all_tag_pairs | append: group_name | append: '|||' | append: value_name | append: '|||' | append: tag | append: '~~~'
    endif
  endfor
  assign all_pairs_arr = all_tag_pairs | split: '~~~'

  comment
    Build a unique list of group names.
    Bookend with ~~~ so the `contains` check matches whole names only —
    otherwise "Thread Type" contains "Type" as a substring and the
    "Type" group would be silently dropped.
  endcomment
  assign unique_groups = '~~~'
  for pair in all_pairs_arr
    if pair == blank
      continue
    endif
    assign pair_parts = pair | split: '|||'
    assign g = pair_parts[0]
    assign needle = '~~~' | append: g | append: '~~~'
    unless unique_groups contains needle
      assign unique_groups = unique_groups | append: g | append: '~~~'
    endunless
  endfor
  assign unique_groups_arr = unique_groups | split: '~~~'

  comment
    Reorder: preferred groups first, then any remaining alphabetically.
  endcomment
  assign sorted_groups = '~~~'
  for preferred in group_order_arr
    assign preferred_trim = preferred | strip
    for g in unique_groups_arr
      if g == preferred_trim
        assign sorted_groups = sorted_groups | append: g | append: '~~~'
      endif
    endfor
  endfor
  for g in unique_groups_arr
    assign needle = '~~~' | append: g | append: '~~~'
    unless sorted_groups contains needle
      assign sorted_groups = sorted_groups | append: g | append: '~~~'
    endunless
  endfor
  assign sorted_groups_arr = sorted_groups | split: '~~~'
-%}

<aside class="tagfilter" data-tagfilter>
  <div class="tagfilter__header">
    <h2 class="tagfilter__title">Filters</h2>
    {% if current_tags.size > 0 %}
      <a href="{{ collection.url }}" class="tagfilter__clear-all">Clear all</a>
    {% endif %}
  </div>

  {%- if sorted_groups_arr.size <= 1 -%}
    <div class="tagfilter__empty">
      <p><strong>No filters available yet.</strong></p>
      <p>Tag your products with the pattern <code>Group-Value</code> in Shopify Admin to populate filters.</p>
      <p>Examples: <code>Material-14K</code>, <code>Stone-Amethyst</code>, <code>Thread Type-Push Fit</code>, <code>Type-Flat Back Studs</code></p>
    </div>
  {%- endif -%}

  {%- for group in sorted_groups_arr -%}
    {%- if group == blank -%}{% continue %}{%- endif -%}
    {%- liquid
      assign group_values = ''
      for pair in all_pairs_arr
        if pair == blank
          continue
        endif
        assign pair_parts = pair | split: '|||'
        if pair_parts[0] == group
          unless group_values contains pair_parts[2]
            assign group_values = group_values | append: pair_parts[1] | append: '|||' | append: pair_parts[2] | append: '~~~'
          endunless
        endif
      endfor
      assign group_values_arr = group_values | split: '~~~'
      assign group_id = group | handle
    -%}

    <details class="tagfilter__group" open data-tagfilter-group>
      <summary class="tagfilter__group-summary">
        <h3 class="tagfilter__group-title">{{ group }}</h3>
        <span class="tagfilter__chevron" aria-hidden="true">
          <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
      </summary>

      <ul class="tagfilter__list">
        {%- for entry in group_values_arr -%}
          {%- if entry == blank -%}{% continue %}{%- endif -%}
          {%- liquid
            assign entry_parts = entry | split: '|||'
            assign value_label = entry_parts[0]
            assign full_tag = entry_parts[1]
            assign tag_handle = full_tag | handle
            assign is_active = false
            if current_tags contains full_tag
              assign is_active = true
            endif

            comment
              Count products that carry this tag in the current collection
            endcomment
            assign tag_count = 0
            for product in collection.products
              if product.tags contains full_tag
                assign tag_count = tag_count | plus: 1
              endif
            endfor

            comment
              Build URL for this tag: toggle it in/out of current_tags.
              Handleize each tag separately (the `handle` filter strips `+`,
              so concatenating first and handleizing after eats the separator).
            endcomment
            assign new_tags = ''
            for t in current_tags
              if t == full_tag
                continue
              endif
              assign t_handle = t | handle
              if new_tags == ''
                assign new_tags = t_handle
              else
                assign new_tags = new_tags | append: '+' | append: t_handle
              endif
            endfor
            unless is_active
              if new_tags == ''
                assign new_tags = tag_handle
              else
                assign new_tags = new_tags | append: '+' | append: tag_handle
              endif
            endunless

            if new_tags == ''
              assign tag_url = collection.url
            else
              assign tag_url = collection.url | append: '/' | append: new_tags
            endif
          -%}
          <li class="tagfilter__item{% if is_active %} tagfilter__item--active{% endif %}">
            <a href="{{ tag_url }}" class="tagfilter__link" data-tag="{{ full_tag | escape }}">
              <span class="tagfilter__checkbox" aria-hidden="true">
                {% if is_active %}
                  <svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M2.5 7L5.5 10L11.5 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                {% endif %}
              </span>
              <span class="tagfilter__label">{{ value_label }}</span>
              {% if tag_count > 0 %}
                <span class="tagfilter__count">({{ tag_count }})</span>
              {% endif %}
            </a>
          </li>
        {%- endfor -%}
      </ul>
    </details>
  {%- endfor -%}

  {%- comment -%} Price filter — uses Shopify storefront price filter if enabled, else falls back to defaults. {%- endcomment -%}
  {%- liquid
    assign price_filter = nil
    for f in collection.filters
      if f.type == 'price_range'
        assign price_filter = f
        break
      endif
    endfor

    assign price_floor = 4
    if price_filter
      assign price_ceiling = price_filter.range_max | divided_by: 100
      if price_filter.min_value.value != null
        assign price_current_min = price_filter.min_value.value | divided_by: 100
      else
        assign price_current_min = price_floor
      endif
      if price_filter.max_value.value != null
        assign price_current_max = price_filter.max_value.value | divided_by: 100
      else
        assign price_current_max = price_ceiling
      endif
      assign min_param = price_filter.min_value.param_name
      assign max_param = price_filter.max_value.param_name
    else
      assign price_ceiling = 790
      assign price_current_min = price_floor
      assign price_current_max = price_ceiling
      assign min_param = 'filter.v.price.gte'
      assign max_param = 'filter.v.price.lte'
    endif

    if price_current_min < price_floor
      assign price_current_min = price_floor
    endif
    if price_current_max > price_ceiling
      assign price_current_max = price_ceiling
    endif

    assign price_span = price_ceiling | minus: price_floor
    if price_span <= 0
      assign price_span = 1
    endif
    assign min_offset = price_current_min | minus: price_floor
    assign max_offset = price_current_max | minus: price_floor
    assign fill_left_pct = min_offset | times: 100 | divided_by: price_span
    assign fill_right_pct_raw = max_offset | times: 100 | divided_by: price_span
    assign fill_right_pct = 100 | minus: fill_right_pct_raw

    assign price_is_active = false
    if price_current_min > price_floor or price_current_max < price_ceiling
      assign price_is_active = true
    endif
  -%}

  <div class="tagfilter__price">
    <div class="tagfilter__price-header">
      <span class="tagfilter__price-title">Price</span>
      <button
        type="button"
        class="tagfilter__price-clear{% if price_is_active %} is-active{% endif %}"
        data-price-clear
      >
        Clear
      </button>
    </div>

    <form
      method="get"
      action="{{ request.path }}"
      class="tagfilter__price-form"
      data-price-form
      data-price-floor="{{ price_floor }}"
      data-price-ceiling="{{ price_ceiling }}"
    >
      <div class="tagfilter__price-slider" data-price-slider>
        <div class="tagfilter__price-track"></div>
        <div
          class="tagfilter__price-fill"
          data-price-fill
          style="left: {{ fill_left_pct }}%; right: {{ fill_right_pct }}%;"
        ></div>
        <input
          type="range"
          class="tagfilter__price-range tagfilter__price-range--min"
          min="{{ price_floor }}"
          max="{{ price_ceiling }}"
          value="{{ price_current_min }}"
          step="1"
          aria-label="Minimum price"
          data-price-range-min
        >
        <input
          type="range"
          class="tagfilter__price-range tagfilter__price-range--max"
          min="{{ price_floor }}"
          max="{{ price_ceiling }}"
          value="{{ price_current_max }}"
          step="1"
          aria-label="Maximum price"
          data-price-range-max
        >
      </div>

      <div class="tagfilter__price-inputs">
        <div class="tagfilter__price-field">
          <span class="tagfilter__price-currency" aria-hidden="true">$</span>
          <input
            type="number"
            class="tagfilter__price-input"
            name="{{ min_param }}"
            value="{{ price_current_min }}"
            min="{{ price_floor }}"
            max="{{ price_ceiling }}"
            aria-label="Minimum price"
            data-price-input-min
            autocomplete="off"
          >
        </div>
        <span class="tagfilter__price-to">to</span>
        <div class="tagfilter__price-field">
          <span class="tagfilter__price-currency" aria-hidden="true">$</span>
          <input
            type="number"
            class="tagfilter__price-input"
            name="{{ max_param }}"
            value="{{ price_current_max }}"
            min="{{ price_floor }}"
            max="{{ price_ceiling }}"
            aria-label="Maximum price"
            data-price-input-max
            autocomplete="off"
          >
        </div>
      </div>

      <noscript>
        <button type="submit" class="tagfilter__price-apply">Apply</button>
      </noscript>
    </form>
  </div>
</aside>

<script>
  (function () {
    var form = document.querySelector('[data-price-form]');
    if (!form) return;

    var floor = parseInt(form.dataset.priceFloor, 10);
    var ceiling = parseInt(form.dataset.priceCeiling, 10);
    var span = ceiling - floor || 1;

    var rangeMin = form.querySelector('[data-price-range-min]');
    var rangeMax = form.querySelector('[data-price-range-max]');
    var inputMin = form.querySelector('[data-price-input-min]');
    var inputMax = form.querySelector('[data-price-input-max]');
    var fill = form.querySelector('[data-price-fill]');
    var clearBtn = document.querySelector('[data-price-clear]');

    function clamp(value, min, max) {
      value = isNaN(value) ? min : value;
      return Math.min(Math.max(value, min), max);
    }

    function updateFill() {
      var minVal = clamp(parseInt(rangeMin.value, 10), floor, ceiling);
      var maxVal = clamp(parseInt(rangeMax.value, 10), floor, ceiling);
      if (minVal > maxVal) {
        var tmp = minVal; minVal = maxVal; maxVal = tmp;
      }
      var leftPct = ((minVal - floor) / span) * 100;
      var rightPct = 100 - ((maxVal - floor) / span) * 100;
      fill.style.left = leftPct + '%';
      fill.style.right = rightPct + '%';
    }

    function pruneDefaults() {
      inputMin.disabled = parseInt(inputMin.value, 10) <= floor;
      inputMax.disabled = parseInt(inputMax.value, 10) >= ceiling;
    }

    var submitTimer;
    function scheduleSubmit() {
      clearTimeout(submitTimer);
      submitTimer = setTimeout(function () {
        pruneDefaults();
        form.submit();
      }, 600);
    }

    form.addEventListener('submit', pruneDefaults);

    function syncFromRange(which) {
      var minVal = clamp(parseInt(rangeMin.value, 10), floor, ceiling);
      var maxVal = clamp(parseInt(rangeMax.value, 10), floor, ceiling);
      if (which === 'min' && minVal > maxVal) {
        rangeMin.value = maxVal;
        minVal = maxVal;
      }
      if (which === 'max' && maxVal < minVal) {
        rangeMax.value = minVal;
        maxVal = minVal;
      }
      inputMin.value = minVal;
      inputMax.value = maxVal;
      updateFill();
    }

    function syncFromInput(which) {
      var minVal = clamp(parseInt(inputMin.value, 10), floor, ceiling);
      var maxVal = clamp(parseInt(inputMax.value, 10), floor, ceiling);
      if (which === 'min' && minVal > maxVal) minVal = maxVal;
      if (which === 'max' && maxVal < minVal) maxVal = minVal;
      rangeMin.value = minVal;
      rangeMax.value = maxVal;
      updateFill();
    }

    rangeMin.addEventListener('input', function () { syncFromRange('min'); });
    rangeMax.addEventListener('input', function () { syncFromRange('max'); });
    rangeMin.addEventListener('change', scheduleSubmit);
    rangeMax.addEventListener('change', scheduleSubmit);

    inputMin.addEventListener('input', function () { syncFromInput('min'); });
    inputMax.addEventListener('input', function () { syncFromInput('max'); });
    inputMin.addEventListener('change', function () {
      inputMin.value = clamp(parseInt(inputMin.value, 10), floor, ceiling);
      scheduleSubmit();
    });
    inputMax.addEventListener('change', function () {
      inputMax.value = clamp(parseInt(inputMax.value, 10), floor, ceiling);
      scheduleSubmit();
    });

    if (clearBtn) {
      clearBtn.addEventListener('click', function () {
        var url = new URL(window.location.href);
        url.searchParams.delete(inputMin.name);
        url.searchParams.delete(inputMax.name);
        window.location.href = url.pathname + (url.search ? url.search : '');
      });
    }
  })();
</script>

<style>
  /* ===== Grid placement: dock sidebar flush to the left =====
     Override the wrapper's default layout (which relies on Shopify's
     storefront-filter block CSS variables that aren't set here). */
  .collection-wrapper:has(> .tagfilter) {
    display: grid !important;
    grid-template-columns: 240px minmax(0, 1fr) !important;
    column-gap: 24px;
    row-gap: 0;
    padding-inline: 16px;
    max-width: none;
    margin: 0;
    align-items: start;
  }

  .collection-wrapper > .tagfilter {
    grid-column: 1;
    grid-row: 1;
    padding-block-start: 8px;
  }

  .collection-wrapper:has(> .tagfilter) > .main-collection-column {
    grid-column: 2 !important;
    grid-row: 1 !important;
    padding-inline: 0 !important;
  }

  /* Tighten the gap between the page title and the product grid */
  .collection-wrapper:has(> .tagfilter) .collection--title {
    margin-bottom: 16px;
  }

  /* Force the product grid to 5 columns on desktop when the tag sidebar is active.
     The grid uses --product-grid-columns-desktop, so override that. */
  .collection-wrapper:has(> .tagfilter) .product-grid {
    --product-grid-columns-desktop: repeat(5, minmax(0, 1fr)) !important;
    grid-template-columns: repeat(5, minmax(0, 1fr)) !important;
  }

  .collection-wrapper:has(> .tagfilter) .product-grid__item {
    grid-column: auto !important;
    width: auto !important;
    max-width: none !important;
  }

  /* Tablet: 3 per row */
  @media (max-width: 1199px) and (min-width: 750px) {
    .collection-wrapper:has(> .tagfilter) .product-grid {
      --product-grid-columns-desktop: repeat(3, minmax(0, 1fr)) !important;
      grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
    }
  }

  /* Mobile: stack vertically, 2 products per row */
  @media (max-width: 749px) {
    .collection-wrapper:has(> .tagfilter) {
      grid-template-columns: 1fr !important;
      column-gap: 0;
      padding-inline: 12px;
    }
    .collection-wrapper > .tagfilter,
    .collection-wrapper:has(> .tagfilter) > .main-collection-column {
      grid-column: 1 !important;
    }
    .collection-wrapper:has(> .tagfilter) > .main-collection-column {
      grid-row: 2 !important;
    }
    .collection-wrapper:has(> .tagfilter) .product-grid {
      --product-grid-columns-desktop: repeat(2, minmax(0, 1fr)) !important;
      grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
    }
  }

  .tagfilter {
    width: 100%;
    font-family: inherit;
    color: #222;
  }

  .tagfilter__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 12px;
    border-bottom: 1px solid #e5e5e5;
    margin-bottom: 8px;
  }

  .tagfilter__title {
    margin: 0;
    font-size: 18px;
    font-weight: 500;
  }

  .tagfilter__clear-all {
    font-size: 12px;
    color: #da1e37;
    text-decoration: none;
    font-weight: 500;
  }

  .tagfilter__clear-all:hover {
    text-decoration: underline;
  }

  .tagfilter__group {
    border-bottom: 1px solid #f0f0f0;
    padding: 14px 0;
  }

  .tagfilter__group-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  .tagfilter__group-summary::-webkit-details-marker {
    display: none;
  }

  .tagfilter__group-title {
    margin: 0;
    font-size: 14px;
    font-weight: 600;
    color: #111;
  }

  .tagfilter__chevron {
    display: inline-flex;
    transition: transform 0.2s ease;
    color: #555;
  }

  .tagfilter__group:not([open]) .tagfilter__chevron {
    transform: rotate(-90deg);
  }

  .tagfilter__list {
    list-style: none;
    padding: 10px 0 0;
    margin: 0;
  }

  .tagfilter__item {
    padding: 6px 0;
  }

  .tagfilter__link {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: #333;
    font-size: 13px;
    transition: color 0.15s ease;
  }

  .tagfilter__link:hover {
    color: #000;
  }

  .tagfilter__checkbox {
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    border: 1.5px solid #888;
    border-radius: 3px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    background: #fff;
    transition: background 0.15s ease, border-color 0.15s ease;
  }

  .tagfilter__item--active .tagfilter__checkbox {
    background: #111;
    border-color: #111;
  }

  .tagfilter__item--active .tagfilter__label {
    font-weight: 500;
  }

  .tagfilter__label {
    line-height: 1.3;
    flex: 1;
  }

  .tagfilter__count {
    color: #888;
    font-size: 12px;
    margin-left: 4px;
  }

  .tagfilter__empty {
    padding: 16px;
    background: #fff8e1;
    border: 1px solid #f3d573;
    border-radius: 6px;
    font-size: 12px;
    color: #5a4a00;
    line-height: 1.5;
  }
  .tagfilter__empty p { margin: 0 0 6px; }
  .tagfilter__empty p:last-child { margin-bottom: 0; }
  .tagfilter__empty code {
    background: #fff;
    padding: 1px 5px;
    border-radius: 3px;
    font-size: 11px;
    border: 1px solid #ddd;
  }

  @media (max-width: 749px) {
    .tagfilter {
      max-width: none;
    }
  }

  /* ===== Price filter ===== */
  .tagfilter__price {
    padding: 18px 0 14px;
    border-bottom: 1px solid #f0f0f0;
  }

  .tagfilter__price-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 14px;
  }

  .tagfilter__price-title {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #111;
  }

  .tagfilter__price-clear {
    background: transparent;
    border: none;
    padding: 0;
    cursor: pointer;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #e3173e;
    opacity: 0.55;
  }

  .tagfilter__price-clear.is-active {
    opacity: 1;
  }

  .tagfilter__price-clear:hover {
    color: #b8122f;
  }

  .tagfilter__price-form {
    margin: 0;
  }

  .tagfilter__price-slider {
    position: relative;
    width: 100%;
    height: 18px;
    margin: 0 0 14px;
  }

  .tagfilter__price-track {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 3px;
    background: #e81a48;
    border-radius: 2px;
    transform: translateY(-50%);
    pointer-events: none;
  }

  .tagfilter__price-fill {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 3px;
    background: #e81a48;
    border-radius: 2px;
    transform: translateY(-50%);
    pointer-events: none;
  }

  .tagfilter__price-range {
    -webkit-appearance: none;
    appearance: none;
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 18px;
    background: transparent;
    margin: 0;
    padding: 0;
    outline: none;
    pointer-events: none;
  }

  .tagfilter__price-range--min { z-index: 3; }
  .tagfilter__price-range--max { z-index: 4; }

  .tagfilter__price-range::-webkit-slider-runnable-track {
    height: 18px;
    background: transparent;
    border: none;
  }

  .tagfilter__price-range::-moz-range-track {
    height: 18px;
    background: transparent;
    border: none;
  }

  .tagfilter__price-range::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #000;
    border: none;
    cursor: pointer;
    pointer-events: auto;
    margin-top: 0;
  }

  .tagfilter__price-range::-moz-range-thumb {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #000;
    border: none;
    cursor: pointer;
    pointer-events: auto;
  }

  .tagfilter__price-inputs {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .tagfilter__price-field {
    position: relative;
    flex: 1 1 0;
    min-width: 0;
  }

  .tagfilter__price-to {
    font-size: 13px;
    color: #555;
    flex: 0 0 auto;
  }

  .tagfilter__price-currency {
    position: absolute;
    left: 10px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 13px;
    color: #1f1f1f;
    pointer-events: none;
    line-height: 1;
  }

  .tagfilter__price-input {
