{%- doc -%}
  Renders a price filter.

  @param {object} filter - The filter object to render.
  @param {string} filter_style - The filter style, can be 'horizontal' or 'vertical'.
  @param {boolean} [autofocus] - Whether to autofocus the filter.
  @param {boolean} [should_render_clear] - Whether to render the clear button.

  @example
  {% render 'price-filter', filter: filter, filter_style: 'vertical' %}
{%- enddoc -%}

{% if filter_style == 'vertical' %}
  {%- if filter.min_value.value != null or filter.max_value.value != null -%}
    {%- assign has_active_values = true -%}
  {%- endif -%}
  <div class="facets__item facets__item--no-accordion price-facet-vertical">
    <div class="facets__filter-title-row">
      <div class="facets__filter-title">{{ filter.label }}</div>
      <facet-clear-component
        class="clear-filter price-clear-inline"
        tabindex="{% if has_active_values %}0{% else %}-1{% endif %}"
        on:click="/clearFilter"
        on:keydown="/clearFilter"
      >
        <div
          class="facets__clear {% if has_active_values %}facets__clear--active{% endif %}"
          ref="clearButton"
        >
          {{- 'actions.clear' | t -}}
        </div>
      </facet-clear-component>
    </div>
    <div class="facets__panel-content-open">
{% else %}
  <accordion-custom
    class="facets__item"
    data-disable-animation-on-desktop="true"
    data-close-with-escape="true"
    open-by-default-on-mobile
  >
    <details
      class="facets__panel"
      data-auto-close-details="desktop"
    >
      <summary class="facets__summary">
        <span class="facets__label">{{ filter.label }}</span>
        <facet-status-component class="facets__status">
          <template ref="moneyFormat">{{ shop.money_format }}</template>

          <span
            class="hide-when-empty"
            ref="facetStatus"
            data-currency="{{ localization.country.currency.iso_code }}"
            data-range-max="{{ filter.range_max }}"
          >
            {%- if filter.min_value.value != null or filter.max_value.value != null %}
              {%- if filter.min_value.value != null and filter.max_value.value != null %}
                {{- filter.min_value.value | money | strip_html -}}
                –
                {{- filter.max_value.value | money | strip_html -}}
              {%- elsif filter.min_value.value != null -%}
                {{ filter.min_value.value | money | strip_html }}–{{ filter.range_max | money | strip_html }}

              {%- elsif filter.max_value.value != null -%}
                {{- 0 | money | strip_html -}}
                –
                {{- filter.max_value.value | money | strip_html -}}
              {%- endif -%}
            {%- endif -%}
          </span>
        </facet-status-component>
        <span class="svg-wrapper icon-caret icon-animated">
          {{- 'icon-caret.svg' | inline_asset_content -}}
        </span>
      </summary>
      <floating-panel-component
        data-close-on-resize
        class="facets__panel-content details-content color-{{ settings.popover_color_scheme }}"
      >
{% endif %}
      {% assign min_input_max_value = filter.max_value.value | default: filter.range_max %}
      {% assign max_input_min_value = filter.min_value.value | default: 0 %}

      <price-facet-component
        class="price-facet"
        id="facet-inputs-{{ filter.param_name | escape | replace: '.', '-' }}"
        on:change="/updatePriceFilterAndResults"
      >
        {%- assign range_max_cents = filter.range_max -%}
        {%- if filter.min_value.value != null -%}
          {%- assign min_value_display = filter.min_value.value | divided_by: 100 -%}
        {%- else -%}
          {%- assign min_value_display = 4 -%}
        {%- endif -%}
        {%- if filter.max_value.value != null -%}
          {%- assign max_value_display = filter.max_value.value | divided_by: 100 -%}
        {%- else -%}
          {%- assign max_value_display = 790 -%}
        {%- endif -%}

        {%- assign range_span = 786 -%}
        {%- assign min_offset = min_value_display | minus: 4 -%}
        {%- assign max_offset = max_value_display | minus: 4 -%}
        {%- assign fill_left_pct = min_offset | times: 100 | divided_by: range_span -%}
        {%- assign fill_right_pct_raw = max_offset | times: 100 | divided_by: range_span -%}
        {%- assign fill_right_pct = 100 | minus: fill_right_pct_raw -%}

        <div class="price-facet__slider-wrap" ref="sliderWrap">
          <div class="price-facet__track"></div>
          <div
            class="price-facet__fill"
            ref="rangeFill"
            style="left: {{ fill_left_pct }}%; right: {{ fill_right_pct }}%;"
          ></div>
          <input
            type="range"
            class="price-facet__range-input price-facet__range-input--min"
            min="4"
            max="790"
            value="{{ min_value_display }}"
            step="1"
            ref="rangeMin"
            aria-label="Minimum price"
          >
          <input
            type="range"
            class="price-facet__range-input price-facet__range-input--max"
            min="4"
            max="790"
            value="{{ max_value_display }}"
            step="1"
            ref="rangeMax"
            aria-label="Maximum price"
          >
        </div>

        <div class="price-filter-inputs">
          <div class="price-facet__field">
            <span class="price-facet__currency" aria-hidden="true">$</span>
            <input
              type="number"
              class="price-facet__input"
              name="{{ filter.min_value.param_name }}"
              id="{{ filter.label | escape }}-GTE"
              value="{{ min_value_display }}"
              placeholder="Min"
              data-min="4"
              data-max="{{ max_value_display }}"
              ref="minInput"
              autocomplete="off"
              {% if autofocus %}
                autofocus
              {% endif %}
            >
          </div>
          <span class="price-facet__to">to</span>
          <div class="price-facet__field">
            <span class="price-facet__currency" aria-hidden="true">$</span>
            <input
              type="number"
              class="price-facet__input"
              name="{{ filter.max_value.param_name }}"
              id="{{ filter.label | escape }}-LTE"
              value="{{ max_value_display }}"
              placeholder="Max"
              data-min="{{ min_value_display }}"
              data-max="790"
              ref="maxInput"
              autocomplete="off"
              {% if autofocus %}
                autofocus
              {% endif %}
            >
          </div>
        </div>


        {% if filter.min_value.value != null or filter.max_value.value != null %}
          {% assign has_active_values = true %}
        {% endif %}

        {% if should_render_clear %}
          <facet-clear-component
            class="clear-filter"
            tabindex="{% if has_active_values %}0{% else %}-1{% endif %}"
            on:click="/clearFilter"
            on:keydown="/clearFilter"
          >
            <div
              class="facets__clear {% if has_active_values %}facets__clear--active{% endif %}"
              ref="clearButton"
            >
              {{- 'actions.clear' | t -}}
            </div>
          </facet-clear-component>
        {% endif %}
      </price-facet-component>
{% if filter_style == 'vertical' %}
    </div>
  </div>
{% else %}
    </floating-panel-component>
  </details>
</accordion-custom>
{% endif %}

{% stylesheet %}
  /* Price filter */
  .price-facet {
    container-type: inline-size;
    display: flex;
    flex-direction: column;
  }

  .price-facet__slider-wrap {
    position: relative;
    width: 100%;
    height: 20px;
    margin: 0 0 6px;
  }

  .price-facet__track {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 3px;
    background: #e81a48;
    border-radius: 2px;
    transform: translateY(-50%);
    pointer-events: none;
  }

  .price-facet__fill {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 3px;
    background: #e81a48;
    border-radius: 2px;
    transform: translateY(-50%);
    pointer-events: none;
  }

  .price-facet__fill--hidden {
    display: none;
  }

  .price-facet__range-input {
    -webkit-appearance: none;
    appearance: none;
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 18px;
    background: transparent;
    margin: 0;
    padding: 0;
    outline: none;
    pointer-events: none;
    touch-action: none;
  }

  .price-facet__range-input--min {
    z-index: 3;
  }

  .price-facet__range-input--max {
    z-index: 4;
  }

  .price-facet__range-input::-webkit-slider-runnable-track {
    height: 18px;
    background: transparent;
    border: none;
  }

  .price-facet__range-input::-moz-range-track {
    height: 18px;
    background: transparent;
    border: none;
  }

  .price-facet__range-input::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #000000;
    border: none;
    box-shadow: none;
    cursor: pointer;
    pointer-events: auto;
    margin-top: 0;
  }

  .price-facet__range-input::-moz-range-thumb {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #000000;
    border: none;
    box-shadow: none;
    cursor: pointer;
    pointer-events: auto;
  }

  .price-facet__range-input:focus {
    outline: none;
  }

  .price-filter-inputs {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 12px;
  }

  .price-facet__field {
    position: relative;
    flex: 1 1 0;
    min-width: 0;
  }

  .price-facet__to {
    font-size: 13px;
    color: #555;
    flex: 0 0 auto;
  }

  .price-facet__input {
    width: 100%;
    box-sizing: border-box;
    padding: 8px 22px 8px 24px;
    font-size: 13px;
    color: #1f1f1f;
    background: #ffffff;
    border: 1px solid #d0d0d0;
    border-radius: 4px;
    outline: none;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .price-facet__input:focus {
    border-color: #9a9a9a;
    box-shadow: none;
  }

  .price-facet__currency {
    position: absolute;
    left: 10px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 13px;
    color: #1f1f1f;
    pointer-events: none;
    line-height: 1;
  }

  .facets--horizontal .facets__panel-content:has(.price-facet) {
    min-width: 360px;
  }

  /* Scoped CLEAR button for price facet (red + uppercase, top-right) */
  .price-facet .clear-filter {
    position: absolute;
    top: 0;
    right: 0;
    margin: 0;
  }

  .price-facet .clear-filter .facets__clear,
  .price-clear-inline .facets__clear {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #e3173e;
    background: transparent;
    border: none;
    padding: 0;
    cursor: pointer;
  }

  .price-facet .clear-filter .facets__clear:hover,
  .price-clear-inline .facets__clear:hover {
    color: #b8122f;
  }

  .price-facet {
    position: relative;
    padding-top: 4px;
  }

  /* Vertical layout: PRICE title and CLEAR on the same row */
  .price-facet-vertical .facets__filter-title-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 12px 0 10px;
    border-bottom: none;
  }

  .facets--vertical .price-facet-vertical .facets__filter-title,
  .facets--drawer .price-facet-vertical .facets__filter-title,
  .price-facet-vertical .facets__filter-title-row .facets__filter-title {
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0;
    border-bottom: none;
    margin: 0;
    color: #111;
  }

  .price-clear-inline {
    position: static !important;
    display: inline-flex;
    align-items: center;
    background: transparent;
    box-shadow: none;
    padding: 0;
  }
{% endstylesheet %}
