<div class="rio-media-gallery" data-rio-media-mobile-target {{ block.shopify_attributes }}></div>

<script>
  (function () {
    if (window.__rioMobileMediaInit) return;
    window.__rioMobileMediaInit = true;

    var BREAKPOINT = '(max-width: 749px)';
    var mq = window.matchMedia(BREAKPOINT);

    function placeGallery() {
      var mobileTarget = document.querySelector('[data-rio-media-mobile-target]');
      var desktopContainer = document.querySelector('.product-information__media');
      var gallery =
        (desktopContainer && desktopContainer.querySelector('media-gallery')) ||
        (mobileTarget && mobileTarget.querySelector('media-gallery'));
      if (!gallery || !mobileTarget || !desktopContainer) return;

      if (mq.matches) {
        if (gallery.parentElement !== mobileTarget) {
          mobileTarget.appendChild(gallery);
        }
      } else {
        if (gallery.parentElement !== desktopContainer) {
          desktopContainer.appendChild(gallery);
        }
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', placeGallery);
    } else {
      placeGallery();
    }

    if (mq.addEventListener) {
      mq.addEventListener('change', placeGallery);
    } else if (mq.addListener) {
      mq.addListener(placeGallery);
    }

    document.addEventListener('shopify:section:load', placeGallery);
    document.addEventListener('shopify:block:select', placeGallery);

    // On mobile, tapping a pagination dot should also open the zoom dialog.
    document.addEventListener(
      'click',
      function (e) {
        if (!mq.matches) return;

        var dotBtn = e.target && e.target.closest && e.target.closest('.slideshow-control.button.button-unstyled');
        if (!dotBtn) return;
        if (!dotBtn.closest('.rio-media-gallery')) return;

        var list = dotBtn.closest('ol, ul');
        var items = list ? list.querySelectorAll('li') : [];
        var index = 0;
        for (var i = 0; i < items.length; i++) {
          if (items[i].contains(dotBtn)) {
            index = i;
            break;
          }
        }

        var zoomDialog = document.querySelector('.rio-media-gallery zoom-dialog');
        if (zoomDialog && typeof zoomDialog.open === 'function') {
          zoomDialog.open(index, e);
        }
      },
      true
    );
  })();
</script>

{% stylesheet %}
  .rio-media-gallery {
    width: 100%;
  }

  @media screen and (max-width: 749px) {
    .rio-media-gallery {
      display: block;
      margin-block-start: 12px;
      margin-block-end: 0;
    }

    .rio-media-gallery + .variant-picker,
    .rio-media-gallery + * .variant-picker {
      padding-block-start: 0 !important;
      margin-block-start: 0 !important;
    }

    .product-information__details > .rio-media-gallery + product-inventory + variant-picker,
    .product-information__details > .rio-media-gallery ~ variant-picker {
      padding-block-start: 0 !important;
      margin-block-start: 0 !important;
    }

    .product-information__grid:has(.rio-media-gallery media-gallery) .product-information__media {
      display: none;
    }

    /* Zoom dialog (full-screen expand) — match the reference layout on mobile */
    zoom-dialog dialog[open] {
      width: 100vw;
      height: 100vh;
      height: 100dvh;
      max-width: 100vw;
      max-height: 100dvh;
      margin: 0;
      padding: 0;
      border: 0;
      background: #fff;
      overflow: hidden;
    }

    zoom-dialog dialog[open]::backdrop {
      background: rgba(0, 0, 0, 0.5);
    }

    .dialog-zoomed-gallery__close-button.close-button {
      position: fixed;
      top: 16px;
      right: 16px;
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: #fff !important;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.18);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0;
      z-index: 20;
    }

    .dialog-zoomed-gallery__close-button.close-button svg {
      width: 16px;
      height: 16px;
      color: #111;
    }

    /* Image area — fills viewport minus the thumbnail strip */
    .dialog-zoomed-gallery {
      list-style: none;
      margin: 0;
      padding: 0;
      width: 100vw;
      height: calc(100dvh - 92px);
      max-height: calc(100dvh - 92px);
      overflow: hidden;
      display: flex;
    }

    .dialog-zoomed-gallery > li.product-media-container {
      width: 100vw;
      height: 100%;
      max-height: 100%;
      flex: 0 0 100vw;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0;
      background: #fff;
    }

    .dialog-zoomed-gallery .product-media__drag-zoom-wrapper,
    .dialog-zoomed-gallery product-media,
    .dialog-zoomed-gallery .product-media {
      width: 100%;
      height: 100%;
      max-height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .dialog-zoomed-gallery img,
    .dialog-zoomed-gallery picture {
      max-width: 100%;
      max-height: 100%;
      width: auto;
      height: auto;
      object-fit: contain;
    }

    /* Bottom thumbnail strip */
    .dialog-thumbnails-list-container {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      background: #fff;
      border-top: 1px solid #e5e5e5;
      padding: 0;
      z-index: 15;
      max-width: 100vw;
    }

    .dialog-thumbnails-list {
      display: flex;
      flex-direction: row;
      gap: 10px;
      padding: 10px 12px;
      margin: 0;
      overflow-x: auto;
      overflow-y: hidden;
      flex-wrap: nowrap;
      scroll-snap-type: x mandatory;
      animation: none;
      opacity: 1;
      position: static;
      max-height: none;
    }

    .dialog-thumbnails-list__thumbnail {
      width: 86px;
      height: 86px;
      flex: 0 0 86px;
      border-radius: 4px;
      border: 1px solid transparent;
      overflow: visible;
      padding: 2px;
      scroll-snap-align: start;
      background: transparent;
      box-sizing: border-box;
    }

    .dialog-thumbnails-list__thumbnail img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      aspect-ratio: 1 / 1;
      border-radius: 2px;
      display: block;
    }

    .dialog-thumbnails-list__thumbnail[aria-selected='true'] {
      outline: 0;
      border: 2px solid #111;
      padding: 1px;
    }
  }

  @media screen and (min-width: 750px) {
    .rio-media-gallery {
      display: none;
    }
  }
{% endstylesheet %}

