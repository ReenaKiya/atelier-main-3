{%- liquid
  assign heading = section.settings.heading | default: 'Shop by Type'
  assign bg_color = section.settings.bg_color | default: '#fce4ec'
-%}

<section class="sbt" style="background-color: {{ bg_color }};">
  <div class="sbt__inner">
    <!-- Left Image (stays fixed) -->
    <div class="sbt__image-col">
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 800 | image_tag: class: 'sbt__image', loading: 'lazy' }}
      {% else %}
        <div class="sbt__image-placeholder"></div>
      {% endif %}
    </div>

    <!-- Right Content -->
    <div class="sbt__content-col">
      <h2 class="sbt__heading">{{ heading }}</h2>

      <!-- Tabs -->
      <div class="sbt__tabs">
        {% for block in section.blocks %}
          <button
            class="sbt__tab {% if forloop.first %}sbt__tab--active{% endif %}"
            data-sbt-tab="{{ forloop.index0 }}"
            {{ block.shopify_attributes }}
          >
            {{ block.settings.tab_label }}
          </button>
        {% endfor %}
      </div>

      <!-- Panels -->
      <div class="sbt__panels">
        {% for block in section.blocks %}
          <div class="sbt__panel {% if forloop.first %}sbt__panel--active{% endif %}" data-sbt-panel="{{ forloop.index0 }}">
            <div class="sbt__grid">
              {% assign collection = block.settings.collection %}
              {% if collection != blank %}
                {% for product in collection.products limit: 6 %}
                  <div class="sbt__card">
                    <a href="{{ product.url }}" class="sbt__card-link">
                      {% if product.featured_image != blank %}
                        <img
                          src="{{ product.featured_image | image_url: width: 400 }}"
                          alt="{{ product.title | escape }}"
                          class="sbt__card-img"
                          loading="lazy"
                        >
                      {% endif %}
                    </a>
                    <div class="sbt__card-info">
                      <h3 class="sbt__card-title">{{ product.title }}</h3>
                      <div class="sbt__card-rating">
                        <span class="sbt__stars">★★★★★</span>
                        <span class="sbt__review-count">({{ product.metafields.reviews.rating_count | default: 0 }})</span>
                      </div>
                      <span class="sbt__card-price">{{ product.price | money }}</span>
                      <a href="{{ product.url }}" class="sbt__card-btn">View Product</a>
                    </div>
                  </div>
                {% endfor %}
              {% else %}
                {% for i in (1..6) %}
                  <div class="sbt__card">
                    <div class="sbt__card-img-placeholder"></div>
                    <div class="sbt__card-info">
                      <h3 class="sbt__card-title">Product {{ i }}</h3>
                      <div class="sbt__card-rating">
                        <span class="sbt__stars">★★★★★</span>
                        <span class="sbt__review-count">(0)</span>
                      </div>
                      <span class="sbt__card-price">£0.00</span>
                      <a href="#" class="sbt__card-btn">View Product</a>
                    </div>
                  </div>
                {% endfor %}
              {% endif %}
            </div>
            <div class="sbt__view-more">
              {% if collection != blank %}
                <a href="{{ collection.url }}" class="sbt__view-more-btn">View More</a>
              {% else %}
                <a href="#" class="sbt__view-more-btn">View More</a>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Shop by Type",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Left Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Type"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fce4ec"
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        {
          "type": "text",
          "id": "tab_label",
          "label": "Tab Label",
          "default": "Ear"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by Type",
      "blocks": [
        { "type": "tab", "settings": { "tab_label": "Ear" } },
        { "type": "tab", "settings": { "tab_label": "Nose" } },
        { "type": "tab", "settings": { "tab_label": "Lips" } },
        { "type": "tab", "settings": { "tab_label": "More" } }
      ]
    }
  ]
}
{% endschema %}

<style>
/* Section */
.sbt {
  padding: 0;
}

.sbt__inner {
  max-width: 100%;
  margin: 0;
  display: flex;
  gap: 0;
  align-items: stretch;
}

/* Left Image */
.sbt__image-col {
  flex: 0 0 43%;
  max-width: 43%;
  position: relative;
  margin: 19px;
}

.sbt__image {
  width: 100%;
  height: 100%;
  display: block;
  border-radius: 12px;
  object-fit: cover;
}

.sbt__image-placeholder {
  width: 100%;
  height: 100%;
  min-height: 500px;
  background: #f0d0d0;
  border-radius: 0;
}

/* Right Content */
.sbt__content-col {
  flex: 1;
  padding: 40px 40px 40px 40px;
}

.sbt__heading {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 26px;
  font-weight: 800;
  color: #111;
  text-align: center;
  margin: 0 0 20px;
}

/* Tabs */
.sbt__tabs {
  display: flex;
  justify-content: center;
  gap: 10px;
  margin-bottom: 25px;
}

.sbt__tab {
  padding: 8px 24px;
  border: 1.5px solid #ccc;
  border-radius: 50px;
  background: #fff;
  color: #333;
  font-family: 'Nunito Sans', sans-serif;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
}

.sbt__tab--active {
  background: #d32f2f;
  color: #fff;
  border-color: #d32f2f;
}

.sbt__tab:hover:not(.sbt__tab--active) {
  background: #f5f5f5;
}

/* Panels */
.sbt__panel {
  display: none;
}

.sbt__panel--active {
  display: block;
  animation: sbtFadeIn 0.4s ease;
}

@keyframes sbtFadeIn {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}

/* Product Grid */
.sbt__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 15px;
}

/* Product Card */
.sbt__card {
  background: #fff;
  border-radius: 0;
  overflow: hidden;
  border: 1px solid #eee;
  display: flex;
  flex-direction: column;
}

.sbt__card-link {
  display: block;
  padding: 15px;
  text-decoration: none;
}

.sbt__card-img {
  width: 100%;
  height: 150px;
  object-fit: contain;
  display: block;
}

.sbt__card-img-placeholder {
  width: 100%;
  height: 150px;
  background: #f5f5f5;
  border-radius: 0;
}

.sbt__card-info {
  padding: 0 15px 15px;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  flex: 1;
}

.sbt__card-title {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 13px;
  font-weight: 600;
  color: #333;
  margin: 0 0 6px;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.sbt__card-rating {
  display: flex;
  align-items: center;
  gap: 4px;
  margin-bottom: 6px;
}

.sbt__stars {
  color: #f5a623;
  font-size: 12px;
  letter-spacing: 1px;
}

.sbt__review-count {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 11px;
  color: #999;
}

.sbt__card-price {
  font-family: 'Nunito Sans', sans-serif;
  font-size: 16px;
  font-weight: 700;
  color: #111;
  margin-bottom: 10px;
}

.sbt__card-btn {
  display: block;
  width: 100%;
  padding: 10px;
  background: #000000;
  color: #fff;
  border: none;
  border-radius: 0;
  font-family: 'Nunito Sans', sans-serif;
  font-size: 13px;
  font-weight: 700;
  text-align: center;
  text-decoration: none;
  cursor: pointer;
  transition: background 0.3s ease;
  margin-top: auto;
}

.sbt__card-btn:hover {
  background: #333;
  color: #fff;
}

/* View More */
.sbt__view-more {
  text-align: center;
  margin-top: 25px;
}

.sbt__view-more-btn {
  display: inline-block;
  padding: 12px 40px;
  background: #000;
  color: #fff;
  border: 2px solid #000;
  border-radius: 27px;
  font-family: 'Nunito Sans', sans-serif;
  font-size: 14px;
  font-weight: 700;
  text-decoration: none;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  cursor: pointer;
  transition: all 0.3s ease;
}

.sbt__view-more-btn:hover {
  background: #111;
  color: #fff;
}

/* Responsive */
@media screen and (max-width: 999px) {
  .sbt__inner {
    flex-direction: column;
  }

  .sbt__image-col {
    flex: none;
    max-width: 100%;
    width: auto;
    margin: 12px;
    height: auto;
    position: relative;
  }

  .sbt__image {
    position: static;
    width: 100%;
    height: auto;
    max-height: 360px;
    object-fit: cover;
    border-radius: 12px;
  }

  .sbt__image-placeholder {
    min-height: 280px;
    border-radius: 12px;
  }

  .sbt__content-col {
    padding: 30px 20px;
  }
}

@media screen and (max-width: 600px) {
  .sbt__image-col {
    margin: 10px;
  }

  .sbt__image {
    max-height: 240px;
    border-radius: 10px;
  }

  .sbt__image-placeholder {
    min-height: 200px;
    border-radius: 10px;
  }

  .sbt__content-col {
    padding: 20px 14px;
  }

  /* Carousel: turn grid into horizontal scroll-snap on mobile */
  .sbt__panel--active .sbt__grid {
    display: flex;
    grid-template-columns: none;
    gap: 12px;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scroll-padding-inline: 14px;
    padding-bottom: 10px;
    margin-inline: -14px;
    padding-inline: 14px;
    scrollbar-width: none;
  }

  .sbt__panel--active .sbt__grid::-webkit-scrollbar {
    display: none;
  }

  .sbt__panel--active .sbt__grid > .sbt__card {
    flex: 0 0 65%;
    max-width: 65%;
    scroll-snap-align: start;
  }

  .sbt__heading {
    font-size: 22px;
  }

  .sbt__tabs {
    flex-wrap: wrap;
    gap: 8px;
  }

  .sbt__tab {
    padding: 6px 16px;
    font-size: 12px;
  }

  .sbt__card-img {
    height: 110px;
  }
}

@media screen and (max-width: 380px) {
  .sbt__image {
    max-height: 200px;
  }
}
</style>

<script>
document.addEventListener("DOMContentLoaded", function () {
  var tabs = document.querySelectorAll(".sbt__tab");
  var panels = document.querySelectorAll(".sbt__panel");

  tabs.forEach(function (tab) {
    tab.addEventListener("click", function () {
      var index = this.getAttribute("data-sbt-tab");

      tabs.forEach(function (t) { t.classList.remove("sbt__tab--active"); });
      panels.forEach(function (p) { p.classList.remove("sbt__panel--active"); });

      this.classList.add("sbt__tab--active");
      var target = document.querySelector('.sbt__panel[data-sbt-panel="' + index + '"]');
      if (target) target.classList.add("sbt__panel--active");
    });
  });
});
</script>
