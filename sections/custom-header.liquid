  }

  .custom-cart-drawer__close:hover {
    opacity: 0.6;
  }

  /* Free Shipping Banner */
  .custom-cart-drawer__shipping-banner {
    background: #000;
    color: #fff;
    text-align: center;
    padding: 10px 20px;
    font-size: 13px;
    flex-shrink: 0;
  }

  .custom-cart-drawer__shipping-banner strong {
    color: #ff4d6d;
  }

  /* Content / Items */
  .custom-cart-drawer__content {
    flex: 1;
    overflow-y: auto;
    padding: 16px 20px;
  }

  .custom-cart-drawer__empty {
    text-align: center;
    padding: 40px 0;
  }

  .custom-cart-drawer__empty p {
    font-size: 16px;
    color: #666;
    margin-bottom: 20px;
  }

  .custom-cart-drawer__continue-btn {
    display: inline-block;
    padding: 12px 28px;
    background: #000;
    color: #fff;
    text-decoration: none;
    border-radius: 4px;
    font-size: 14px;
  }

  /* Cart Item */
  .custom-cart-drawer__item {
    display: flex;
    gap: 14px;
    padding: 14px 0;
    border-bottom: 1px solid #f0f0f0;
    align-items: flex-start;
  }

  .custom-cart-drawer__item:last-child {
    border-bottom: none;
  }

  .custom-cart-drawer__item-image {
    width: 70px;
    flex-shrink: 0;
    border: 1px solid #eee;
    border-radius: 6px;
    overflow: hidden;
  }

  .custom-cart-drawer__item-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .custom-cart-drawer__item-details {
    flex: 1;
    min-width: 0;
  }

  .custom-cart-drawer__item-title {
    font-size: 13px;
    font-weight: 600;
    color: #000;
    text-decoration: none;
    display: block;
    margin-bottom: 4px;
    line-height: 1.3;
  }

  .custom-cart-drawer__item-title:hover {
    text-decoration: underline;
  }

  .custom-cart-drawer__item-variant {
    font-size: 12px;
    color: #888;
    margin: 0 0 4px;
  }

  .custom-cart-drawer__item-price {
    font-size: 13px;
    color: #333;
    margin-bottom: 8px;
  }

  .custom-cart-drawer__item-line-price {
    font-size: 14px;
    font-weight: 600;
    color: #000;
    white-space: nowrap;
    padding-top: 2px;
  }

  /* Quantity Controls */
  .custom-cart-drawer__quantity {
    display: inline-flex;
    align-items: center;
    border: 1px solid #ddd;
    border-radius: 20px;
    overflow: hidden;
  }

  .custom-cart-drawer__qty-btn {
    background: none;
    border: none;
    width: 30px;
    height: 30px;
    font-size: 16px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #c41e3a;
    font-weight: 600;
  }

  .custom-cart-drawer__qty-btn:hover {
    background: #f5f5f5;
  }

  .custom-cart-drawer__qty-value {
    font-size: 13px;
    min-width: 28px;
    text-align: center;
    font-weight: 600;
  }

  /* You May Also Like */
  .custom-cart-drawer__recommendations {
    flex-shrink: 0;
    padding: 14px 20px;
    border-top: 1px solid #eee;
    background: #fafafa;
  }

  .custom-cart-drawer__rec-title {
    font-size: 14px;
    font-weight: 700;
    color: #000;
    margin: 0 0 12px;
  }

  .custom-cart-drawer__rec-scroll {
    display: flex;
    gap: 12px;
    overflow-x: auto;
    padding-bottom: 6px;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
  }

  .custom-cart-drawer__rec-scroll::-webkit-scrollbar {
    height: 4px;
  }

  .custom-cart-drawer__rec-scroll::-webkit-scrollbar-track {
    background: #eee;
    border-radius: 2px;
  }

  .custom-cart-drawer__rec-scroll::-webkit-scrollbar-thumb {
    background: #999;
    border-radius: 2px;
  }

  .custom-cart-drawer__rec-card {
    min-width: 140px;
    max-width: 140px;
    scroll-snap-align: start;
    border: 1px solid #eee;
    border-radius: 8px;
    background: #fff;
    padding: 10px;
    flex-shrink: 0;
  }

  .custom-cart-drawer__rec-img {
    width: 100%;
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: 4px;
    margin-bottom: 8px;
    background: #f5f5f5;
  }

  .custom-cart-drawer__rec-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .custom-cart-drawer__rec-info {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 6px;
  }

  .custom-cart-drawer__rec-price {
    font-size: 13px;
    font-weight: 700;
    color: #000;
  }

  .custom-cart-drawer__rec-add {
    background: #000;
    color: #fff;
    border: none;
    border-radius: 4px;
    padding: 4px 12px;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .custom-cart-drawer__rec-add:hover {
    background: #333;
  }

  .custom-cart-drawer__rec-add:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .custom-cart-drawer__rec-name {
    font-size: 11px;
    color: #555;
    margin: 0;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .custom-cart-drawer__rec-name a {
    color: inherit;
    text-decoration: none;
  }

  .custom-cart-drawer__rec-name a:hover {
    text-decoration: underline;
  }

  /* Footer */
  .custom-cart-drawer__footer {
    border-top: 1px solid #eee;
    padding: 18px 20px;
    flex-shrink: 0;
    background: #fff;
  }

  .custom-cart-drawer__total {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 6px;
  }

  .custom-cart-drawer__total-price {
    font-size: 18px;
  }

  .custom-cart-drawer__tax-note {
    font-size: 12px;
    color: #888;
    margin: 0 0 14px;
  }

  .custom-cart-drawer__checkout-btn {
    display: block;
    width: 100%;
    padding: 14px;
    background: #000;
    color: #fff;
    text-align: center;
    text-decoration: none;
    border-radius: 4px;
    font-size: 15px;
    font-weight: 600;
    border: none;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .custom-cart-drawer__checkout-btn:hover {
    background: #333;
  }

  /* Mobile adjustments */
  @media screen and (max-width: 480px) {
    .custom-cart-drawer {
      width: 100vw;
      max-width: 100vw;
    }
  }

  /* ===================== */
  /* MOBILE MENU DRAWER    */
  /* ===================== */
  .custom-mobile-menu-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    z-index: 99999;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .custom-mobile-menu-overlay.is-open {
    opacity: 1;
    visibility: visible;
  }

  .custom-mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    width: 320px;
    max-width: 85vw;
    height: 100vh;
    background: #fff;
    z-index: 100000;
    transform: translateX(-100%);
    transition: transform 0.3s ease;
    display: flex;
    flex-direction: column;
    box-shadow: 4px 0 20px rgba(0, 0, 0, 0.1);
    overflow-y: auto;
  }

  .custom-mobile-menu.is-open {
    transform: translateX(0);
  }

  .custom-mobile-menu__header {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding: 18px 20px 8px;
    flex-shrink: 0;
  }

  .custom-mobile-menu__title {
    display: none;
  }

  .custom-mobile-menu__close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    color: #000;
    display: flex;
    align-items: center;
  }

  .custom-mobile-menu__close:hover {
    opacity: 0.6;
  }

  .custom-mobile-menu__nav {
    padding: 0 24px 24px;
    flex: 1;
  }

  .custom-mobile-menu__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .custom-mobile-menu__item {
    border-bottom: 1px solid #f2f2f2;
  }

  .custom-mobile-menu__item:last-child {
    border-bottom: none;
  }

  .custom-mobile-menu__link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 0;
    color: #000;
    text-decoration: none;
    font-size: 17px;
    font-weight: 600;
  }

  .custom-mobile-menu__item.has-children > .custom-mobile-menu__link::after {
    content: '';
    width: 10px;
    height: 10px;
    border-right: 2px solid #000;
    border-bottom: 2px solid #000;
    transform: rotate(45deg);
    margin-left: 12px;
    transition: transform 0.2s ease;
  }

  .custom-mobile-menu__item.has-children.is-open > .custom-mobile-menu__link::after {
    transform: rotate(-135deg);
  }

  .custom-mobile-menu__sublist {
    list-style: none;
    margin: 0;
    padding: 0 0 14px 12px;
    display: none;
  }

  .custom-mobile-menu__item.is-open > .custom-mobile-menu__sublist {
    display: block;
  }

  .custom-mobile-menu__sublink {
    display: block;
    padding: 10px 0;
    color: #333;
    text-decoration: none;
    font-size: 15px;
  }

  .custom-mobile-menu__sublink:hover,
  .custom-mobile-menu__link:hover {
    color: #c41e3a;
  }

  body.mobile-menu-open {
    overflow: hidden;
  }

  /* =====================================================
     Mobile drawer: override cloned desktop nav styles so
     header-navigation content stacks vertically as an
     accordion (matches the mobile menu reference design).
     ===================================================== */
  .custom-mobile-menu__nav .site-header,
  .custom-mobile-menu__nav .site-navigation-wrapper,
  .custom-mobile-menu__nav .site-navigation {
    all: unset;
    display: block;
    width: 100%;
  }

  .custom-mobile-menu__nav .navmenu,
  .custom-mobile-menu__nav .navmenu-depth-1 {
    display: block !important;
    flex-direction: column;
    align-items: stretch !important;
    width: 100%;
    margin: 0 !important;
    padding: 0 !important;
    list-style: none;
    height: auto !important;
  }

  .custom-mobile-menu__nav .navmenu-item,
  .custom-mobile-menu__nav .navmenu-item-parent,
  .custom-mobile-menu__nav .navmenu-basic__item {
    display: block !important;
    width: 100%;
    border-bottom: 1px solid #f2f2f2;
    position: static !important;
    height: auto !important;
    padding: 0 !important;
  }

  .custom-mobile-menu__nav details[data-navmenu-details] {
    display: block;
    width: 100%;
    position: static;
  }

  .custom-mobile-menu__nav .navmenu-link,
  .custom-mobile-menu__nav summary.navmenu-link {
    display: flex !important;
    width: 100%;
    justify-content: space-between;
    align-items: center;
    padding: 18px 0 !important;
    font-size: 16px !important;
    font-weight: 600;
    text-transform: none !important;
    letter-spacing: 0 !important;
    color: #000 !important;
    white-space: normal !important;
    cursor: pointer;
    list-style: none;
  }

  .custom-mobile-menu__nav summary.navmenu-link::-webkit-details-marker {
    display: none;
  }

  .custom-mobile-menu__nav details[open] > summary.navmenu-link {
    color: #c41e3a !important;
  }

  .custom-mobile-menu__nav .navmenu-icon {
    margin-left: auto;
  }

  .custom-mobile-menu__nav .navmenu-icon svg {
    width: 12px;
    height: 8px;
    transition: transform 0.2s ease;
  }

  .custom-mobile-menu__nav details[open] > summary .navmenu-icon svg {
    transform: rotate(180deg);
  }

  /* Mega menu container — flatten to inline block */
  .custom-mobile-menu__nav .navmenu-meganav,
  .custom-mobile-menu__nav .navmenu-meganav-multi-column,
  .custom-mobile-menu__nav .navmenu-meganav--desktop {
    position: static !important;
    display: block !important;
    width: 100% !important;
    max-width: 100% !important;
    transform: none !important;
    box-shadow: none !important;
    background: #f8f8f8 !important;
    padding: 0 !important;
    margin: 0 0 8px !important;
    opacity: 1 !important;
    visibility: visible !important;
    top: auto !important;
    left: auto !important;
  }

  .custom-mobile-menu__nav .multi-col-wrapper {
    display: block !important;
    grid-template-columns: none !important;
    min-height: 0 !important;
    width: 100%;
  }

  .custom-mobile-menu__nav .multi-col-categories {
    background: transparent !important;
    border: none !important;
    padding: 0 !important;
  }

  .custom-mobile-menu__nav .multi-col-category-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .custom-mobile-menu__nav .multi-col-category-item {
    border-bottom: 1px solid #ececec;
    position: static;
  }

  .custom-mobile-menu__nav .multi-col-category-item:last-child {
    border-bottom: none;
  }

  .custom-mobile-menu__nav .multi-col-category-link {
    display: flex !important;
    justify-content: space-between;
    align-items: center;
    padding: 14px 18px !important;
    font-size: 15px !important;
    font-weight: 500 !important;
    color: #000 !important;
    background: transparent !important;
    border: none !important;
    text-decoration: none;
  }

  .custom-mobile-menu__nav .multi-col-category-item.is-open > .multi-col-category-link {
    color: #c41e3a !important;
  }

  .custom-mobile-menu__nav .multi-col-category-arrow {
    width: 14px !important;
    height: 14px !important;
    color: #999 !important;
    transition: transform 0.2s ease;
  }

  .custom-mobile-menu__nav .multi-col-category-item.is-open > .multi-col-category-link .multi-col-category-arrow {
    transform: rotate(90deg);
    color: #c41e3a !important;
  }

  /* Submenu panels: hidden by default, shown when their category is open */
  .custom-mobile-menu__nav .multi-col-submenu-panel {
    display: none !important;
    background: #fff;
    padding: 6px 18px 14px 30px;
  }

  .custom-mobile-menu__nav .multi-col-category-item.is-open > .multi-col-submenu-panel {
    display: block !important;
  }

  .custom-mobile-menu__nav .multi-col-submenu-grid {
    display: block !important;
    grid-template-columns: none !important;
    gap: 0 !important;
  }

  .custom-mobile-menu__nav .multi-col-submenu-link {
    display: block;
    padding: 10px 0;
    font-size: 14px;
    color: #333;
    text-decoration: none;
  }

  .custom-mobile-menu__nav .multi-col-submenu-link--view-all {
    margin-top: 8px;
    font-weight: 600;
    color: #c41e3a;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Custom Header",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search placeholder",
      "default": "Search the shiny things..."
    },
    {
      "type": "checkbox",
      "id": "show_account",
      "label": "Show account icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_wishlist",
      "label": "Show wishlist icon",
      "default": true
    },
    {
      "type": "url",
      "id": "wishlist_url",
      "label": "Wishlist page URL"
    },
    {
      "type": "link_list",
      "id": "mobile_menu",
      "label": "Mobile menu",
      "default": "main-menu"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text / Icon color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#EEEEEE"
    }
  ],
  "presets": [
    {
      "name": "Custom Header",
      "category": "Header"
    }
  ]
}
{% endschema %}
