{%- liquid
  assign logo = section.settings.logo
  assign search_placeholder = section.settings.search_placeholder
-%}

<header
  class="custom-header"
  style="
    --ch-bg: {{ section.settings.background_color }};
    --ch-text: {{ section.settings.text_color }};
    --ch-border: {{ section.settings.border_color }};
  "
>
  <div class="custom-header__inner page-width">
    <!-- Search -->
    <div class="custom-header__search">
      <form action="/search" method="get" class="custom-header__search-form">
        <input
          type="search"
          name="q"
          class="custom-header__search-input"
          placeholder="{{ search_placeholder }}"
          autocomplete="off"
        >
        <button type="submit" class="custom-header__search-btn" aria-label="Search">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
        </button>
      </form>
    </div>

    <!-- Logo -->
    <div class="custom-header__logo">
      <a href="/" class="custom-header__logo-link">
        {%- if logo != blank -%}
          {{ logo | image_url: width: 400 | image_tag: class: 'custom-header__logo-img', loading: 'eager', alt: shop.name }}
        {%- else -%}
          <span class="custom-header__logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </div>

    <!-- Icons -->
    <div class="custom-header__icons">
      {%- if section.settings.show_account and shop.customer_accounts_enabled -%}
        <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}" class="custom-header__icon" aria-label="Account">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
            <circle cx="12" cy="7" r="4"></circle>
          </svg>
        </a>
      {%- endif -%}

      {%- if section.settings.show_wishlist -%}
        <a href="{{ section.settings.wishlist_url | default: '/pages/wishlist' }}" class="custom-header__icon" aria-label="Wishlist">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
          </svg>
        </a>
      {%- endif -%}

      <!-- Side Cart Drawer -->
      <div class="custom-cart-drawer-wrapper">
        <button class="custom-header__icon custom-header__cart" aria-label="Open cart" onclick="document.getElementById('custom-cart-drawer').classList.add('is-open'); document.getElementById('custom-cart-overlay').classList.add('is-open');">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <path d="M16 10a4 4 0 0 1-8 0"></path>
          </svg>
          <span class="custom-header__cart-count" data-cart-count>{{ cart.item_count }}</span>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- Cart Drawer Overlay -->
<div id="custom-cart-overlay" class="custom-cart-overlay" onclick="document.getElementById('custom-cart-drawer').classList.remove('is-open'); this.classList.remove('is-open');"></div>

<!-- Cart Drawer Panel -->
<div id="custom-cart-drawer" class="custom-cart-drawer">
  <div class="custom-cart-drawer__inner">
    <!-- Header -->
    <div class="custom-cart-drawer__header">
      <span class="custom-cart-drawer__title">Your Beautiful Picks</span>
      <button class="custom-cart-drawer__close" aria-label="Close cart" onclick="document.getElementById('custom-cart-drawer').classList.remove('is-open'); document.getElementById('custom-cart-overlay').classList.remove('is-open');">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    {%- unless cart.empty? -%}
      <!-- Free Shipping Banner -->
      <div class="custom-cart-drawer__shipping-banner">
        You're eligible for <strong>free UK shipping!</strong>
      </div>
    {%- endunless -%}

    <!-- Cart Content -->
    <div class="custom-cart-drawer__content">
      {%- if cart.empty? -%}
        <div class="custom-cart-drawer__empty">
          <p>Your cart is empty</p>
          <a href="{{ routes.all_products_collection_url }}" class="custom-cart-drawer__continue-btn">Continue Shopping</a>
        </div>
      {%- else -%}
        <!-- Cart Items -->
        <form action="{{ routes.cart_url }}" method="post" id="custom-cart-form">
          {%- for item in cart.items -%}
            <div class="custom-cart-drawer__item" data-line-key="{{ item.key }}" data-line-index="{{ forloop.index }}">
              <div class="custom-cart-drawer__item-image">
                {%- if item.image -%}
                  <a href="{{ item.url }}">
                    {{ item.image | image_url: width: 150 | image_tag: loading: 'lazy' }}
                  </a>
                {%- endif -%}
              </div>
              <div class="custom-cart-drawer__item-details">
                <a href="{{ item.url }}" class="custom-cart-drawer__item-title">{{ item.product.title }}</a>
                {%- if item.product.has_only_default_variant == false -%}
                  <p class="custom-cart-drawer__item-variant">
                    {%- for option in item.options_with_values -%}
                      {{ option.value }}{% unless forloop.last %} / {% endunless %}
                    {%- endfor -%}
                  </p>
                {%- endif -%}
                <div class="custom-cart-drawer__item-price">{{ item.final_price | money }}</div>
                <div class="custom-cart-drawer__quantity">
                  <button type="button" class="custom-cart-drawer__qty-btn" aria-label="Decrease quantity" onclick="updateCartQty(this, -1)">−</button>
                  <span class="custom-cart-drawer__qty-value">{{ item.quantity }}</span>
                  <button type="button" class="custom-cart-drawer__qty-btn" aria-label="Increase quantity" onclick="updateCartQty(this, 1)">+</button>
                </div>
              </div>
              <div class="custom-cart-drawer__item-line-price">
                {{ item.final_line_price | money }}
              </div>
            </div>
          {%- endfor -%}
        </form>
      {%- endif -%}

      {%- unless cart.empty? -%}
        <!-- You May Also Like Section -->
        <div class="custom-cart-drawer__recommendations">
          <h3 class="custom-cart-drawer__rec-title">You May Also Like</h3>
          <div class="custom-cart-drawer__rec-scroll" id="cart-drawer-recommendations">

            {%- comment -%} Server-side rendered recommendations from collections {%- endcomment -%}
            {%- assign rec_product_ids = '' -%}
            {%- for item in cart.items -%}
              {%- assign rec_product_ids = rec_product_ids | append: item.product.id | append: ',' -%}
            {%- endfor -%}

            {%- assign rec_count = 0 -%}
            {%- for item in cart.items -%}
              {%- if rec_count >= 6 -%}{%- break -%}{%- endif -%}
              {%- for collection in item.product.collections -%}
                {%- if rec_count >= 6 -%}{%- break -%}{%- endif -%}
                {%- for product in collection.products limit: 10 -%}
                  {%- if rec_count >= 6 -%}{%- break -%}{%- endif -%}
                  {%- assign pid_check = product.id | append: ',' -%}
                  {%- if rec_product_ids contains pid_check -%}{%- continue -%}{%- endif -%}
                  {%- assign rec_product_ids = rec_product_ids | append: product.id | append: ',' -%}
                  {%- assign rec_count = rec_count | plus: 1 -%}
                  <div class="custom-cart-drawer__rec-card">
                    <div class="custom-cart-drawer__rec-img">
                      {%- if product.featured_image -%}
                        <a href="{{ product.url }}">
                          {{ product.featured_image | image_url: width: 200 | image_tag: loading: 'lazy' }}
                        </a>
                      {%- endif -%}
                    </div>
                    <div class="custom-cart-drawer__rec-info">
                      <span class="custom-cart-drawer__rec-price">{{ product.price | money }}</span>
                      <button class="custom-cart-drawer__rec-add" onclick="addRecToCart({{ product.variants.first.id }}, this)">Add</button>
                    </div>
                    <p class="custom-cart-drawer__rec-name">
                      <a href="{{ product.url }}">{{ product.title }}</a>
                    </p>
                  </div>
                {%- endfor -%}
              {%- endfor -%}
            {%- endfor -%}

          </div>
        </div>
      {%- endunless -%}
    </div>

    {%- unless cart.empty? -%}
      <!-- Cart Footer -->
      <div class="custom-cart-drawer__footer">
        <div class="custom-cart-drawer__total">
          <span>Total</span>
          <span class="custom-cart-drawer__total-price">{{ cart.total_price | money }}</span>
        </div>
        <p class="custom-cart-drawer__tax-note">Coupons apply at checkout.</p>
        <a href="{{ routes.cart_url }}/checkout" class="custom-cart-drawer__checkout-btn">Checkout</a>
      </div>
    {%- endunless -%}
  </div>
</div>

<script>
  // Auto-open cart drawer when item is added
  document.addEventListener('cart:add', function() {
    document.getElementById('custom-cart-drawer').classList.add('is-open');
    document.getElementById('custom-cart-overlay').classList.add('is-open');
  });

  // Format price in cents to money string
  function formatMoney(cents) {
    var moneyFormat = {{ shop.money_format | json }};
    var amount = (cents / 100).toFixed(2);
    var amountNoDecimals = Math.round(cents / 100);
    var amountWithComma = amount.replace('.', ',');
    return moneyFormat
      .replace(/\{\{\s*amount_with_comma_separator\s*\}\}/g, amountWithComma)
      .replace(/\{\{\s*amount_no_decimals\s*\}\}/g, amountNoDecimals)
      .replace(/\{\{\s*amount\s*\}\}/g, amount);
  }

  // Refresh cart drawer UI from cart JSON
  function refreshCartDrawer(cartData) {
    // Update total price
    var totalEl = document.querySelector('.custom-cart-drawer__total-price');
    if (totalEl) totalEl.textContent = formatMoney(cartData.total_price);

    // Update cart count badge
    document.querySelectorAll('[data-cart-count]').forEach(function(el) {
      el.textContent = cartData.item_count;
    });

    // Update each line item by key
    cartData.items.forEach(function(item, index) {
      var lineIndex = index + 1;
      var itemEl = document.querySelector('[data-line-index="' + lineIndex + '"]');
      if (!itemEl) return;
      var qtyEl = itemEl.querySelector('.custom-cart-drawer__qty-value');
      var linePriceEl = itemEl.querySelector('.custom-cart-drawer__item-line-price');
      if (qtyEl) qtyEl.textContent = item.quantity;
      if (linePriceEl) linePriceEl.textContent = formatMoney(item.final_line_price);
    });

    // Remove deleted items
    document.querySelectorAll('.custom-cart-drawer__item[data-line-key]').forEach(function(el) {
      var key = el.getAttribute('data-line-key');
      var found = cartData.items.some(function(item) { return item.key === key; });
      if (!found) el.remove();
    });

    // If cart empty, reload
    if (cartData.item_count === 0) window.location.reload();
  }

  // Update cart quantity using line index (most reliable Shopify method)
  function updateCartQty(btn, change) {
    var itemEl = btn.closest('.custom-cart-drawer__item');
    if (!itemEl) return;

    var lineIndex = parseInt(itemEl.getAttribute('data-line-index'));
    var qtyEl = itemEl.querySelector('.custom-cart-drawer__qty-value');
    var currentQty = parseInt(qtyEl.textContent);
    var newQty = Math.max(currentQty + change, 0);

    // Immediately update displayed quantity
    if (newQty > 0) qtyEl.textContent = newQty;

    // Disable buttons during request
    var btns = itemEl.querySelectorAll('.custom-cart-drawer__qty-btn');
    btns.forEach(function(b) { b.disabled = true; });

    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ line: lineIndex, quantity: newQty })
    })
    .then(function(res) { return res.json(); })
    .then(function(cartData) {
      refreshCartDrawer(cartData);
      // Re-enable buttons
      btns.forEach(function(b) { b.disabled = false; });
    })
    .catch(function() {
      // Revert on error
      qtyEl.textContent = currentQty;
      btns.forEach(function(b) { b.disabled = false; });
    });
  }

  // Add recommended product to cart
  function addRecToCart(variantId, btn) {
    btn.disabled = true;
    btn.textContent = '...';
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: 1 })
    })
    .then(function(res) { return res.json(); })
    .then(function() {
      btn.textContent = 'Added!';
      // Fetch fresh cart data to update totals
      return fetch('/cart.js').then(function(r) { return r.json(); });
    })
    .then(function(cartData) {
      refreshCartDrawer(cartData);
    })
    .catch(function() { btn.disabled = false; btn.textContent = 'Add'; });
  }
</script>

{% stylesheet %}
  .custom-header {
    background: var(--ch-bg);
    border-bottom: 1px solid var(--ch-border);
    padding: 12px 0;
  }

  .custom-header__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 20px;
  }

  /* Search */
  .custom-header__search {
    justify-self: start;
  }

  .custom-header__search-form {
    display: flex;
    align-items: center;
    border: 1px solid #ddd;
    border-radius: 30px;
    overflow: hidden;
    background: #fff;
    width: 280px;
  }

  .custom-header__search-input {
    flex: 1;
    border: none;
    outline: none;
    padding: 10px 16px;
    font-size: 13px;
    color: #666;
    background: transparent;
  }

  .custom-header__search-input::placeholder {
    color: #aaa;
  }

  .custom-header__search-btn {
    background: none;
    border: none;
    padding: 8px 14px;
    cursor: pointer;
    color: #666;
    display: flex;
    align-items: center;
  }

  .custom-header__search-btn:hover {
    color: #000;
  }

  /* Logo */
  .custom-header__logo {
    justify-self: center;
    text-align: center;
  }

  .custom-header__logo-link {
    text-decoration: none;
    color: var(--ch-text);
  }

  .custom-header__logo-img {
    max-height: 50px;
    width: auto;
  }

  .custom-header__logo-text {
    font-size: 24px;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--ch-text);
  }

  /* Icons */
  .custom-header__icons {
    justify-self: end;
    display: flex;
    align-items: center;
    gap: 18px;
  }

  .custom-header__icon {
    color: var(--ch-text);
    text-decoration: none;
    display: flex;
    align-items: center;
    transition: opacity 0.2s ease;
  }

  .custom-header__icon:hover {
    opacity: 0.6;
  }

  .custom-header__cart {
    position: relative;
  }

  .custom-header__cart-count {
    position: absolute;
    top: -6px;
    right: -8px;
    background: #c41e3a;
    color: #fff;
    font-size: 10px;
    font-weight: 600;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  .custom-header__cart-count:empty {
    display: none;
  }

  /* Responsive */
  @media screen and (max-width: 749px) {
    .custom-header__inner {
      grid-template-columns: auto 1fr auto;
      gap: 12px;
    }

    .custom-header__search-form {
      width: 160px;
    }

    .custom-header__logo-img {
      max-height: 36px;
    }

    .custom-header__icons {
      gap: 14px;
    }
  }

  @media screen and (max-width: 480px) {
    .custom-header__search-form {
      width: 120px;
    }

    .custom-header__search-input {
      padding: 8px 12px;
      font-size: 12px;
    }
  }

  /* ===================== */
  /* SIDE CART DRAWER      */
  /* ===================== */

  .custom-cart-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.4);
    z-index: 99999;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .custom-cart-overlay.is-open {
    opacity: 1;
    visibility: visible;
  }

  .custom-cart-drawer {
    position: fixed;
    top: 0;
    right: 0;
    width: 420px;
    max-width: 90vw;
    height: 100vh;
    background: #fff;
    z-index: 100000;
    transform: translateX(100%);
    transition: transform 0.3s ease;
    display: flex;
    flex-direction: column;
    box-shadow: -4px 0 20px rgba(0,0,0,0.1);
  }

  .custom-cart-drawer.is-open {
    transform: translateX(0);
  }

  .custom-cart-drawer__inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
  }

  /* Header */
  .custom-cart-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 20px;
    border-bottom: 1px solid #eee;
    flex-shrink: 0;
  }

  .custom-cart-drawer__title {
    font-size: 18px;
    font-weight: 700;
    color: #000;
  }

  .custom-cart-drawer__close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    color: #000;
    display: flex;
    align-items: center;
  }

  .custom-cart-drawer__close:hover {
    opacity: 0.6;
  }

  /* Free Shipping Banner */
  .custom-cart-drawer__shipping-banner {
    background: #000;
    color: #fff;
    text-align: center;
    padding: 10px 20px;
    font-size: 13px;
    flex-shrink: 0;
  }

  .custom-cart-drawer__shipping-banner strong {
    color: #ff4d6d;
  }

  /* Content / Items */
  .custom-cart-drawer__content {
    flex: 1;
    overflow-y: auto;
    padding: 16px 20px;
  }

  .custom-cart-drawer__empty {
    text-align: center;
    padding: 40px 0;
  }

  .custom-cart-drawer__empty p {
    font-size: 16px;
    color: #666;
    margin-bottom: 20px;
  }

  .custom-cart-drawer__continue-btn {
    display: inline-block;
    padding: 12px 28px;
    background: #000;
    color: #fff;
    text-decoration: none;
    border-radius: 4px;
    font-size: 14px;
  }

  /* Cart Item */
  .custom-cart-drawer__item {
    display: flex;
    gap: 14px;
    padding: 14px 0;
    border-bottom: 1px solid #f0f0f0;
    align-items: flex-start;
  }

  .custom-cart-drawer__item:last-child {
    border-bottom: none;
  }

  .custom-cart-drawer__item-image {
    width: 70px;
    flex-shrink: 0;
    border: 1px solid #eee;
    border-radius: 6px;
    overflow: hidden;
  }

  .custom-cart-drawer__item-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .custom-cart-drawer__item-details {
    flex: 1;
    min-width: 0;
  }

  .custom-cart-drawer__item-title {
    font-size: 13px;
    font-weight: 600;
    color: #000;
    text-decoration: none;
    display: block;
    margin-bottom: 4px;
    line-height: 1.3;
  }

  .custom-cart-drawer__item-title:hover {
    text-decoration: underline;
  }

  .custom-cart-drawer__item-variant {
    font-size: 12px;
    color: #888;
    margin: 0 0 4px;
  }

  .custom-cart-drawer__item-price {
    font-size: 13px;
    color: #333;
    margin-bottom: 8px;
  }

  .custom-cart-drawer__item-line-price {
    font-size: 14px;
    font-weight: 600;
    color: #000;
    white-space: nowrap;
    padding-top: 2px;
  }

  /* Quantity Controls */
  .custom-cart-drawer__quantity {
    display: inline-flex;
    align-items: center;
    border: 1px solid #ddd;
    border-radius: 20px;
    overflow: hidden;
  }

  .custom-cart-drawer__qty-btn {
    background: none;
    border: none;
    width: 30px;
    height: 30px;
    font-size: 16px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #c41e3a;
    font-weight: 600;
  }

  .custom-cart-drawer__qty-btn:hover {
    background: #f5f5f5;
  }

  .custom-cart-drawer__qty-value {
    font-size: 13px;
    min-width: 28px;
    text-align: center;
    font-weight: 600;
  }

  /* You May Also Like */
  .custom-cart-drawer__recommendations {
    flex-shrink: 0;
    padding: 14px 20px;
    border-top: 1px solid #eee;
    background: #fafafa;
  }

  .custom-cart-drawer__rec-title {
    font-size: 14px;
    font-weight: 700;
    color: #000;
    margin: 0 0 12px;
  }

  .custom-cart-drawer__rec-scroll {
    display: flex;
    gap: 12px;
    overflow-x: auto;
    padding-bottom: 6px;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
  }

  .custom-cart-drawer__rec-scroll::-webkit-scrollbar {
    height: 4px;
  }

  .custom-cart-drawer__rec-scroll::-webkit-scrollbar-track {
    background: #eee;
    border-radius: 2px;
  }

  .custom-cart-drawer__rec-scroll::-webkit-scrollbar-thumb {
    background: #999;
    border-radius: 2px;
  }

  .custom-cart-drawer__rec-card {
    min-width: 140px;
    max-width: 140px;
    scroll-snap-align: start;
    border: 1px solid #eee;
    border-radius: 8px;
    background: #fff;
    padding: 10px;
    flex-shrink: 0;
  }

  .custom-cart-drawer__rec-img {
    width: 100%;
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: 4px;
    margin-bottom: 8px;
    background: #f5f5f5;
  }

  .custom-cart-drawer__rec-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .custom-cart-drawer__rec-info {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 6px;
  }

  .custom-cart-drawer__rec-price {
    font-size: 13px;
    font-weight: 700;
    color: #000;
  }

  .custom-cart-drawer__rec-add {
    background: #000;
    color: #fff;
    border: none;
    border-radius: 4px;
    padding: 4px 12px;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .custom-cart-drawer__rec-add:hover {
    background: #333;
  }

  .custom-cart-drawer__rec-add:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .custom-cart-drawer__rec-name {
    font-size: 11px;
    color: #555;
    margin: 0;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .custom-cart-drawer__rec-name a {
    color: inherit;
    text-decoration: none;
  }

  .custom-cart-drawer__rec-name a:hover {
    text-decoration: underline;
  }

  /* Footer */
  .custom-cart-drawer__footer {
    border-top: 1px solid #eee;
    padding: 18px 20px;
    flex-shrink: 0;
    background: #fff;
  }

  .custom-cart-drawer__total {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 6px;
  }

  .custom-cart-drawer__total-price {
    font-size: 18px;
  }

  .custom-cart-drawer__tax-note {
    font-size: 12px;
    color: #888;
    margin: 0 0 14px;
  }

  .custom-cart-drawer__checkout-btn {
    display: block;
    width: 100%;
    padding: 14px;
    background: #000;
    color: #fff;
    text-align: center;
    text-decoration: none;
    border-radius: 4px;
    font-size: 15px;
    font-weight: 600;
    border: none;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .custom-cart-drawer__checkout-btn:hover {
    background: #333;
  }

  /* Mobile adjustments */
  @media screen and (max-width: 480px) {
    .custom-cart-drawer {
      width: 100vw;
      max-width: 100vw;
    }
  }
{% endstylesheet %}

