{%- liquid
  assign logo = section.settings.logo
  assign search_placeholder = section.settings.search_placeholder
-%}

<header
  class="custom-header"
  style="
    --ch-bg: {{ section.settings.background_color }};
    --ch-text: {{ section.settings.text_color }};
    --ch-border: {{ section.settings.border_color }};
  "
>
  <div class="custom-header__inner page-width">
    <!-- Hamburger (mobile only) -->
    <button
      type="button"
      class="custom-header__hamburger"
      aria-label="Open menu"
      onclick="window.openCustomMobileMenu && window.openCustomMobileMenu();"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>

    <!-- Search -->
    <div class="custom-header__search" data-ch-search>
      <form action="/search" method="get" class="custom-header__search-form">
        <input
          type="search"
          name="q"
          class="custom-header__search-input"
          placeholder="{{ search_placeholder }}"
          autocomplete="off"
          data-ch-search-input
        >
        <button type="submit" class="custom-header__search-btn" aria-label="Search">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
        </button>
      </form>

      <!-- Predictive Search Dropdown -->
      <div class="ch-search-results" data-ch-search-results hidden>
        <div class="ch-search-loading" data-ch-search-loading hidden>Searching...</div>
        <div class="ch-search-content" data-ch-search-content></div>
      </div>
    </div>

    <!-- Logo -->
    <div class="custom-header__logo">
      <a href="/" class="custom-header__logo-link">
        {%- if logo != blank -%}
          {{ logo | image_url: width: 400 | image_tag: class: 'custom-header__logo-img', loading: 'eager', alt: shop.name }}
        {%- else -%}
          <span class="custom-header__logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </div>

    <!-- Icons -->
    <div class="custom-header__icons">
      {%- if section.settings.show_account and shop.customer_accounts_enabled -%}
        <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}" class="custom-header__icon" aria-label="Account">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
            <circle cx="12" cy="7" r="4"></circle>
          </svg>
        </a>
      {%- endif -%}

      {%- if section.settings.show_wishlist -%}
        <a href="{{ section.settings.wishlist_url | default: '/pages/wishlist' }}" class="custom-header__icon" aria-label="Wishlist">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
          </svg>
        </a>
      {%- endif -%}

      <!-- Side Cart Drawer -->
      <div class="custom-cart-drawer-wrapper">
        <button class="custom-header__icon custom-header__cart" aria-label="Open cart" onclick="document.getElementById('custom-cart-drawer').classList.add('is-open'); document.getElementById('custom-cart-overlay').classList.add('is-open');">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <path d="M16 10a4 4 0 0 1-8 0"></path>
          </svg>
          <span class="custom-header__cart-count" data-cart-count>{{ cart.item_count }}</span>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- Mobile Menu Overlay -->
<div
  id="custom-mobile-menu-overlay"
  class="custom-mobile-menu-overlay"
  onclick="document.getElementById('custom-mobile-menu').classList.remove('is-open'); this.classList.remove('is-open');"
></div>

<!-- Mobile Menu Drawer -->
<div id="custom-mobile-menu" class="custom-mobile-menu">
  <div class="custom-mobile-menu__header">
    <span class="custom-mobile-menu__title">Menu</span>
    <button
      type="button"
      class="custom-mobile-menu__close"
      aria-label="Close menu"
      onclick="document.getElementById('custom-mobile-menu').classList.remove('is-open'); document.getElementById('custom-mobile-menu-overlay').classList.remove('is-open');"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>
  <div class="custom-mobile-menu__nav" aria-label="Main" data-mobile-menu-body>
    {% comment %} Content is injected from #site-header-nav (header-navigation section) on hamburger click {% endcomment %}
  </div>
  {% comment %}
  <nav class="custom-mobile-menu__nav" aria-label="Main">
    <ul class="navmenu navmenu-depth-1" data-navmenu="" aria-label="Menu Hierarchy" style="display:flex;align-items:center;height:auto;margin:0;">

      {% for link in linklists[section.settings.mobile_menu].links %}
        {% assign link_handle = link.title | handleize %}

        {% if link.links.size > 0 %}
          {% comment %} ========== MEGA MENU ITEM ========== {% endcomment %}
          {% assign meganav_id = 'meganav_mobile_' | append: section.id | append: '_' | append: forloop.index %}

          <li class="navmenu-item navmenu-item-parent navmenu-meganav__item-parent navmenu-id-{{ link_handle }}"
              data-navmenu-meganav-trigger=""
              data-navmenu-meganav-type="multi-column-menu"
              data-navmenu-parent=""
              style="display:flex;align-items:center;padding-top:0;height:auto;--menu-closed-height:0;">
            <details data-navmenu-details="">
              <summary class="navmenu-link navmenu-link-depth-1 navmenu-link-parent"
                       aria-haspopup="true"
                       aria-expanded="false"
                       data-href="{{ link.url }}">
                {{ link.title }}
                <span class="navmenu-icon navmenu-icon-depth-1" data-navmenu-trigger="">
                  <svg aria-hidden="true" focusable="false" role="presentation" width="8" height="6" viewBox="0 0 8 6" fill="none" xmlns="http://www.w3.org/2000/svg" class="icon-chevron-down" style="animation:none;">
                    <path class="icon-chevron-down-left" d="M4 4.5L7 1.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="square"></path>
                    <path class="icon-chevron-down-right" d="M4 4.5L1 1.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="square"></path>
                  </svg>
                </span>
              </summary>

              <div class="navmenu-meganav navmenu-meganav--desktop navmenu-meganav-multi-column"
                   data-navmenu-submenu=""
                   data-meganav-menu=""
                   data-meganav-id="{{ meganav_id }}"
                   data-meganav-multi-column=""
                   style="display:none;opacity:0;visibility:hidden;">
                <div class="multi-col-wrapper">

                  {% comment %} Left Column: Categories (Level 2 links) {% endcomment %}
                  <div class="multi-col-categories">
                    <p class="multi-col-categories-title">Browse by category</p>
                    <ul class="multi-col-category-list">
                      {% for child_link in link.links %}
                        <li class="multi-col-category-item">
                          <a href="{{ child_link.url }}"
                             class="multi-col-category-link{% if forloop.first %} active{% endif %}"
                             data-category-index="{{ forloop.index }}">
                            <span class="multi-col-category-text">{{ child_link.title }}</span>
                            <svg class="multi-col-category-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="animation:none;">
                              <polyline points="9 18 15 12 9 6"></polyline>
                            </svg>
                          </a>
                        </li>
                      {% endfor %}
                    </ul>
                  </div>

                  {% comment %} Middle Column: Submenus (Level 3 links) {% endcomment %}
                  <div class="multi-col-submenus">
                    {% for child_link in link.links %}
                      <div class="multi-col-submenu-panel{% if forloop.first %} active{% endif %}" data-submenu-panel="{{ forloop.index }}">
                        <div class="multi-col-submenu-grid">
                          {% for grandchild_link in child_link.links %}
                            <a href="{{ grandchild_link.url }}" class="multi-col-submenu-link">{{ grandchild_link.title }}</a>
                          {% endfor %}
                          <a href="{{ child_link.url }}" class="multi-col-submenu-link multi-col-submenu-link--view-all">View All {{ child_link.title }} &rarr;</a>
                        </div>
                      </div>
                    {% endfor %}
                  </div>

                  {% comment %} Right Column: Featured (images + products per category) {% endcomment %}
                  <div class="multi-col-featured">
                    <p class="multi-col-featured-title">Featured</p>

                    {% for child_link in link.links %}
                      {% assign child_handle = child_link.title | handleize %}
                      <div class="multi-col-featured-panel{% if forloop.first %} active{% endif %}" data-featured-panel="{{ forloop.index }}">

                        {% comment %} Featured Images for this category {% endcomment %}
                        {% for block in section.blocks %}
                          {% if block.type == 'featured_image' %}
                            {% assign block_parent_handle = block.settings.parent_menu_title | handleize %}
                            {% assign block_category_handle = block.settings.category_title | handleize %}
                            {% if block_parent_handle == link_handle and block_category_handle == child_handle and block.settings.image != blank %}
                              <a href="{{ block.settings.link | default: child_link.url }}" class="multi-col-featured-item" {{ block.shopify_attributes }}>
                                <div class="multi-col-featured-image-wrapper">
                                  <img src="{{ block.settings.image | image_url: width: 200 }}"
                                       alt="{{ block.settings.image.alt | default: block.settings.heading | escape }}"
                                       class="multi-col-featured-image"
                                       loading="lazy">
                                  <div class="multi-col-featured-content">
                                    {% if block.settings.heading != blank %}
                                      <p class="multi-col-featured-item-title">{{ block.settings.heading }}</p>
                                    {% endif %}
                                    {% if block.settings.subtext != blank %}
                                      <span class="multi-col-featured-subtext">{{ block.settings.subtext }}</span>
                                    {% endif %}
                                    <span class="multi-col-featured-cta">
                                      {{ block.settings.cta_text | default: 'Shop Now' }}
                                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="animation:none;">
                                        <polyline points="9 18 15 12 9 6"></polyline>
                                      </svg>
                                    </span>
                                  </div>
                                </div>
                              </a>
                            {% endif %}
                          {% endif %}
                        {% endfor %}

                        {% comment %} Featured Products for this category {% endcomment %}
                        {% for block in section.blocks %}
                          {% if block.type == 'featured_product' %}
                            {% assign block_parent_handle = block.settings.parent_menu_title | handleize %}
                            {% assign block_category_handle = block.settings.category_title | handleize %}
                            {% if block_parent_handle == link_handle and block.settings.product != blank %}
                              {% assign show_product = false %}
                              {% if block.settings.category_title == blank %}
                                {% assign show_product = true %}
                              {% elsif block_category_handle == child_handle %}
                                {% assign show_product = true %}
                              {% endif %}
                              {% if show_product %}
                                {% assign feat_product = block.settings.product %}
                                <a href="{{ feat_product.url }}" class="multi-col-featured-item" {{ block.shopify_attributes }}>
                                  <div class="multi-col-featured-image-wrapper">
                                    {% if feat_product.featured_image %}
                                      <img src="{{ feat_product.featured_image | image_url: width: 200 }}"
                                           alt="{{ feat_product.featured_image.alt | escape }}"
                                           class="multi-col-featured-image"
                                           loading="lazy">
                                    {% endif %}
                                    <div class="multi-col-featured-content">
                                      <p class="multi-col-featured-item-title">{{ feat_product.title | truncate: 45 }}</p>
                                      <span class="multi-col-featured-price">{{ feat_product.price | money }}</span>
                                      <span class="multi-col-featured-cta">
                                        Shop Now
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="animation:none;">
                                          <polyline points="9 18 15 12 9 6"></polyline>
                                        </svg>
                                      </span>
                                    </div>
                                  </div>
                                </a>
                              {% endif %}
                            {% endif %}
                          {% endif %}
                        {% endfor %}

                      </div>
                    {% endfor %}
                  </div>

                </div>
              </div>
            </details>
          </li>

        {% else %}
          {% comment %} ========== SIMPLE LINK ========== {% endcomment %}
          <li class="navmenu-item navmenu-basic__item navmenu-id-{{ link_handle }}" style="display:flex;align-items:center;padding-top:0;height:auto;">
            <a class="navmenu-link navmenu-link-depth-1" href="{{ link.url }}">{{ link.title }}</a>
          </li>
        {% endif %}
      {% endfor %}

    </ul>
  </nav>
  {% endcomment %}
</div>

<script>
  (function() {
    var menu = document.getElementById('custom-mobile-menu');
    if (!menu) return;
    menu.querySelectorAll('[data-mobile-menu-toggle]').forEach(function(toggle) {
      toggle.addEventListener('click', function(e) {
        e.preventDefault();
        var item = toggle.closest('.custom-mobile-menu__item');
        if (item) item.classList.toggle('is-open');
      });
    });
  })();

  // Open mobile drawer with header-navigation content cloned in
  window.openCustomMobileMenu = function() {
    var drawer = document.getElementById('custom-mobile-menu');
    var overlay = document.getElementById('custom-mobile-menu-overlay');
    var body = drawer && drawer.querySelector('[data-mobile-menu-body]');
    var source = document.getElementById('site-header-nav');

    if (body && source && !body.dataset.populated) {
      // Clone the header-navigation markup so the live desktop nav stays intact
      var clone = source.cloneNode(true);
      clone.removeAttribute('id');
      // Force inner nav/menus to be visible inside the drawer regardless of desktop CSS
      clone.querySelectorAll('[style]').forEach(function(el) {
        if (el.style.display === 'none') el.style.display = '';
        if (el.style.visibility === 'hidden') el.style.visibility = '';
        if (el.style.opacity === '0') el.style.opacity = '';
      });

      // Restructure each mega menu for mobile: nest each submenu panel inside
      // its matching category item, and drop the desktop-only featured column.
      clone.querySelectorAll('.navmenu-meganav-multi-column').forEach(function(meganav) {
        var categoryItems = meganav.querySelectorAll('.multi-col-category-item');
        var submenuPanels = meganav.querySelectorAll('.multi-col-submenu-panel');
        categoryItems.forEach(function(item, i) {
          var panel = submenuPanels[i];
          if (panel) {
            panel.classList.remove('active');
            item.appendChild(panel);
          }
          // Strip the desktop "active" highlight; mobile uses click-to-open instead
          var link = item.querySelector('.multi-col-category-link');
          if (link) link.classList.remove('active');
        });
        var featured = meganav.querySelector('.multi-col-featured');
        if (featured) featured.remove();
        var submenusWrap = meganav.querySelector('.multi-col-submenus');
        if (submenusWrap) submenusWrap.remove();
        var catTitle = meganav.querySelector('.multi-col-categories-title');
        if (catTitle) catTitle.remove();
        // Remove "View All" links inside the mobile menu
        meganav.querySelectorAll('.multi-col-submenu-link--view-all').forEach(function(el) {
          el.remove();
        });
      });

      // Click on a level-2 category toggles its nested submenu panel
      clone.querySelectorAll('.multi-col-category-link').forEach(function(link) {
        link.addEventListener('click', function(e) {
          var item = this.closest('.multi-col-category-item');
          // Only intercept if there's a nested submenu to toggle
          if (item && item.querySelector('.multi-col-submenu-panel')) {
            e.preventDefault();
            item.classList.toggle('is-open');
          }
        });
      });

      body.innerHTML = '';
      body.appendChild(clone);
      body.dataset.populated = '1';
    }

    if (drawer) drawer.classList.add('is-open');
    if (overlay) overlay.classList.add('is-open');
  };
</script>

<!-- Cart Drawer Overlay -->
<div id="custom-cart-overlay" class="custom-cart-overlay" onclick="document.getElementById('custom-cart-drawer').classList.remove('is-open'); this.classList.remove('is-open');"></div>

<!-- Cart Drawer Panel -->
<div id="custom-cart-drawer" class="custom-cart-drawer">
  <div class="custom-cart-drawer__inner">
    <!-- Header -->
    <div class="custom-cart-drawer__header">
      <span class="custom-cart-drawer__title">Your Beautiful Picks</span>
      <button class="custom-cart-drawer__close" aria-label="Close cart" onclick="document.getElementById('custom-cart-drawer').classList.remove('is-open'); document.getElementById('custom-cart-overlay').classList.remove('is-open');">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    {%- unless cart.empty? -%}
      <!-- Free Shipping Banner -->
      <div class="custom-cart-drawer__shipping-banner">
        You're eligible for <strong>free UK shipping!</strong>
      </div>
    {%- endunless -%}

    <!-- Cart Content -->
    <div class="custom-cart-drawer__content">
      {%- if cart.empty? -%}
        <div class="custom-cart-drawer__empty">
          <p>Your cart is empty</p>
          <a href="{{ routes.all_products_collection_url }}" class="custom-cart-drawer__continue-btn">Continue Shopping</a>
        </div>
      {%- else -%}
        <!-- Cart Items -->
        <form action="{{ routes.cart_url }}" method="post" id="custom-cart-form">
          {%- for item in cart.items -%}
            <div class="custom-cart-drawer__item" data-line-key="{{ item.key }}" data-line-index="{{ forloop.index }}">
              <div class="custom-cart-drawer__item-image">
                {%- if item.image -%}
                  <a href="{{ item.url }}">
                    {{ item.image | image_url: width: 150 | image_tag: loading: 'lazy' }}
                  </a>
                {%- endif -%}
              </div>
              <div class="custom-cart-drawer__item-details">
                <a href="{{ item.url }}" class="custom-cart-drawer__item-title">{{ item.product.title }}</a>
                {%- if item.product.has_only_default_variant == false -%}
                  <p class="custom-cart-drawer__item-variant">
                    {%- for option in item.options_with_values -%}
                      {{ option.value }}{% unless forloop.last %} / {% endunless %}
                    {%- endfor -%}
                  </p>
                {%- endif -%}
                <div class="custom-cart-drawer__item-price">{{ item.final_price | money }}</div>
                <div class="custom-cart-drawer__quantity">
                  <button type="button" class="custom-cart-drawer__qty-btn" aria-label="Decrease quantity" onclick="updateCartQty(this, -1)">−</button>
                  <span class="custom-cart-drawer__qty-value">{{ item.quantity }}</span>
                  <button type="button" class="custom-cart-drawer__qty-btn" aria-label="Increase quantity" onclick="updateCartQty(this, 1)">+</button>
                </div>
              </div>
              <div class="custom-cart-drawer__item-line-price">
                {{ item.final_line_price | money }}
              </div>
            </div>
          {%- endfor -%}
        </form>
      {%- endif -%}

      {%- unless cart.empty? -%}
        <!-- You May Also Like Section -->
        <div class="custom-cart-drawer__recommendations">
          <h3 class="custom-cart-drawer__rec-title">You May Also Like</h3>
          <div class="custom-cart-drawer__rec-scroll" id="cart-drawer-recommendations">

            {%- comment -%} Server-side rendered recommendations from collections {%- endcomment -%}
            {%- assign rec_product_ids = '' -%}
            {%- for item in cart.items -%}
              {%- assign rec_product_ids = rec_product_ids | append: item.product.id | append: ',' -%}
            {%- endfor -%}

            {%- assign rec_count = 0 -%}
            {%- for item in cart.items -%}
              {%- if rec_count >= 6 -%}{%- break -%}{%- endif -%}
              {%- for collection in item.product.collections -%}
                {%- if rec_count >= 6 -%}{%- break -%}{%- endif -%}
                {%- for product in collection.products limit: 10 -%}
                  {%- if rec_count >= 6 -%}{%- break -%}{%- endif -%}
                  {%- assign pid_check = product.id | append: ',' -%}
                  {%- if rec_product_ids contains pid_check -%}{%- continue -%}{%- endif -%}
                  {%- assign rec_product_ids = rec_product_ids | append: product.id | append: ',' -%}
                  {%- assign rec_count = rec_count | plus: 1 -%}
                  <div class="custom-cart-drawer__rec-card">
                    <div class="custom-cart-drawer__rec-img">
                      {%- if product.featured_image -%}
                        <a href="{{ product.url }}">
                          {{ product.featured_image | image_url: width: 200 | image_tag: loading: 'lazy' }}
                        </a>
                      {%- endif -%}
                    </div>
                    <div class="custom-cart-drawer__rec-info">
                      <span class="custom-cart-drawer__rec-price">{{ product.price | money }}</span>
                      <button class="custom-cart-drawer__rec-add" onclick="addRecToCart({{ product.variants.first.id }}, this)">Add</button>
                    </div>
                    <p class="custom-cart-drawer__rec-name">
                      <a href="{{ product.url }}">{{ product.title }}</a>
                    </p>
                  </div>
                {%- endfor -%}
              {%- endfor -%}
            {%- endfor -%}

          </div>
        </div>
      {%- endunless -%}
    </div>

    {%- unless cart.empty? -%}
      <!-- Cart Footer -->
      <div class="custom-cart-drawer__footer">
        <div class="custom-cart-drawer__total">
          <span>Total</span>
          <span class="custom-cart-drawer__total-price">{{ cart.total_price | money }}</span>
        </div>
        <p class="custom-cart-drawer__tax-note">Coupons apply at checkout.</p>
        <a href="{{ routes.cart_url }}/checkout" class="custom-cart-drawer__checkout-btn">Checkout</a>
      </div>
    {%- endunless -%}
  </div>
</div>

<script>
  // ===================== //
  // PREDICTIVE SEARCH     //
  // ===================== //
  (function() {
    var searchEl = document.querySelector('[data-ch-search]');
    if (!searchEl) return;
    var input = searchEl.querySelector('[data-ch-search-input]');
    var resultsEl = searchEl.querySelector('[data-ch-search-results]');
    var contentEl = searchEl.querySelector('[data-ch-search-content]');
    var loadingEl = searchEl.querySelector('[data-ch-search-loading]');
    var debounceTimer = null;
    var moneyFormat = {{ shop.money_format | json }};

    function formatMoney(cents) {
      var amount = (cents / 100).toFixed(2);
      var amountNoDecimals = Math.round(cents / 100);
      var amountWithComma = amount.replace('.', ',');
      return moneyFormat
        .replace(/\{\{\s*amount_with_comma_separator\s*\}\}/g, amountWithComma)
        .replace(/\{\{\s*amount_no_decimals\s*\}\}/g, amountNoDecimals)
        .replace(/\{\{\s*amount\s*\}\}/g, amount);
    }

    function escapeHtml(str) {
      if (str == null) return '';
      return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function getRecentQueries() {
      try {
        var raw = localStorage.getItem('ch_recent_queries');
        return raw ? JSON.parse(raw) : [];
      } catch(e) { return []; }
    }

    function addRecentQuery(q) {
      if (!q) return;
      var list = getRecentQueries();
      list = list.filter(function(x) { return x !== q; });
      list.unshift(q);
      list = list.slice(0, 6);
      try { localStorage.setItem('ch_recent_queries', JSON.stringify(list)); } catch(e) {}
    }

    function removeRecentQuery(q) {
      var list = getRecentQueries().filter(function(x) { return x !== q; });
      try { localStorage.setItem('ch_recent_queries', JSON.stringify(list)); } catch(e) {}
    }

    function showResults() { resultsEl.hidden = false; }
    function hideResults() { resultsEl.hidden = true; }

    function renderLeftColumn(query, collections) {
      var html = '';
      var recent = getRecentQueries();
      if (recent.length) {
        html += '<div class="ch-search-section">';
        html += '<div class="ch-search-section-title">Your Search Queries</div>';
        html += '<ul class="ch-search-list">';
        recent.forEach(function(q) {
          html += '<li class="ch-search-recent-item">' +
                  '<a href="/search?q=' + encodeURIComponent(q) + '">' + escapeHtml(q) + '</a>' +
                  '<button type="button" class="ch-search-recent-remove" data-recent-remove="' + escapeHtml(q) + '" aria-label="Remove">&times;</button>' +
                  '</li>';
        });
        html += '</ul></div>';
      }

      if (collections && collections.length) {
        html += '<div class="ch-search-section">';
        html += '<div class="ch-search-section-title">Categories</div>';
        html += '<ul class="ch-search-list">';
        collections.slice(0, 6).forEach(function(c) {
          html += '<li><a href="' + c.url + '">' + escapeHtml(c.title) + '</a></li>';
        });
        html += '</ul></div>';
      }

      return html;
    }

    function renderPopularProducts(products) {
      if (!products || !products.length) return '';
      var html = '<div class="ch-search-section">';
      html += '<div class="ch-search-section-title">Popular Products</div>';
      html += '<ul class="ch-search-list">';
      products.slice(0, 4).forEach(function(p) {
        html += '<li><a href="' + p.url + '">' + escapeHtml(p.title) + '</a></li>';
      });
      html += '</ul></div>';
      return html;
    }

    function renderRightColumn(query, products, queries) {
      var html = '<div class="ch-search-section">';
      html += '<div class="ch-search-section-title">Pages</div>';
      html += '<div class="ch-search-info">Showing <strong>' + products.length + '</strong> results for <strong>' + escapeHtml(query) + '</strong>.';
      if (queries && queries.length) html += ' Did you mean: ';
      html += '</div>';
      if (queries && queries.length) {
        html += '<div class="ch-search-suggestions-row">';
        queries.slice(0, 4).forEach(function(q) {
          var text = q.text || q;
          html += '<a href="/search?q=' + encodeURIComponent(text) + '">' + escapeHtml(text) + '</a>';
        });
        html += '</div>';
      }
      html += '</div>';

      html += '<div class="ch-search-section">';
      html += '<div class="ch-search-section-title">Products</div>';
      if (products.length) {
        html += '<div class="ch-search-products-grid">';
        products.slice(0, 4).forEach(function(p) {
          var img = p.featured_image && p.featured_image.url ? p.featured_image.url : (p.image || '');
          var price = (p.price !== undefined) ? formatMoney(p.price) : '';
          html += '<a href="' + p.url + '" class="ch-search-product-card">' +
                  '<div class="ch-search-product-card__image">' +
                  (img ? '<img src="' + img + '" alt="' + escapeHtml(p.title) + '" loading="lazy">' : '') +
                  '</div>' +
                  '<div class="ch-search-product-card__vendor">' + escapeHtml(p.vendor || '') + '</div>' +
                  '<div class="ch-search-product-card__title">' + escapeHtml(p.title) + '</div>' +
                  '<div class="ch-search-product-card__price">' + price + '</div>' +
                  '<div class="ch-search-product-card__rating">★★★★★</div>' +
                  '</a>';
        });
        html += '</div>';
      } else {
        html += '<div class="ch-search-empty">No products found.</div>';
      }
      html += '</div>';

      return html;
    }

    function render(query, data) {
      var products = (data.resources && data.resources.results && data.resources.results.products) || [];
      var collections = (data.resources && data.resources.results && data.resources.results.collections) || [];
      var queries = (data.resources && data.resources.results && data.resources.results.queries) || [];

      var html = '<div class="ch-search-wrapper">';
      html += '<div class="ch-search-left">' + renderLeftColumn(query, collections) + renderPopularProducts(products) + '</div>';
      html += '<div class="ch-search-right">' + renderRightColumn(query, products, queries) + '</div>';
      html += '</div>';
      html += '<div class="ch-search-all"><a href="/search?q=' + encodeURIComponent(query) + '">View All Results for "' + escapeHtml(query) + '"</a></div>';

      contentEl.innerHTML = html;
    }

    function renderEmpty() {
      var recent = getRecentQueries();
      if (!recent.length) {
        contentEl.innerHTML = '<div class="ch-search-empty">Start typing to search...</div>';
        return;
      }
      var html = '<div class="ch-search-wrapper">';
      html += '<div class="ch-search-left">' + renderLeftColumn('', []) + '</div>';
      html += '<div class="ch-search-right"><div class="ch-search-empty">Start typing to see results.</div></div>';
      html += '</div>';
      contentEl.innerHTML = html;
    }

    function fetchPredictive(query) {
      loadingEl.hidden = false;
      var url = '/search/suggest.json?q=' + encodeURIComponent(query) +
                '&resources[type]=product,collection,query' +
                '&resources[limit]=6&resources[options][unavailable_products]=last';
      fetch(url)
        .then(function(r) { return r.json(); })
        .then(function(data) {
          loadingEl.hidden = true;
          render(query, data);
          showResults();
        })
        .catch(function() {
          loadingEl.hidden = true;
        });
    }

    input.addEventListener('focus', function() {
      if (input.value.trim().length >= 2) {
        fetchPredictive(input.value.trim());
      } else {
        renderEmpty();
        showResults();
      }
    });

    input.addEventListener('input', function() {
      var q = input.value.trim();
      clearTimeout(debounceTimer);
      if (q.length < 2) {
        renderEmpty();
        showResults();
        return;
      }
      debounceTimer = setTimeout(function() { fetchPredictive(q); }, 250);
    });

    // Save query on submit
    searchEl.querySelector('form').addEventListener('submit', function() {
      addRecentQuery(input.value.trim());
    });

    // Remove recent query button
    contentEl.addEventListener('click', function(e) {
      var btn = e.target.closest('[data-recent-remove]');
      if (btn) {
        e.preventDefault();
        e.stopPropagation();
        removeRecentQuery(btn.getAttribute('data-recent-remove'));
        var q = input.value.trim();
        if (q.length >= 2) fetchPredictive(q); else renderEmpty();
      }
    });

    // Close on outside click
    document.addEventListener('click', function(e) {
      if (!searchEl.contains(e.target)) hideResults();
    });

    // Close on Escape
    input.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') { hideResults(); input.blur(); }
    });
  })();

  // Auto-open cart drawer when item is added
  document.addEventListener('cart:add', function() {
    document.getElementById('custom-cart-drawer').classList.add('is-open');
    document.getElementById('custom-cart-overlay').classList.add('is-open');
  });

  // Format price in cents to money string
  function formatMoney(cents) {
    var moneyFormat = {{ shop.money_format | json }};
    var amount = (cents / 100).toFixed(2);
    var amountNoDecimals = Math.round(cents / 100);
    var amountWithComma = amount.replace('.', ',');
    return moneyFormat
      .replace(/\{\{\s*amount_with_comma_separator\s*\}\}/g, amountWithComma)
      .replace(/\{\{\s*amount_no_decimals\s*\}\}/g, amountNoDecimals)
      .replace(/\{\{\s*amount\s*\}\}/g, amount);
  }

  // Refresh cart drawer UI from cart JSON
  function refreshCartDrawer(cartData) {
    // Update total price
    var totalEl = document.querySelector('.custom-cart-drawer__total-price');
    if (totalEl) totalEl.textContent = formatMoney(cartData.total_price);

    // Update cart count badge
    document.querySelectorAll('[data-cart-count]').forEach(function(el) {
      el.textContent = cartData.item_count;
    });

    // Update each line item by key
    cartData.items.forEach(function(item, index) {
      var lineIndex = index + 1;
      var itemEl = document.querySelector('[data-line-index="' + lineIndex + '"]');
      if (!itemEl) return;
      var qtyEl = itemEl.querySelector('.custom-cart-drawer__qty-value');
      var linePriceEl = itemEl.querySelector('.custom-cart-drawer__item-line-price');
      if (qtyEl) qtyEl.textContent = item.quantity;
      if (linePriceEl) linePriceEl.textContent = formatMoney(item.final_line_price);
    });

    // Remove deleted items
    document.querySelectorAll('.custom-cart-drawer__item[data-line-key]').forEach(function(el) {
      var key = el.getAttribute('data-line-key');
      var found = cartData.items.some(function(item) { return item.key === key; });
      if (!found) el.remove();
    });

    // If cart empty, reload
    if (cartData.item_count === 0) window.location.reload();
  }

  // Update cart quantity using line index (most reliable Shopify method)
  function updateCartQty(btn, change) {
    var itemEl = btn.closest('.custom-cart-drawer__item');
    if (!itemEl) return;

    var lineIndex = parseInt(itemEl.getAttribute('data-line-index'));
    var qtyEl = itemEl.querySelector('.custom-cart-drawer__qty-value');
    var currentQty = parseInt(qtyEl.textContent);
    var newQty = Math.max(currentQty + change, 0);

    // Immediately update displayed quantity
    if (newQty > 0) qtyEl.textContent = newQty;

    // Disable buttons during request
    var btns = itemEl.querySelectorAll('.custom-cart-drawer__qty-btn');
    btns.forEach(function(b) { b.disabled = true; });

    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ line: lineIndex, quantity: newQty })
    })
    .then(function(res) { return res.json(); })
    .then(function(cartData) {
      refreshCartDrawer(cartData);
      // Re-enable buttons
      btns.forEach(function(b) { b.disabled = false; });
    })
    .catch(function() {
      // Revert on error
      qtyEl.textContent = currentQty;
      btns.forEach(function(b) { b.disabled = false; });
    });
  }

  // Add recommended product to cart
  function addRecToCart(variantId, btn) {
    btn.disabled = true;
    btn.textContent = '...';
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: 1 })
    })
    .then(function(res) { return res.json(); })
    .then(function() {
      btn.textContent = 'Added!';
      // Fetch fresh cart data to update totals
      return fetch('/cart.js').then(function(r) { return r.json(); });
    })
    .then(function(cartData) {
      refreshCartDrawer(cartData);
    })
    .catch(function() { btn.disabled = false; btn.textContent = 'Add'; });
  }
</script>

