{%- style -%}
.sc-section {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  background-color: {{ section.settings.bg_color }};
}

.sc-container {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 20px;
}

.sc-heading {
  font-family: inherit;
  font-size: 28px;
  font-weight: 400;
  color: #333;
  text-align: center;
  margin: 0 0 30px;
  letter-spacing: 0.02em;
}

.sc-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
}

.sc-item {
  text-align: center;
  text-decoration: none;
  display: block;
}

.sc-item__image-wrapper {
  position: relative;
  overflow: hidden;
  aspect-ratio: 1 / 1;
  background: #f5f5f5;
}

.sc-item__image-wrapper img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.4s ease;
}

.sc-item:hover .sc-item__image-wrapper img {
  transform: scale(1.05);
}

.sc-item__title {
  font-size: 16px;
  font-weight: 500;
  color: #e53935;
  margin: 14px 0 0;
  letter-spacing: 0.02em;
}

.sc-item:hover .sc-item__title {
  text-decoration: underline;
}

@media screen and (max-width: 999px) {
  .sc-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 15px;
  }

  .sc-heading {
    font-size: 24px;
    margin-bottom: 20px;
  }
}

@media screen and (max-width: 480px) {
  .sc-item__title {
    font-size: 14px;
  }
}
{%- endstyle -%}

<section class="sc-section">
  <div class="sc-container">
    {% if section.settings.heading != blank %}
      <h2 class="sc-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="sc-grid">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link }}" class="sc-item" {{ block.shopify_attributes }}>
          <div class="sc-item__image-wrapper">
            {% if block.settings.image != blank %}
              <img
                src="{{ block.settings.image | image_url: width: 600 }}"
                alt="{{ block.settings.title | escape }}"
                loading="lazy"
                width="600"
                height="600"
              >
            {% else %}
              {{ 'collection-1' | placeholder_svg_tag }}
            {% endif %}
          </div>
          {% if block.settings.title != blank %}
            <p class="sc-item__title">{{ block.settings.title }}</p>
          {% endif %}
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Signature Collections",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Signature Collections"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 40,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "collection_item",
      "name": "Collection",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Collection Name"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Signature Collections",
      "blocks": [
        { "type": "collection_item", "settings": { "title": "Flatback Studs" } },
        { "type": "collection_item", "settings": { "title": "Nose Studs" } },
        { "type": "collection_item", "settings": { "title": "Hinged Segment Clicker" } },
        { "type": "collection_item", "settings": { "title": "Huggies & Studs" } }
      ]
    }
  ]
}
{% endschema %}
