  .cf-slide {
    flex: 0 0 50%;
    max-width: 50%;
  }

  .cf-heading {
    font-size: 20px;
  }

  .cf-nav {
    width: 30px;
    height: 30px;
  }

  .cf-nav svg {
    width: 12px;
    height: 12px;
  }

  .cf-quickshop-modal {
    width: 95%;
    max-height: 95vh;
  }

  .cf-quickshop-modal__content.cf-loaded {
    grid-template-columns: 1fr;
  }

  .cf-quickshop__images {
    padding: 15px;
  }

  .cf-quickshop__details {
    padding: 20px 15px;
    max-height: none;
