{{ 'image-text-carousel.css' | asset_url | stylesheet_tag }}

<div class="image-text-carousel" data-carousel-section data-autoplay="{{ section.settings.autoplay_speed }}">
  <div class="carousel__track">
    {% for block in section.blocks %}
      <div class="carousel__slide {% if forloop.first %}is-active{% endif %}" data-slide-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
        <div class="carousel__slide-inner">
          <div class="carousel__image carousel__image--left">
            {% if block.settings.image_left != blank %}
              {{ block.settings.image_left | image_url: width: 1200 | image_tag: loading: 'lazy', class: 'carousel__img', sizes: '(min-width: 750px) 33vw, 100vw' }}
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'carousel__placeholder' }}
            {% endif %}
          </div>

          <div class="carousel__content color-{{ section.settings.color_scheme }}">
            {% if block.settings.heading != blank %}
              <h2 class="carousel__heading" style="color: {{ block.settings.heading_color }};">{{ block.settings.heading }}</h2>
            {% endif %}
            {% if block.settings.button_label != blank %}
              <a href="{{ block.settings.button_link }}" class="carousel__button" style="color: {{ block.settings.button_color }}; border-color: {{ block.settings.button_color }};">
                {{ block.settings.button_label }}
              </a>
            {% endif %}
          </div>

          <div class="carousel__image carousel__image--right">
            {% if block.settings.image_right != blank %}
              {{ block.settings.image_right | image_url: width: 1200 | image_tag: loading: 'lazy', class: 'carousel__img', sizes: '(min-width: 750px) 33vw, 100vw' }}
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'carousel__placeholder' }}
            {% endif %}
          </div>
        </div>
      </div>
    {% endfor %}
  </div>

  {% if section.blocks.size > 1 %}
    <button class="carousel__arrow carousel__arrow--prev" data-carousel-prev aria-label="Previous slide">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M13 4L7 10L13 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
    <button class="carousel__arrow carousel__arrow--next" data-carousel-next aria-label="Next slide">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M7 4L13 10L7 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <div class="carousel__dots" data-carousel-dots>
      {% for block in section.blocks %}
        <button class="carousel__dot {% if forloop.first %}is-active{% endif %}" data-carousel-dot="{{ forloop.index0 }}" aria-label="Go to slide {{ forloop.index }}"></button>
      {% endfor %}
    </div>
  {% endif %}
</div>

<script>
  (function() {
    var section = document.querySelector('[data-carousel-section]');
    if (!section) return;

    var slides = section.querySelectorAll('.carousel__slide');
    var dots = section.querySelectorAll('[data-carousel-dot]');
    var prevBtn = section.querySelector('[data-carousel-prev]');
    var nextBtn = section.querySelector('[data-carousel-next]');
    var autoplaySpeed = parseInt(section.getAttribute('data-autoplay'), 10) * 1000;
    var current = 0;
    var total = slides.length;
    var interval = null;
    var isHovered = false;

    function goTo(index) {
      slides[current].classList.remove('is-active');
      if (dots[current]) dots[current].classList.remove('is-active');

      current = (index + total) % total;

      slides[current].classList.add('is-active');
      if (dots[current]) dots[current].classList.add('is-active');
    }

    function next() { goTo(current + 1); }
    function prev() { goTo(current - 1); }

    function startAutoplay() {
      if (interval) clearInterval(interval);
      interval = setInterval(function() {
        if (!isHovered && !document.hidden) next();
      }, autoplaySpeed);
    }

    function stopAutoplay() {
      clearInterval(interval);
      interval = null;
    }

    if (prevBtn) prevBtn.addEventListener('click', function() { prev(); startAutoplay(); });
    if (nextBtn) nextBtn.addEventListener('click', function() { next(); startAutoplay(); });

    dots.forEach(function(dot) {
      dot.addEventListener('click', function() {
        goTo(parseInt(this.getAttribute('data-carousel-dot'), 10));
        startAutoplay();
      });
    });

    section.addEventListener('mouseenter', function() { isHovered = true; });
    section.addEventListener('mouseleave', function() { isHovered = false; });

    document.addEventListener('visibilitychange', function() {
      if (document.hidden) stopAutoplay();
      else startAutoplay();
    });

    if (total > 1) startAutoplay();
  })();
</script>

{% schema %}
{
  "name": "Image Text Carousel",
  "class": "image-text-carousel-section",
  "settings": [
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Auto-rotate speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 5
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "primary"
    },
    {
      "type": "select",
      "id": "height",
      "label": "Section height",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "medium"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image_left",
          "label": "Left image"
        },
        {
          "type": "image_picker",
          "id": "image_right",
          "label": "Right image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Your new everyday stones"
        },
        {
          "type": "color",
          "id": "heading_color",
          "label": "Heading color",
          "default": "#6B2D8B"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "SHOP NATURAL STONES"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "color",
          "id": "button_color",
          "label": "Button color",
          "default": "#6B2D8B"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image Text Carousel",
      "category": "Storytelling",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "heading": "Your new everyday stones",
            "button_label": "SHOP NATURAL STONES"
          }
        },
        {
          "type": "slide",
          "settings": {
            "heading": "Discover our collection",
            "button_label": "SHOP NOW"
          }
        },
        {
          "type": "slide",
          "settings": {
            "heading": "Timeless elegance",
            "button_label": "EXPLORE MORE"
          }
        }
      ]
    }
  ]
}
{% endschema %}
