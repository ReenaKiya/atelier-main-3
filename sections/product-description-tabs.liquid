<style>
  .pdt-container{max-width:1550px;margin:20px auto;color:#222;box-sizing:border-box;padding:0 15px}
  .pdt-tabs{width:100%}
  .pdt-tab-nav{display:flex;align-items:center;margin-bottom:0;padding:0;position:relative;gap:8px;min-height:auto}
  .pdt-arrow{background:#f5f5f5;border:none;border-radius:50%;width:36px;height:36px;display:flex;align-items:center;justify-content:center;transition:all .2s;cursor:pointer;flex-shrink:0}
  .pdt-arrow:hover{background:#e0e0e0}
  .pdt-arrow svg{pointer-events:none}
  .pdt-tabs-scroll{flex:1;overflow-x:auto;display:flex;gap:8px;scrollbar-width:none;-ms-overflow-style:none;align-items:center}
  .pdt-tabs-scroll::-webkit-scrollbar{display:none}
  .pdt-tab-buttons{display:flex;min-width:max-content;width:100%;gap:8px;align-items:center}
  .pdt-tab-btn{padding:8px 20px;background:#f8f9fa;border:1px solid #e9ecef;border-bottom:none;border-radius:8px 8px 0 0;margin-bottom:-1px;font-size:16px;font-weight:600;cursor:pointer;white-space:nowrap;transition:all .3s ease;color:#212529;font-family:inherit}
  .pdt-tab-btn.active{background:#db1e37;color:#fff;border-color:#db1e37;box-shadow:0 -2px 8px rgba(0,0,0,.1)}
  .pdt-tab-content{display:none;padding:10px 24px 24px;background:#fff;border-radius:8px;box-shadow:0 2px 12px rgba(0,0,0,.08);margin-top:-1px;animation:pdtFadeIn .3s ease}
  .pdt-tab-content.active{display:block}
  .pdt-tab-content table,.pdt-acc-content table{border-collapse:collapse;width:100%;border:1px solid #000}
  .pdt-tab-content table th,.pdt-tab-content table td,.pdt-acc-content table th,.pdt-acc-content table td{border:1px solid #000;padding:8px 12px;text-align:left}
  .pdt-tab-content table th,.pdt-acc-content table th{background:#f8f9fa;font-weight:700}
  .pdt-tab-content ul,.pdt-tab-content ol,.pdt-acc-content ul,.pdt-acc-content ol{padding-left:20px;line-height:1.8}
  .pdt-tab-content li,.pdt-acc-content li{margin-bottom:4px}
  .pdt-tab-content p,.pdt-acc-content p{margin:0 0 12px;line-height:1.6}
  .pdt-tab-content p:last-child,.pdt-acc-content p:last-child{margin-bottom:0}
  @keyframes pdtFadeIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}

  /* FAQ styles */
  .pdt-faq-list{list-style:none;padding:0;margin:0}
  .pdt-faq-item{border:1px solid #eee;margin-bottom:8px;background:#fff;border-radius:4px;overflow:hidden}
  .pdt-faq-item:last-child{margin-bottom:0}
  .pdt-faq-item details{width:100%}
  .pdt-faq-item summary{padding:15px 20px;cursor:pointer;font-weight:600;font-size:16px;color:#000;background:#f5f5f5;display:flex;justify-content:space-between;align-items:center;transition:background-color .2s;list-style:none}
  .pdt-faq-item summary::-webkit-details-marker{display:none}
  .pdt-faq-item summary:hover{background:#e8e8e8}
  .pdt-faq-item details[open] summary{background:#fff;color:#333}
  .pdt-faq-icon{width:20px;height:20px;transition:transform .2s;flex-shrink:0;margin-left:12px}
  .pdt-faq-item details[open] .pdt-faq-icon{transform:rotate(180deg)}
  .pdt-faq-answer{padding:18px 20px;background:#fff;border-top:1px solid #eee;color:inherit;font-size:inherit}
  .pdt-faq-answer p{margin:0;line-height:1.6}

  /* Mobile accordion */
  .pdt-accordion{display:none}
  .pdt-acc-item{border:1px solid #eee;background:#fff;overflow:hidden;margin-bottom:8px;border-radius:8px}
  .pdt-acc-header{padding:16px 20px;font-size:16px;color:#212529;background:#f5f5f5;cursor:pointer;font-weight:600;display:flex;justify-content:space-between;align-items:center;transition:all .2s;border:none;width:100%;font-family:inherit}
  .pdt-acc-header:hover{background:#fff}
  .pdt-acc-header.active{background:#fff;color:#212529}
  .pdt-acc-icon::before{content:'+';font-size:20px;line-height:1;font-weight:300}
  .pdt-acc-header.active .pdt-acc-icon::before{content:'-'}
  .pdt-acc-content{padding:0 20px;display:none;background:#fff;border-top:1px solid #f0f0f0}
  .pdt-acc-content.active{display:block;padding:18px 20px}

  @media (max-width:749px){
    .pdt-desktop{display:none!important}
    .pdt-accordion{display:block}
    .pdt-acc-header,.pdt-acc-content{padding:12px 16px;font-size:15px}
    .pdt-tab-content table,.pdt-acc-content table{display:block;overflow-x:auto}
    .pdt-faq-item summary,.pdt-faq-answer{padding:12px 15px}
  }
  @media (min-width:750px){
    .pdt-accordion{display:none!important}
    .pdt-desktop{display:block}
  }
</style>

{%- comment -%}
  ============================================================
  DYNAMIC PRODUCT DESC TABS
  Reads from product metafields first (dynamic/app-populated),
  falls back to section settings (manual HTML), then product description.

  Required metafields (namespace: custom, type: multi_line_text_field):
    - custom.pdt_description
    - custom.pdt_specifications
    - custom.pdt_features
    - custom.pdt_how_to_use
    - custom.pdt_care_instructions
    - custom.pdt_materials
    - custom.pdt_ideal_usages
    - custom.pdt_size_guide
    - custom.pdt_faq
  ============================================================
{%- endcomment -%}

{%- comment -%} Resolve content: metafield > section setting > product description {%- endcomment -%}
{%- assign pdt_description = product.metafields.custom.pdt_description.value | default: blank -%}
{%- if pdt_description == blank -%}
  {%- assign pdt_description = section.settings.description_content -%}
{%- endif -%}
{%- if pdt_description == blank and product.description != blank -%}
  {%- assign pdt_description = product.description -%}
{%- endif -%}

{%- assign pdt_specifications = product.metafields.custom.pdt_specifications.value | default: blank -%}
{%- if pdt_specifications == blank -%}
  {%- assign pdt_specifications = section.settings.specifications_content -%}
{%- endif -%}

{%- assign pdt_features = product.metafields.custom.pdt_features.value | default: blank -%}
{%- if pdt_features == blank -%}
  {%- assign pdt_features = section.settings.features_content -%}
{%- endif -%}

{%- assign pdt_how_to_use = product.metafields.custom.pdt_how_to_use.value | default: blank -%}
{%- if pdt_how_to_use == blank -%}
  {%- assign pdt_how_to_use = section.settings.how_to_use_content -%}
{%- endif -%}

{%- assign pdt_care = product.metafields.custom.pdt_care_instructions.value | default: blank -%}
{%- if pdt_care == blank -%}
  {%- assign pdt_care = section.settings.care_content -%}
{%- endif -%}

{%- assign pdt_materials = product.metafields.custom.pdt_materials.value | default: blank -%}
{%- if pdt_materials == blank -%}
  {%- assign pdt_materials = section.settings.materials_content -%}
{%- endif -%}

{%- assign pdt_ideal_usages = product.metafields.custom.pdt_ideal_usages.value | default: blank -%}
{%- if pdt_ideal_usages == blank -%}
  {%- assign pdt_ideal_usages = section.settings.ideal_usages_content -%}
{%- endif -%}

{%- assign pdt_size_guide = product.metafields.custom.pdt_size_guide.value | default: blank -%}
{%- if pdt_size_guide == blank -%}
  {%- assign pdt_size_guide = section.settings.size_guide_content -%}
{%- endif -%}

{%- assign pdt_faq = product.metafields.custom.pdt_faq.value | default: blank -%}
{%- if pdt_faq == blank -%}
  {%- assign pdt_faq = section.settings.faq_content -%}
{%- endif -%}

{%- comment -%} Build tabs array from available content {%- endcomment -%}
{%- assign tabs = '' -%}
{%- if pdt_description != blank -%}{%- assign tabs = tabs | append: 'description,' -%}{%- endif -%}
{%- if pdt_specifications != blank -%}{%- assign tabs = tabs | append: 'specifications,' -%}{%- endif -%}
{%- if pdt_features != blank -%}{%- assign tabs = tabs | append: 'features,' -%}{%- endif -%}
{%- if pdt_how_to_use != blank -%}{%- assign tabs = tabs | append: 'how-to-use,' -%}{%- endif -%}
{%- if pdt_care != blank -%}{%- assign tabs = tabs | append: 'care-instructions,' -%}{%- endif -%}
{%- if pdt_materials != blank -%}{%- assign tabs = tabs | append: 'materials,' -%}{%- endif -%}
{%- if pdt_ideal_usages != blank -%}{%- assign tabs = tabs | append: 'ideal-usages,' -%}{%- endif -%}
{%- if pdt_size_guide != blank -%}{%- assign tabs = tabs | append: 'gauge-size-guide,' -%}{%- endif -%}
{%- if pdt_faq != blank -%}{%- assign tabs = tabs | append: 'faq,' -%}{%- endif -%}

{%- assign tabs_array = tabs | split: ',' -%}
{%- assign first_tab = tabs_array | first -%}

{%- assign tab_labels = 'description:Description,specifications:Specifications,features:Features,how-to-use:How to Use,care-instructions:Care Instructions,materials:Materials,ideal-usages:Ideal Usages,gauge-size-guide:Gauge Size Guide,faq:FAQ' | split: ',' -%}

{%- if tabs != '' -%}
<div class="pdt-container">
  <!-- Desktop Tabs -->
  <div class="pdt-desktop">
    <div class="pdt-tabs">
      <div class="pdt-tab-nav">
        <button class="pdt-arrow pdt-arrow-left" aria-label="Scroll left">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#222" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>
        <div class="pdt-tabs-scroll">
          <div class="pdt-tab-buttons">
            {%- for tab_id in tabs_array -%}
              {%- if tab_id != '' -%}
                {%- assign tab_label = '' -%}
                {%- for pair in tab_labels -%}
                  {%- assign pair_parts = pair | split: ':' -%}
                  {%- if pair_parts[0] == tab_id -%}
                    {%- assign tab_label = pair_parts[1] -%}
                    {%- break -%}
                  {%- endif -%}
                {%- endfor -%}
                <button class="pdt-tab-btn{% if tab_id == first_tab %} active{% endif %}" data-pdt-tab="{{ tab_id }}"><strong>{{ tab_label }}</strong></button>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
        <button class="pdt-arrow pdt-arrow-right" aria-label="Scroll right">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#222" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
      </div>

      {%- if pdt_description != blank -%}
        <div class="pdt-tab-content{% if first_tab == 'description' %} active{% endif %}" data-pdt-panel="description">{{ pdt_description }}</div>
      {%- endif -%}
      {%- if pdt_specifications != blank -%}
        <div class="pdt-tab-content{% if first_tab == 'specifications' %} active{% endif %}" data-pdt-panel="specifications">{{ pdt_specifications }}</div>
      {%- endif -%}
      {%- if pdt_features != blank -%}
        <div class="pdt-tab-content{% if first_tab == 'features' %} active{% endif %}" data-pdt-panel="features">{{ pdt_features }}</div>
      {%- endif -%}
      {%- if pdt_how_to_use != blank -%}
        <div class="pdt-tab-content{% if first_tab == 'how-to-use' %} active{% endif %}" data-pdt-panel="how-to-use">{{ pdt_how_to_use }}</div>
      {%- endif -%}
      {%- if pdt_care != blank -%}
        <div class="pdt-tab-content{% if first_tab == 'care-instructions' %} active{% endif %}" data-pdt-panel="care-instructions">{{ pdt_care }}</div>
      {%- endif -%}
      {%- if pdt_materials != blank -%}
        <div class="pdt-tab-content{% if first_tab == 'materials' %} active{% endif %}" data-pdt-panel="materials">{{ pdt_materials }}</div>
      {%- endif -%}
      {%- if pdt_ideal_usages != blank -%}
        <div class="pdt-tab-content{% if first_tab == 'ideal-usages' %} active{% endif %}" data-pdt-panel="ideal-usages">{{ pdt_ideal_usages }}</div>
      {%- endif -%}
      {%- if pdt_size_guide != blank -%}
        <div class="pdt-tab-content{% if first_tab == 'gauge-size-guide' %} active{% endif %}" data-pdt-panel="gauge-size-guide">{{ pdt_size_guide }}</div>
      {%- endif -%}
      {%- if pdt_faq != blank -%}
        <div class="pdt-tab-content{% if first_tab == 'faq' %} active{% endif %}" data-pdt-panel="faq">{{ pdt_faq }}</div>
      {%- endif -%}
    </div>
  </div>

  <!-- Mobile Accordion -->
  <div class="pdt-accordion">
    {%- for tab_id in tabs_array -%}
      {%- if tab_id != '' -%}
        {%- assign tab_label = '' -%}
        {%- for pair in tab_labels -%}
          {%- assign pair_parts = pair | split: ':' -%}
          {%- if pair_parts[0] == tab_id -%}
            {%- assign tab_label = pair_parts[1] -%}
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}

        <div class="pdt-acc-item">
          <button class="pdt-acc-header">{{ tab_label }} <span class="pdt-acc-icon"></span></button>
          <div class="pdt-acc-content">
            {%- case tab_id -%}
              {%- when 'description' -%}
                {{ pdt_description }}
              {%- when 'specifications' -%}
                {{ pdt_specifications }}
              {%- when 'features' -%}
                {{ pdt_features }}
              {%- when 'how-to-use' -%}
                {{ pdt_how_to_use }}
              {%- when 'care-instructions' -%}
                {{ pdt_care }}
              {%- when 'materials' -%}
                {{ pdt_materials }}
              {%- when 'ideal-usages' -%}
                {{ pdt_ideal_usages }}
              {%- when 'gauge-size-guide' -%}
                {{ pdt_size_guide }}
              {%- when 'faq' -%}
                {{ pdt_faq }}
            {%- endcase -%}
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>
{%- endif -%}

<script>
  (function(){
    const section = document.querySelector('.pdt-container');
    if (!section) return;

    // Desktop tabs
    section.querySelectorAll('.pdt-tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const tab = btn.getAttribute('data-pdt-tab');
        section.querySelectorAll('.pdt-tab-btn').forEach(b => b.classList.remove('active'));
        section.querySelectorAll('.pdt-tab-content').forEach(p => p.classList.remove('active'));
        btn.classList.add('active');
        const panel = section.querySelector('[data-pdt-panel="' + tab + '"]');
        if (panel) panel.classList.add('active');
      });
    });

    // Arrow scroll with opacity
    const scrollContainer = section.querySelector('.pdt-tabs-scroll');
    const leftArrow = section.querySelector('.pdt-arrow-left');
    const rightArrow = section.querySelector('.pdt-arrow-right');

    function updateArrows() {
      if (!scrollContainer || !leftArrow || !rightArrow) return;
      const { scrollLeft, scrollWidth, clientWidth } = scrollContainer;
      const atStart = scrollLeft <= 5;
      const atEnd = scrollLeft + clientWidth >= scrollWidth - 5;
      leftArrow.style.opacity = atStart ? '0.3' : '0.85';
      leftArrow.style.pointerEvents = atStart ? 'none' : 'auto';
      rightArrow.style.opacity = atEnd ? '0.3' : '0.85';
      rightArrow.style.pointerEvents = atEnd ? 'none' : 'auto';
    }

    if (leftArrow && scrollContainer) {
      leftArrow.addEventListener('click', () => { scrollContainer.scrollBy({ left: -200, behavior: 'smooth' }); });
    }
    if (rightArrow && scrollContainer) {
      rightArrow.addEventListener('click', () => { scrollContainer.scrollBy({ left: 200, behavior: 'smooth' }); });
    }
    if (scrollContainer) {
      scrollContainer.addEventListener('scroll', updateArrows);
      updateArrows();
    }

    // Mobile accordion
    section.querySelectorAll('.pdt-acc-header').forEach(header => {
      header.addEventListener('click', () => {
        const content = header.nextElementSibling;
        const isActive = header.classList.contains('active');
        section.querySelectorAll('.pdt-acc-header').forEach(h => h.classList.remove('active'));
        section.querySelectorAll('.pdt-acc-content').forEach(c => c.classList.remove('active'));
        if (!isActive) {
          header.classList.add('active');
          content.classList.add('active');
        }
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Product Desc Tabs",
  "settings": [
    {
      "type": "header",
      "content": "Dynamic Content (Metafields)",
      "info": "Content is auto-loaded from product metafields (namespace: custom). If a metafield is empty, falls back to manual HTML below."
    },
    {
      "type": "paragraph",
      "content": "Metafield keys: pdt_description, pdt_specifications, pdt_features, pdt_how_to_use, pdt_care_instructions, pdt_materials, pdt_ideal_usages, pdt_size_guide, pdt_faq"
    },
    {
      "type": "header",
      "content": "Manual HTML Fallback"
    },
    {
      "type": "html",
      "id": "description_content",
      "label": "Description",
      "info": "Leave blank to use product description. Metafield overrides this."
    },
    {
      "type": "html",
      "id": "specifications_content",
      "label": "Specifications",
      "info": "Paste HTML tables. Metafield: custom.pdt_specifications"
    },
    {
      "type": "html",
      "id": "features_content",
      "label": "Features",
      "info": "HTML lists. Metafield: custom.pdt_features"
    },
    {
      "type": "html",
      "id": "how_to_use_content",
      "label": "How to Use",
      "info": "HTML content. Metafield: custom.pdt_how_to_use"
    },
    {
      "type": "html",
      "id": "care_content",
      "label": "Care Instructions",
      "info": "HTML content. Metafield: custom.pdt_care_instructions"
    },
    {
      "type": "html",
      "id": "materials_content",
      "label": "Materials",
      "info": "HTML tables. Metafield: custom.pdt_materials"
    },
    {
      "type": "html",
      "id": "ideal_usages_content",
      "label": "Ideal Usages",
      "info": "HTML content. Metafield: custom.pdt_ideal_usages"
    },
    {
      "type": "html",
      "id": "size_guide_content",
      "label": "Gauge Size Guide",
      "info": "HTML tables. Metafield: custom.pdt_size_guide"
    },
    {
      "type": "html",
      "id": "faq_content",
      "label": "FAQ",
      "info": "FAQ HTML with details/summary. Metafield: custom.pdt_faq"
    }
  ],
  "presets": [
    {
      "name": "Product Desc Tabs"
    }
  ]
}
{% endschema %}
