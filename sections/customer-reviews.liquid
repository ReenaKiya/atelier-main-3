
<div class="customer-reviews-section page-width">
  {% if section.settings.heading != blank %}
    <h2 class="customer-reviews-heading">{{ section.settings.heading }}</h2>
  {% endif %}

  <div class="customer-reviews-carousel-wrapper"
       data-autoplay="{{ section.settings.autoplay }}"
       data-autoplay-speed="{{ section.settings.autoplay_speed }}">
    <div class="customer-reviews-carousel" id="reviews-carousel-{{ section.id }}">
      {% for block in section.blocks %}
        {% assign rating = block.settings.rating | default: 5 %}
        <article class="review-card" {{ block.shopify_attributes }}>
          <div class="review-card__top">
            <div class="review-card__stars">
              {% for i in (1..5) %}
                <svg class="star-icon {% if forloop.index0 < rating %}filled{% endif %}" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M31.547 12a.848.848 0 00-.677-.577l-9.427-1.376-4.224-8.532a.847.847 0 00-1.516 0l-4.218 8.534-9.427 1.355a.847.847 0 00-.467 1.467l6.823 6.664-1.612 9.375a.847.847 0 001.23.893l8.428-4.434 8.432 4.432a.847.847 0 001.229-.894l-1.615-9.373 6.822-6.665a.845.845 0 00.214-.869z"/>
                </svg>
              {% endfor %}
            </div>
            {% if block.settings.date != blank %}
              <span class="review-card__date">{{ block.settings.date }}</span>
            {% endif %}
          </div>

          <div class="review-card__author">
            {% if block.settings.author_image != blank %}
              <img src="{{ block.settings.author_image | image_url: width: 60 }}" alt="{{ block.settings.author_name | escape }}" class="review-card__avatar" loading="lazy" width="28" height="28">
            {% else %}
              <span class="review-card__avatar review-card__avatar--placeholder" aria-hidden="true">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="1.5">
                  <circle cx="12" cy="9" r="3.25"/>
                  <path d="M4.5 19.5c1-3 4.5-4.5 7.5-4.5s6.5 1.5 7.5 4.5" stroke-linecap="round"/>
                </svg>
              </span>
            {% endif %}
            <span class="review-card__name">{{ block.settings.author_name }}</span>
            {% case block.settings.badge_type %}
              {% when 'verified' %}
                <span class="review-card__badge">Verified</span>
              {% when 'verified_by_shop' %}
                <span class="review-card__badge review-card__badge--shop">Verified by <strong>shop</strong></span>
            {% endcase %}
          </div>

          {% if block.settings.headline != blank %}
            <h3 class="review-card__headline">{{ block.settings.headline }}</h3>
          {% endif %}

          {% if block.settings.body_text != blank %}
            <p class="review-card__body">{{ block.settings.body_text }}</p>
          {% endif %}

          <div class="review-card__footer">
            {% if block.settings.full_review_url != blank %}
              <a href="{{ block.settings.full_review_url }}" class="review-card__full-review">Full Review</a>
            {% else %}
              <span class="review-card__full-review-spacer"></span>
            {% endif %}
            <div class="review-card__helpful">
              <span class="review-card__thumb">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M7 22V11l5-7 1 1c.6.6.7 1.5.5 2.3L13 10h6c1 0 1.8.9 1.7 2l-1.4 7c-.2 1-1 1.7-2 1.7H7zM3 22h4V11H3z"/>
                </svg>
                <span>{{ block.settings.helpful_yes | default: 0 }}</span>
              </span>
              <span class="review-card__thumb">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M17 2v11l-5 7-1-1c-.6-.6-.7-1.5-.5-2.3L11 13H5c-1 0-1.8-.9-1.7-2l1.4-7c.2-1 1-1.7 2-1.7H17zM21 2h-4v11h4z"/>
                </svg>
                <span>{{ block.settings.helpful_no | default: 0 }}</span>
              </span>
            </div>
          </div>
        </article>
      {% endfor %}
    </div>

    <button class="carousel-nav-btn prev" aria-label="Previous reviews" type="button" onclick="moveCarousel('{{ section.id }}', -1)">
      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
    <button class="carousel-nav-btn next" aria-label="Next reviews" type="button" onclick="moveCarousel('{{ section.id }}', 1)">
      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>
</div>

<style>
.customer-reviews-section {
  padding: 60px 20px;
  text-align: center;
  background: #fff;
}

.customer-reviews-heading {
  color: #111;
  font-size: 1.875rem;
  font-weight: 700;
  margin-bottom: 32px;
}

.customer-reviews-carousel-wrapper {
  position: relative;
  max-width: 1200px;
  margin: 0 auto;
}

.customer-reviews-carousel {
  display: flex;
  gap: 16px;
  overflow-x: auto;
  scroll-behavior: smooth;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  padding: 4px 0;
}

.customer-reviews-carousel::-webkit-scrollbar {
  display: none;
}

.review-card {
  flex: 0 0 calc(25% - 12px);
  min-width: 270px;
  display: flex;
  flex-direction: column;
  padding: 22px 22px 18px;
  background: #fff;
  border: 1px solid #e5e5e5;
  text-align: left;
  scroll-snap-align: start;
  min-height: 320px;
  box-sizing: border-box;
}

.review-card__top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14px;
}

.review-card__stars {
  display: flex;
  gap: 2px;
}

.review-card__stars .star-icon {
  width: 16px;
  height: 16px;
  fill: #e5e5e5;
}

.review-card__stars .star-icon.filled {
  fill: #DA1E37;
}

.review-card__date {
  font-size: 13px;
  color: #999;
}

.review-card__author {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 12px;
  flex-wrap: wrap;
}

.review-card__avatar {
  width: 28px;
  height: 28px;
  border-radius: 3px;
  object-fit: cover;
  flex-shrink: 0;
}

.review-card__avatar--placeholder {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #e8e8e8;
  color: #999;
}

.review-card__avatar--placeholder svg {
  width: 18px;
  height: 18px;
}

.review-card__name {
  font-size: 14px;
  font-weight: 600;
  color: #111;
}

.review-card__badge {
  display: inline-block;
  background: #111;
  color: #fff;
  font-size: 11px;
  font-weight: 500;
  padding: 3px 7px;
  border-radius: 2px;
  letter-spacing: 0.02em;
}

.review-card__badge--shop strong {
  font-weight: 700;
  margin-left: 1px;
}

.review-card__headline {
  font-size: 0.95rem;
  font-weight: 700;
  color: #111;
  margin: 0 0 8px;
  line-height: 1.3;
}

.review-card__body {
  font-size: 0.875rem;
  color: #333;
  line-height: 1.5;
  margin: 0 0 16px;
}

.review-card__footer {
  margin-top: auto;
  padding-top: 12px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12px;
}

.review-card__full-review {
  font-size: 13px;
  color: #111;
  text-decoration: underline;
}

.review-card__full-review:hover {
  text-decoration: none;
}

.review-card__full-review-spacer {
  display: inline-block;
}

.review-card__helpful {
  display: flex;
  gap: 14px;
}

.review-card__thumb {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 13px;
  color: #888;
}

.review-card__thumb svg {
  width: 16px;
  height: 16px;
}

.carousel-nav-btn {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  background: transparent;
  border: none;
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  z-index: 10;
  color: #111;
  padding: 0;
}

.carousel-nav-btn:hover {
  color: #444;
}

.carousel-nav-btn.prev {
  left: -32px;
}

.carousel-nav-btn.next {
  right: -32px;
}

.carousel-nav-btn svg {
  width: 22px;
  height: 22px;
}

.carousel-nav-btn:disabled {
  opacity: 0.25;
  cursor: not-allowed;
}

@media screen and (max-width: 990px) {
  .review-card {
    flex: 0 0 calc(50% - 8px);
  }
  .carousel-nav-btn.prev { left: 4px; }
  .carousel-nav-btn.next { right: 4px; }
}

@media screen and (max-width: 749px) {
  .customer-reviews-section {
    padding: 40px 15px;
  }
  .customer-reviews-heading {
    font-size: 1.5rem;
    margin-bottom: 20px;
  }
  .review-card {
    flex: 0 0 85%;
    min-width: 260px;
  }
}
</style>

<script>
let carouselPositions = window.carouselPositions || {};
let autoplayIntervals = window.autoplayIntervals || {};
window.carouselPositions = carouselPositions;
window.autoplayIntervals = autoplayIntervals;

function moveCarousel(sectionId, direction) {
  const carousel = document.getElementById('reviews-carousel-' + sectionId);
  if (!carousel) return;
  const cards = carousel.querySelectorAll('.review-card');
  const cardWidth = cards[0]?.offsetWidth || 0;
  const gap = 16;
  carousel.scrollBy({ left: (cardWidth + gap) * direction, behavior: 'smooth' });
  updateCarouselButtons(sectionId);
}

function updateCarouselButtons(sectionId) {
  const carousel = document.getElementById('reviews-carousel-' + sectionId);
  if (!carousel) return;
  const wrapper = carousel.closest('.customer-reviews-carousel-wrapper');
  const prevBtn = wrapper?.querySelector('.prev');
  const nextBtn = wrapper?.querySelector('.next');
  if (prevBtn && nextBtn) {
    const isAtStart = carousel.scrollLeft <= 0;
    const isAtEnd = carousel.scrollLeft >= carousel.scrollWidth - carousel.clientWidth - 10;
    prevBtn.disabled = isAtStart;
    nextBtn.disabled = isAtEnd;
  }
}

function startAutoplay(sectionId, speed) {
  const carousel = document.getElementById('reviews-carousel-' + sectionId);
  if (!carousel) return;
  if (autoplayIntervals[sectionId]) clearInterval(autoplayIntervals[sectionId]);
  autoplayIntervals[sectionId] = setInterval(() => {
    const cards = carousel.querySelectorAll('.review-card');
    if (!cards.length) return;
    const cardWidth = cards[0].offsetWidth;
    const gap = 16;
    const maxScroll = carousel.scrollWidth - carousel.clientWidth;
    if (carousel.scrollLeft >= maxScroll - 10) {
      carousel.scrollTo({ left: 0, behavior: 'smooth' });
    } else {
      carousel.scrollBy({ left: cardWidth + gap, behavior: 'smooth' });
    }
    updateCarouselButtons(sectionId);
  }, speed);
}

function stopAutoplay(sectionId) {
  if (autoplayIntervals[sectionId]) {
    clearInterval(autoplayIntervals[sectionId]);
    autoplayIntervals[sectionId] = null;
  }
}

document.addEventListener('DOMContentLoaded', function() {
  document.querySelectorAll('.customer-reviews-carousel').forEach(carousel => {
    const sectionId = carousel.id.replace('reviews-carousel-', '');
    const wrapper = carousel.closest('.customer-reviews-carousel-wrapper');
    const autoplayEnabled = wrapper.dataset.autoplay === 'true';
    const autoplaySpeed = parseInt(wrapper.dataset.autoplaySpeed) || 4000;

    updateCarouselButtons(sectionId);
    carousel.addEventListener('scroll', () => updateCarouselButtons(sectionId));

    if (autoplayEnabled) {
      startAutoplay(sectionId, autoplaySpeed);
      wrapper.addEventListener('mouseenter', () => stopAutoplay(sectionId));
      wrapper.addEventListener('mouseleave', () => startAutoplay(sectionId, autoplaySpeed));
    }
  });
});
</script>

{% schema %}
{
  "name": "Customer Reviews",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Customer Reviews"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable Auto Slide",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Auto Slide Speed",
      "min": 2000,
      "max": 8000,
      "step": 500,
      "default": 4000,
      "unit": "ms"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Star Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "text",
          "id": "date",
          "label": "Review Date",
          "info": "e.g. 19/08/2025",
          "default": "01/01/2025"
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Author Name",
          "default": "Customer"
        },
        {
          "type": "image_picker",
          "id": "author_image",
          "label": "Author Image (optional)"
        },
        {
          "type": "select",
          "id": "badge_type",
          "label": "Badge",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "verified", "label": "Verified" },
            { "value": "verified_by_shop", "label": "Verified by Shop" }
          ],
          "default": "verified"
        },
        {
          "type": "text",
          "id": "headline",
          "label": "Review Headline (optional)"
        },
        {
          "type": "textarea",
          "id": "body_text",
          "label": "Review Text"
        },
        {
          "type": "url",
          "id": "full_review_url",
          "label": "Full Review URL (optional)"
        },
        {
          "type": "number",
          "id": "helpful_yes",
          "label": "Thumbs Up Count",
          "default": 0
        },
        {
          "type": "number",
          "id": "helpful_no",
          "label": "Thumbs Down Count",
          "default": 0
        }
      ]
    }
  ],
  "presets": [
