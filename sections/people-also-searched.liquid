{%- liquid
  assign bg_color = section.settings.background_color
  assign title_color = section.settings.title_color
  assign title_size = section.settings.title_size
  assign pill_bg = section.settings.pill_background
  assign pill_color = section.settings.pill_color
  assign pill_size = section.settings.pill_font_size
  assign pill_radius = section.settings.pill_radius
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign hover_bg = section.settings.hover_background
  assign hover_color = section.settings.hover_color

  comment
    Determine the "base term" the pills are about.
    - On product pages: use product.type (e.g. "Barbells", "Nose Stud")
    - On collection pages: use collection.title (e.g. "Flat Backs")
    - Fallback: section.settings.fallback_term
  endcomment

  assign base_term = ''
  if template contains 'product' and product != blank
    if product.type != blank
      assign base_term = product.type
    else
      assign base_term = product.title
    endif
  elsif template contains 'collection' and collection != blank
    assign base_term = collection.title
  endif

  if base_term == blank
    assign base_term = section.settings.fallback_term
  endif

  comment
    Build the dynamic pill list.

    Strategy 1 (preferred): metafield override.
      - product.metafields.custom.people_also_searched  (type: list.single_line_text_field)
      - collection.metafields.custom.people_also_searched (type: list.single_line_text_field)
      Each item is plain text — link auto-built to /search?q={item}

    Strategy 2 (auto): combine each "modifier" from section settings with base_term.
      e.g. modifiers "14K, 9K, Sterling Silver, Surgical Steel, Titanium, UV"
           base_term "Barbells"
      => "14K Barbells", "9K Barbells", "Sterling Silver Barbells", ...

      Plus optional suffix variants ("External", "Internal") rendered as
      "{base_term} External", "{base_term} Internal".
  endcomment

  assign meta_terms = ''
  if template contains 'product' and product.metafields.custom.people_also_searched != blank
    assign meta_terms = product.metafields.custom.people_also_searched.value
  elsif template contains 'collection' and collection.metafields.custom.people_also_searched != blank
    assign meta_terms = collection.metafields.custom.people_also_searched.value
  endif
-%}

{%- if base_term != blank or meta_terms != blank -%}
  <div
    class="related-searches-pills"
    style="
      background-color: {{ bg_color }};
      padding-top: {{ padding_top }}px;
      padding-bottom: {{ padding_bottom }}px;
      --pill-hover-bg: {{ hover_bg }};
      --pill-hover-color: {{ hover_color }};
    "
  >
    <div class="related-searches-pills__container page-width">
      {%- if section.settings.title != blank -%}
        <h3
          class="related-searches-pills__title"
          style="
            color: {{ title_color }};
            font-size: {{ title_size }}px;
          "
        >
          {{ section.settings.title }}
        </h3>
      {%- endif -%}

      <div class="related-searches-pills__tags">
        {%- if meta_terms != blank -%}
          {%- comment -%} Metafield-driven pills (manual override per product/collection) {%- endcomment -%}
          {%- for term in meta_terms -%}
            {%- assign clean = term | strip -%}
            {%- if clean != blank -%}
              <a
                href="/search?q={{ clean | url_encode }}"
                class="related-searches-pills__tag"
                style="
                  background-color: {{ pill_bg }};
                  color: {{ pill_color }};
                  font-size: {{ pill_size }}px;
                  border-radius: {{ pill_radius }}px;
                "
              >
                {{ clean }}
              </a>
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          {%- comment -%} Auto-generated pills from modifiers + base_term {%- endcomment -%}
          {%- assign modifiers = section.settings.modifiers | split: ',' -%}
          {%- for modifier in modifiers -%}
            {%- assign mod = modifier | strip -%}
            {%- if mod != blank -%}
              {%- assign label = mod | append: ' ' | append: base_term -%}
              <a
                href="/search?q={{ label | url_encode }}"
                class="related-searches-pills__tag"
                style="
                  background-color: {{ pill_bg }};
                  color: {{ pill_color }};
                  font-size: {{ pill_size }}px;
                  border-radius: {{ pill_radius }}px;
                "
              >
                {{ label }}
              </a>
            {%- endif -%}
          {%- endfor -%}

          {%- assign suffixes = section.settings.suffixes | split: ',' -%}
          {%- for suffix in suffixes -%}
            {%- assign suf = suffix | strip -%}
            {%- if suf != blank -%}
              {%- assign label = base_term | append: ' ' | append: suf -%}
              <a
                href="/search?q={{ label | url_encode }}"
                class="related-searches-pills__tag"
                style="
                  background-color: {{ pill_bg }};
                  color: {{ pill_color }};
                  font-size: {{ pill_size }}px;
                  border-radius: {{ pill_radius }}px;
                "
              >
                {{ label }}
              </a>
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
{%- endif -%}

{% stylesheet %}
  .related-searches-pills__container {
    max-width: 1200px;
    margin: 0 auto;
    padding-left: 20px;
    padding-right: 20px;
  }

  .related-searches-pills__title {
    font-weight: 600;
    margin: 0 0 18px;
    line-height: 1.3;
  }

  .related-searches-pills__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .related-searches-pills__tag {
    display: inline-block;
    padding: 10px 22px;
    text-decoration: none;
    line-height: 1.2;
    transition: background-color 0.2s ease, color 0.2s ease;
    white-space: nowrap;
  }

  .related-searches-pills__tag:hover {
    background-color: var(--pill-hover-bg, #c41e3a) !important;
    color: var(--pill-hover-color, #ffffff) !important;
  }

  @media screen and (max-width: 749px) {
    .related-searches-pills__tag {
      padding: 8px 16px;
      font-size: 13px !important;
    }

    .related-searches-pills__title {
      font-size: 18px !important;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "People Also Searched",
  "tag": "section",
  "class": "section-related-searches",
  "settings": [
    {
      "type": "paragraph",
      "content": "Pills are generated automatically from the current product type (on product pages) or collection title (on collection pages). To override per item, set a metafield: custom.people_also_searched (list.single_line_text_field)."
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "People Also Searched For"
    },
    {
      "type": "text",
      "id": "fallback_term",
      "label": "Fallback term",
      "info": "Used when product type / collection title are empty.",
      "default": "Jewellery"
    },
    {
      "type": "header",
      "content": "Auto-generated Pills"
    },
    {
      "type": "textarea",
      "id": "modifiers",
      "label": "Material modifiers (comma separated)",
      "info": "Each modifier is combined with the base term. e.g. '14K' + 'Barbells' = '14K Barbells'.",
      "default": "14K, 9K, Sterling Silver, Surgical Steel, Surgical Steel/UV, Titanium, UV"
    },
    {
      "type": "textarea",
      "id": "suffixes",
      "label": "Suffix variants (comma separated)",
      "info": "Each suffix is appended after the base term. e.g. 'Barbells' + 'External' = 'Barbells External'.",
      "default": "External, Internal"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "pill_background",
      "label": "Pill background color",
      "default": "#efefef"
    },
    {
      "type": "color",
      "id": "pill_color",
      "label": "Pill text color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "hover_background",
      "label": "Pill hover background",
      "default": "#c41e3a"
    },
    {
      "type": "color",
      "id": "hover_color",
      "label": "Pill hover text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Typography & Sizing"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title font size",
      "min": 14,
      "max": 36,
      "step": 1,
      "unit": "px",
      "default": 22
    },
    {
      "type": "range",
      "id": "pill_font_size",
      "label": "Pill font size",
      "min": 11,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "pill_radius",
      "label": "Pill corner radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 30
    }
  ],
  "presets": [
    {
      "name": "People Also Searched",
      "category": "Custom"
    }
  ],
  "enabled_on": {
    "templates": ["product", "collection"]
  }
}
{% endschema %}
