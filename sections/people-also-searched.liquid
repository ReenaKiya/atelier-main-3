{%- liquid
  assign bg_color = section.settings.background_color
  assign title_color = section.settings.title_color
  assign title_size = section.settings.title_size
  assign pill_bg = section.settings.pill_background
  assign pill_color = section.settings.pill_color
  assign pill_size = section.settings.pill_font_size
  assign pill_radius = section.settings.pill_radius
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign hover_bg = section.settings.hover_background
  assign hover_color = section.settings.hover_color
  assign max_pills = section.settings.max_products | default: 10
  assign truncate_length = section.settings.truncate_length | default: 40

  assign has_products = false

  comment
    Collect products to display as pills.
    - On collection pages: show products from the current collection
    - On product pages: show other products from the product's first collection (excluding current product)
  endcomment
-%}

{%- comment -%} Determine which products to show {%- endcomment -%}
{%- if template contains 'collection' and collection != blank and collection.products_count > 0 -%}
  {%- assign pill_products = collection.products -%}
  {%- assign has_products = true -%}
{%- elsif template contains 'product' and product != blank -%}
  {%- for col in product.collections limit: 1 -%}
    {%- if col.products_count > 0 -%}
      {%- assign pill_products = col.products -%}
      {%- assign has_products = true -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- if has_products -%}
  <div
    class="related-searches-pills"
    style="
      background-color: {{ bg_color }};
      padding-top: {{ padding_top }}px;
      padding-bottom: {{ padding_bottom }}px;
      --pill-hover-bg: {{ hover_bg }};
      --pill-hover-color: {{ hover_color }};
    "
  >
    <div class="related-searches-pills__container page-width">
      {%- if section.settings.title != blank -%}
        <h3
          class="related-searches-pills__title"
          style="
            color: {{ title_color }};
            font-size: {{ title_size }}px;
          "
        >
          {{ section.settings.title }}
        </h3>
      {%- endif -%}

      <div class="related-searches-pills__tags">
        {%- assign pill_count = 0 -%}
        {%- for p in pill_products -%}
          {%- if template contains 'product' and p.id == product.id -%}
            {%- continue -%}
          {%- endif -%}
          {%- if pill_count >= max_pills -%}
            {%- break -%}
          {%- endif -%}
          <a
            href="{{ p.url }}"
            class="related-searches-pills__tag"
            style="
              background-color: {{ pill_bg }};
              color: {{ pill_color }};
              font-size: {{ pill_size }}px;
              border-radius: {{ pill_radius }}px;
            "
          >
            {{ p.title | truncate: truncate_length }}
          </a>
          {%- assign pill_count = pill_count | plus: 1 -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
{%- endif -%}

{% stylesheet %}
  .related-searches-pills__container {
    max-width: 1200px;
    margin: 0 auto;
    padding-left: 20px;
    padding-right: 20px;
  }

  .related-searches-pills__title {
    font-weight: 600;
    margin: 0 0 18px;
    line-height: 1.3;
  }

  .related-searches-pills__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .related-searches-pills__tag {
    display: inline-block;
    padding: 10px 22px;
    text-decoration: none;
    line-height: 1.2;
    transition: background-color 0.2s ease, color 0.2s ease;
    white-space: nowrap;
  }

  .related-searches-pills__tag:hover {
    background-color: var(--pill-hover-bg, #c41e3a) !important;
    color: var(--pill-hover-color, #ffffff) !important;
  }

  @media screen and (max-width: 749px) {
    .related-searches-pills__tag {
      padding: 8px 16px;
      font-size: 13px !important;
    }

    .related-searches-pills__title {
      font-size: 18px !important;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "People Also Searched",
  "tag": "section",
  "class": "section-related-searches",
  "settings": [
    {
      "type": "paragraph",
      "content": "Pills link to actual product pages from the current collection (on collection pages) or related products (on product pages)."
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "People Also Searched For"
    },
    {
      "type": "header",
      "content": "Product Pills"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Max products to show",
      "min": 3,
      "max": 20,
      "step": 1,
      "default": 10
    },
    {
      "type": "range",
      "id": "truncate_length",
      "label": "Title truncate length",
      "info": "Max characters for product title in pill.",
      "min": 15,
      "max": 80,
      "step": 5,
      "default": 40
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "pill_background",
      "label": "Pill background color",
      "default": "#efefef"
    },
    {
      "type": "color",
      "id": "pill_color",
      "label": "Pill text color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "hover_background",
      "label": "Pill hover background",
      "default": "#c41e3a"
    },
    {
      "type": "color",
      "id": "hover_color",
      "label": "Pill hover text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Typography & Sizing"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title font size",
      "min": 14,
      "max": 36,
      "step": 1,
      "unit": "px",
      "default": 22
    },
    {
      "type": "range",
      "id": "pill_font_size",
      "label": "Pill font size",
      "min": 11,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "pill_radius",
      "label": "Pill corner radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 30
    }
  ],
  "presets": [
    {
      "name": "People Also Searched",
      "category": "Custom"
    }
  ],
  "enabled_on": {
    "templates": ["product", "collection"]
  }
}
{% endschema %}
