    border-bottom: 1px solid #eee;
  }

  .site-header[data-nav-header-sticky] {
    position: sticky;
    top: 0;
  }

  .site-navigation-wrapper {
    width: 100%;
    padding: 0 20px;
  }

  .site-navigation-wrapper.site-header--full-width {
    max-width: 100%;
  }

  .site-navigation {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Nav menu base */
  .navmenu {
    list-style: none;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 0;
  }

  .navmenu-item {
    position: relative;
  }

  .navmenu-item-parent {
    position: static;
  }

  .navmenu-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 16px 18px;
    color: #333;
    text-decoration: none;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    white-space: nowrap;
    transition: color 0.2s ease;
    cursor: pointer;
    background: none;
    border: none;
  }

  .navmenu-link:hover {
    color: #da1e37;
  }

  /* Summary element reset */
  summary.navmenu-link {
    list-style: none;
  }

  summary.navmenu-link::-webkit-details-marker {
    display: none;
  }

  summary.navmenu-link::marker {
    display: none;
    content: '';
  }

  /* Details reset */
  details[data-navmenu-details] {
    position: static;
  }

  /* Chevron icon */
  .navmenu-icon {
    display: inline-flex;
    align-items: center;
    margin-left: 2px;
  }

  .navmenu-icon svg {
    width: 8px;
    height: 6px;
    transition: transform 0.2s ease;
  }

  details[open] > summary .navmenu-icon svg {
    transform: rotate(180deg);
  }

  /* Mega menu positioning */
  .navmenu-meganav {
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    z-index: 9999;
  }

  /* Mobile: hide mega menus and show simple layout */
  @media screen and (max-width: 1024px) {
    .navmenu-meganav--desktop {
      display: none !important;
    }

    .site-navigation {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .navmenu-link {
      padding: 12px 14px;
      font-size: 12px;
    }
  }

  @media screen and (max-width: 749px) {
    .navmenu {
      flex-wrap: nowrap;
      overflow-x: auto;
    }

    .navmenu-link {
      padding: 10px 10px;
      font-size: 11px;
    }
  }

  /* Header height variable for page offset */
  body {
    --header-height: 0px;
    --header-group-height: var(--header-height);
  }

  body:has(> #header-group > header) {
    --header-height: 50px;
  }

  body:has(> #header-group:empty) {
    --header-group-height: 0px;
  }
{% endstylesheet %}

