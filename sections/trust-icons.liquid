{%- assign section_scope = 'trust-icons--' | append: section.id -%}

{% style %}
  .{{ section_scope }} {
    --trust-icons-gap: {{ section.settings.gap }}px;
    --trust-icons-icon-color: {{ section.settings.icon_color }};
    --trust-icons-text-size: {{ section.settings.text_size }}px;
    --trust-icons-icon-margin: {{ section.settings.icon_margin_bottom }}px;
    --trust-icons-border-color: {{ section.settings.border_color }};
  }

  .{{ section_scope }} .trust-icons__wrap {
    {% if section.settings.show_top_border %}
      border-top: 1px solid var(--trust-icons-border-color);
    {% endif %}
    {% if section.settings.show_bottom_border %}
      border-bottom: 1px solid var(--trust-icons-border-color);
    {% endif %}
  }

  .{{ section_scope }} .trust-icons__marquee {
    width: 100%;
  }

  .{{ section_scope }} .trust-icons__list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: var(--trust-icons-gap);
    align-items: center;
    justify-items: center;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .{{ section_scope }} .trust-icons__item {
    width: 100%;
    display: flex;
    justify-content: center;
    transition: transform 0.3s ease;
  }

  .{{ section_scope }} .trust-icons__item--clone {
    display: none;
  }

  .{{ section_scope }} .trust-icons__item svg {
    color: #db1e37;
    fill: currentColor;
  }

  .{{ section_scope }} .trust-icons__item .trust-icons__text {
    font-size: 0.8125rem;
    font-weight: 300;
  }

  .{{ section_scope }} .trust-icons__item:hover {
    transform: translateY(-4px);
  }

  .{{ section_scope }} .trust-icons__link {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0;
    text-decoration: none;
    color: inherit;
  }

  .{{ section_scope }} .trust-icons__icon-wrap {
    color: var(--trust-icons-icon-color);
    line-height: 0;
    margin-bottom: var(--trust-icons-icon-margin);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .{{ section_scope }} .trust-icons__icon {
    display: block;
  }

  .{{ section_scope }} .trust-icons__text {
    font-size: var(--trust-icons-text-size);
    line-height: 1.3;
    letter-spacing: 0;
    font-weight: 400;
  }

  @media screen and (max-width: 749px) {
    .{{ section_scope }} .trust-icons__marquee {
      overflow: hidden;
      -webkit-mask-image: linear-gradient(90deg, transparent 0, #000 8%, #000 92%, transparent 100%);
              mask-image: linear-gradient(90deg, transparent 0, #000 8%, #000 92%, transparent 100%);
    }

    .{{ section_scope }} .trust-icons__list {
      display: flex;
      flex-wrap: nowrap;
      width: max-content;
      gap: 0;
      animation: trust-icons-scroll-{{ section.id }} 25s linear infinite;
    }

    .{{ section_scope }} .trust-icons__marquee:hover .trust-icons__list {
      animation-play-state: paused;
    }

    .{{ section_scope }} .trust-icons__item {
      flex: 0 0 auto;
      width: auto;
      padding-inline: calc(var(--trust-icons-gap) * 0.75 / 2);
    }

    .{{ section_scope }} .trust-icons__item--clone {
      display: flex;
    }
  }

  @keyframes trust-icons-scroll-{{ section.id }} {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .{{ section_scope }} .trust-icons__list {
      animation: none;
    }
  }
{% endstyle %}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} spacing-style color-{{ section.settings.color_scheme }} {{ section_scope }}"
  style="{% render 'spacing-padding', settings: section.settings %}"
>
  <div class="trust-icons__wrap">
    <div class="trust-icons__marquee">
      <ul class="trust-icons__list" role="list">
        {%- for block in section.blocks -%}
          <li class="trust-icons__item" {{ block.shopify_attributes }}>
            {%- if block.settings.link != blank -%}
              <a class="trust-icons__link" href="{{ block.settings.link }}">
            {%- else -%}
              <div class="trust-icons__link">
            {%- endif -%}

              <div class="trust-icons__icon-wrap">
                {%- render 'icon-or-image',
                  icon: block.settings.icon,
                  image_upload: block.settings.image_upload,
                  width: block.settings.icon_size,
                  class_name: 'trust-icons__icon'
                -%}
              </div>

              {%- if block.settings.text != blank -%}
                <div class="trust-icons__text">{{ block.settings.text | escape }}</div>
              {%- endif -%}

            {%- if block.settings.link != blank -%}
              </a>
            {%- else -%}
              </div>
            {%- endif -%}
          </li>
        {%- endfor -%}

        {%- comment -%} Duplicate set for seamless mobile marquee loop {%- endcomment -%}
        {%- for block in section.blocks -%}
          <li class="trust-icons__item trust-icons__item--clone" aria-hidden="true">
            <div class="trust-icons__link">
              <div class="trust-icons__icon-wrap">
                {%- render 'icon-or-image',
                  icon: block.settings.icon,
                  image_upload: block.settings.image_upload,
                  width: block.settings.icon_size,
                  class_name: 'trust-icons__icon'
                -%}
              </div>
              {%- if block.settings.text != blank -%}
                <div class="trust-icons__text">{{ block.settings.text | escape }}</div>
              {%- endif -%}
            </div>
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Trust icons",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#b6465a"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 10,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "icon_margin_bottom",
      "label": "Space between icon and text",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between items",
      "min": 0,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "checkbox",
      "id": "show_top_border",
      "label": "Show top border",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_bottom_border",
      "label": "Show bottom border",
      "default": false
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "alpha": true,
      "default": "#00000014"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "Left padding",
      "min": 0,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "Right padding",
      "min": 0,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon (used if no image is uploaded)",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "truck", "label": "Truck" },
            { "value": "return", "label": "Return" },
            { "value": "box", "label": "Box" },
            { "value": "bottle", "label": "Bottle" },
            { "value": "star", "label": "Star" },
            { "value": "check_box", "label": "Check box" },
            { "value": "heart", "label": "Heart" },
            { "value": "eye", "label": "Eye" },
            { "value": "stopwatch", "label": "Stopwatch" }
          ],
          "default": "truck"
        },
        {
          "type": "image_picker",
          "id": "image_upload",
          "label": "Icon image (optional)"
        },
        {
          "type": "range",
          "id": "icon_size",
          "label": "Icon size",
          "min": 16,
          "max": 80,
          "step": 1,
          "unit": "px",
          "default": 44
        },
        {
          "type": "text",
          "id": "text",
          "label": "Label",
          "default": "Free shipping"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Trust icons",
      "category": "Layout",
      "blocks": [
        { "type": "badge", "settings": { "icon": "truck", "text": "Free shipping" } },
        { "type": "badge", "settings": { "icon": "bottle", "text": "Piercing Aftercare" } },
        { "type": "badge", "settings": { "icon": "return", "text": "30-days returns" } },
        { "type": "badge", "settings": { "icon": "star", "text": "4.8/5 Reviews" } },
        { "type": "badge", "settings": { "icon": "check_box", "text": "Premium Quality" } }
      ]
    }
  ]
}
{% endschema %}

