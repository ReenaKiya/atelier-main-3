<div class="gift-banner" style="
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
">
  <div class="gift-banner__container">
    <div class="gift-banner__content">
      <h2 class="gift-banner__heading">{{ section.settings.heading }}</h2>
      <p class="gift-banner__subheading">{{ section.settings.subheading }}</p>
      <p class="gift-banner__description">{{ section.settings.description }}</p>
      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link }}" class="gift-banner__button">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>
    <div class="gift-banner__images">
      <div class="gift-banner__image-wrapper">
        {% if section.settings.image_1 != blank %}
          <img
            src="{{ section.settings.image_1 | image_url: width: 800 }}"
            alt="{{ section.settings.image_1.alt | escape }}"
            loading="lazy"
            width="{{ section.settings.image_1.width }}"
            height="{{ section.settings.image_1.height }}"
          >
        {% else %}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </div>
      <div class="gift-banner__image-wrapper">
        {% if section.settings.image_2 != blank %}
          <img
            src="{{ section.settings.image_2 | image_url: width: 800 }}"
            alt="{{ section.settings.image_2.alt | escape }}"
            loading="lazy"
            width="{{ section.settings.image_2.width }}"
            height="{{ section.settings.image_2.height }}"
          >
        {% else %}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .gift-banner {
    width: 100%;
    background-color: #fff;
  }

  .gift-banner__container {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 30px;
    padding: 0 20px;
  }

  @media screen and (min-width: 750px) {
    .gift-banner__container {
      flex-direction: row;
      align-items: center;
      gap: 40px;
    }
  }

  .gift-banner__content {
    flex: 1;
    text-align: center;
    padding: 30px 20px;
  }

  .gift-banner__heading {
    font-family: inherit;
    font-size: 28px;
    font-weight: 400;
    font-style: italic;
    line-height: 1.3;
    margin: 0 0 20px;
    color: #000;
  }

  @media screen and (min-width: 750px) {
    .gift-banner__heading {
      font-size: 36px;
    }
  }

  .gift-banner__subheading {
    font-size: 16px;
    font-weight: 700;
    margin: 0 0 10px;
    color: #000;
  }

  .gift-banner__description {
    font-size: 14px;
    font-weight: 400;
    line-height: 1.6;
    margin: 0 0 25px;
    color: #333;
  }

  @media screen and (min-width: 750px) {
    .gift-banner__description {
      font-size: 15px;
    }
  }

  .gift-banner__button {
    display: inline-block;
    padding: 12px 35px;
    background-color: #000;
    color: #fff;
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.5px;
    border: 1px solid #000;
    transition: background-color 0.3s, color 0.3s;
  }

  .gift-banner__button:hover {
    background-color: #fff;
    color: #000;
  }

  .gift-banner__images {
    flex: 1.2;
    display: flex;
    gap: 10px;
  }

  .gift-banner__image-wrapper {
    flex: 1;
    overflow: hidden;
  }

  .gift-banner__image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .gift-banner__image-wrapper .placeholder-svg {
    width: 100%;
    height: 300px;
    background: #f0f0f0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Gift Banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Piercing Jewellery Gifts for Every Occasion"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Jewellery That Loves Their Skin"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Give the gift of comfort with our premium selection of Solid Gold, Sterling Silver, Implant-Grade Titanium and Surgical Steel"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link",
      "default": "/pages/all-body-jewellery"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image 1"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Gift Banner"
    }
  ]
}
{% endschema %}
