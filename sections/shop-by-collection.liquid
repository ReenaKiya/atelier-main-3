}
.sbc-qs__thumbs {
  display: flex;
  gap: 8px;
  margin-top: 12px;
  flex-wrap: wrap;
  justify-content: center;
}
.sbc-qs__thumb {
  width: 60px;
  height: 60px;
  object-fit: contain;
  border: 2px solid transparent;
  border-radius: 4px;
  cursor: pointer;
  transition: border-color 0.2s;
}
.sbc-qs__thumb:hover,
.sbc-qs__thumb.is-active { border-color: #333; }

.sbc-qs__details {
  padding: 30px 25px;
  overflow-y: auto;
  max-height: 85vh;
}
.sbc-qs__title {
  font-size: 22px;
  font-weight: 600;
  margin: 0 0 10px;
  color: #333;
  line-height: 1.3;
}
.sbc-qs__price {
  font-size: 20px;
  font-weight: 600;
  color: var(--sbc-price-color);
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12px;
}
.sbc-qs__option-group { margin-bottom: 16px; }
.sbc-qs__option-label {
  font-size: 14px;
  font-weight: 600;
  margin-bottom: 8px;
  color: #333;
}
.sbc-qs__swatches { display: flex; gap: 8px; flex-wrap: wrap; }
.sbc-qs__swatch-btn {
  width: 30px;
  height: 30px;
  border-radius: 50%;
  border: 2px solid #ddd;
  cursor: pointer;
  padding: 0;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.sbc-qs__swatch-btn:hover,
.sbc-qs__swatch-btn.is-selected {
  border-color: #333;
  box-shadow: 0 0 0 2px #fff, 0 0 0 4px #333;
}
.sbc-qs__select {
  width: 100%;
  padding: 12px 14px;
  border: 1px solid #ddd;
  border-radius: 4px;
  font-size: 14px;
  background: #fff;
  cursor: pointer;
}
.sbc-qs__quantity-row {
  display: flex;
  gap: 12px;
  align-items: stretch;
  margin-bottom: 12px;
}
.sbc-qs__qty {
  display: flex;
  align-items: center;
  border: 1px solid #ddd;
  border-radius: 4px;
  overflow: hidden;
}
.sbc-qs__qty button {
  width: 40px;
  height: 44px;
  border: none;
  background: #fff;
  font-size: 18px;
  cursor: pointer;
}
.sbc-qs__qty button:hover { background: #f5f5f5; }
.sbc-qs__qty input {
  width: 50px;
  text-align: center;
  border: none;
  border-left: 1px solid #ddd;
  border-right: 1px solid #ddd;
  font-size: 15px;
  -moz-appearance: textfield;
}
.sbc-qs__qty input::-webkit-inner-spin-button,
.sbc-qs__qty input::-webkit-outer-spin-button { -webkit-appearance: none; margin: 0; }
.sbc-qs__atc {
  flex: 1;
  padding: 12px 20px;
  border: 1.5px solid var(--sbc-accent);
  background: #fff;
  color: var(--sbc-accent);
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  border-radius: 4px;
  transition: background 0.2s, color 0.2s;
}
.sbc-qs__atc:hover { background: var(--sbc-accent); color: #fff; }
.sbc-qs__atc:disabled { opacity: 0.5; cursor: not-allowed; }
.sbc-qs__view-full {
  display: block;
  text-align: center;
  margin-top: 16px;
  font-size: 13px;
  color: #666;
  text-decoration: underline;
}

/* Responsive */
@media screen and (max-width: 999px) {
  .sbc-slide {
    flex: 0 0 calc(100% / 3);
    max-width: calc(100% / 3);
  }
  .sbc-title { font-size: 26px; }
  .sbc-nav--prev { left: -10px; }
  .sbc-nav--next { right: -10px; }
  .sbc-nav { width: 34px; height: 34px; }
}

@media screen and (max-width: 600px) {
  .sbc-viewport {
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    scroll-snap-type: x mandatory;
  }
  .sbc-viewport::-webkit-scrollbar { display: none; }
  .sbc-track {
    transform: none !important;
    transition: none;
    width: max-content;
  }
  .sbc-slide {
    flex: 0 0 60vw;
    max-width: 60vw;
    width: 60vw;
    scroll-snap-align: start;
  }
  .sbc-title { font-size: 22px; }
  .sbc-nav { display: none; }
  .sbc-tab { width: 96px; }
  .sbc-tab-img-wrap { width: 74px; height: 74px; }
  .sbc-tabs { gap: 18px; }
  .sbc-qs-modal__content.is-loaded { grid-template-columns: 1fr; }
  .sbc-qs__details { padding: 20px 15px; max-height: none; }
}
</style>

<script>
(function () {
  var sectionId = "{{ section.id }}";

  function init() {
    var section = document.querySelector('.sbc-section[data-sbc-section="' + sectionId + '"]');
    if (!section) return;

    /* ── Tab switching ── */
    var tabs = section.querySelectorAll(".sbc-tab");
    var panels = section.querySelectorAll(".sbc-panel");
    var carousels = {};

    tabs.forEach(function (tab) {
      tab.addEventListener("click", function () {
        var index = this.getAttribute("data-sbc-tab");
        tabs.forEach(function (t) {
          t.classList.remove("is-active");
          t.setAttribute("aria-selected", "false");
        });
        panels.forEach(function (p) { p.classList.remove("is-active"); });
        this.classList.add("is-active");
        this.setAttribute("aria-selected", "true");
        var target = section.querySelector('.sbc-panel[data-sbc-panel="' + index + '"]');
        if (target) {
          target.classList.add("is-active");
          if (carousels[index]) carousels[index].refresh();
        }
      });
    });

    /* ── Tab bar horizontal scroll arrows ── */
    var tabsScroll = section.querySelector(".sbc-tabs-scroll");
    var tabsPrev = section.querySelector(".sbc-tabs-arrow--prev");
    var tabsNext = section.querySelector(".sbc-tabs-arrow--next");

    function updateTabArrows() {
      if (!tabsScroll) return;
      var maxScroll = tabsScroll.scrollWidth - tabsScroll.clientWidth;
      var noOverflow = maxScroll <= 1;
      if (tabsPrev) tabsPrev.disabled = noOverflow || tabsScroll.scrollLeft <= 1;
      if (tabsNext) tabsNext.disabled = noOverflow || tabsScroll.scrollLeft >= maxScroll - 1;
    }
    if (tabsScroll) {
      if (tabsPrev) tabsPrev.addEventListener("click", function () {
        tabsScroll.scrollBy({ left: -tabsScroll.clientWidth * 0.7, behavior: "smooth" });
      });
      if (tabsNext) tabsNext.addEventListener("click", function () {
        tabsScroll.scrollBy({ left: tabsScroll.clientWidth * 0.7, behavior: "smooth" });
      });
      tabsScroll.addEventListener("scroll", updateTabArrows, { passive: true });
      updateTabArrows();
    }

    /* ── Per-panel product carousel ── */
    var perView = parseInt(getComputedStyle(section).getPropertyValue("--sbc-per-view")) || 4;

    function getPerView() {
      if (window.innerWidth <= 600) return 2;
      if (window.innerWidth <= 999) return 3;
      return perView;
    }

    panels.forEach(function (panel) {
      var carousel = panel.querySelector(".sbc-carousel");
      if (!carousel) return;
      var viewport = carousel.querySelector(".sbc-viewport");
      var track = carousel.querySelector(".sbc-track");
      var slides = track.querySelectorAll(".sbc-slide");
      var prevBtn = carousel.querySelector(".sbc-nav--prev");
      var nextBtn = carousel.querySelector(".sbc-nav--next");
      var currentIndex = 0;
      var startX = 0;
      var dragging = false;

      function maxIndex() { return Math.max(0, slides.length - getPerView()); }

      function update() {
        var pv = getPerView();
        var slideWidth = 100 / pv;
        if (window.innerWidth > 600) {
          track.style.transform = "translateX(-" + (currentIndex * slideWidth) + "%)";
        }
        if (prevBtn) prevBtn.disabled = currentIndex <= 0;
        if (nextBtn) nextBtn.disabled = currentIndex >= maxIndex();
      }

      if (prevBtn) prevBtn.addEventListener("click", function () {
        if (currentIndex > 0) { currentIndex--; update(); }
      });
      if (nextBtn) nextBtn.addEventListener("click", function () {
        if (currentIndex < maxIndex()) { currentIndex++; update(); }
      });

      if (viewport) {
        viewport.addEventListener("touchstart", function (e) {
          startX = e.touches[0].clientX; dragging = true;
        }, { passive: true });
        viewport.addEventListener("touchend", function (e) {
          if (!dragging) return;
          dragging = false;
          if (window.innerWidth <= 600) return; /* native scroll handles mobile */
          var diff = startX - e.changedTouches[0].clientX;
          if (Math.abs(diff) > 40) {
            if (diff > 0 && currentIndex < maxIndex()) currentIndex++;
            else if (diff < 0 && currentIndex > 0) currentIndex--;
            update();
          }
        }, { passive: true });
      }

      var idx = panel.getAttribute("data-sbc-panel");
      carousels[idx] = {
        refresh: function () {
          if (currentIndex > maxIndex()) currentIndex = maxIndex();
          update();
        }
      };
      update();
    });

    var resizeTimer;
    window.addEventListener("resize", function () {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(function () {
        Object.keys(carousels).forEach(function (k) { carousels[k].refresh(); });
        updateTabArrows();
      }, 150);
    });

    /* ── Swatch hover/click image swap ── */
    section.querySelectorAll(".sbc-card").forEach(function (card) {
      var img = card.querySelector(".sbc-card__image--primary");
      if (!img) return;
      img.setAttribute("data-original-src", img.getAttribute("src"));
      function setImage(src) {
        if (!src) return;
        img.removeAttribute("srcset");
        img.removeAttribute("sizes");
        img.setAttribute("src", src);
      }
      card.querySelectorAll(".sbc-swatch").forEach(function (swatch) {
        swatch.addEventListener("mouseenter", function () {
          var p = swatch.getAttribute("data-image");
          if (p) setImage(p);
        });
        swatch.addEventListener("mouseleave", function () {
          var active = card.querySelector(".sbc-swatch.is-active");
          setImage(active ? active.getAttribute("data-image") : img.getAttribute("data-original-src"));
        });
        swatch.addEventListener("click", function (e) {
          e.preventDefault();
          e.stopPropagation();
          var src = swatch.getAttribute("data-image");
          if (!src) return;
          setImage(src);
          card.querySelectorAll(".sbc-swatch").forEach(function (s) { s.classList.remove("is-active"); });
          swatch.classList.add("is-active");
        });
      });
    });

    /* ── Wishlist (shared with featured-collection via cf_wishlist key) ── */
    var WKEY = "cf_wishlist";
    function getWishlist() {
      try { return JSON.parse(localStorage.getItem(WKEY)) || []; } catch (e) { return []; }
    }
    function saveWishlist(list) {
      try { localStorage.setItem(WKEY, JSON.stringify(list)); } catch (e) {}
    }
    var wl = getWishlist();
    section.querySelectorAll(".sbc-card__wishlist").forEach(function (btn) {
      var handle = btn.getAttribute("data-wishlist-handle");
      if (handle && wl.indexOf(handle) !== -1) {
        btn.classList.add("is-active");
        btn.setAttribute("aria-pressed", "true");
      }
      btn.addEventListener("click", function (e) {
        e.preventDefault();
        e.stopPropagation();
        if (!handle) return;
        var list = getWishlist();
        var i = list.indexOf(handle);
        if (i === -1) {
          list.push(handle);
          btn.classList.add("is-active");
          btn.setAttribute("aria-pressed", "true");
        } else {
          list.splice(i, 1);
          btn.classList.remove("is-active");
          btn.setAttribute("aria-pressed", "false");
        }
        saveWishlist(list);
      });
    });

    /* ── Quick Shop modal ── */
    var overlay = document.getElementById("sbc-qs-overlay-" + sectionId);
    var modal = document.getElementById("sbc-qs-modal-" + sectionId);
    var content = document.getElementById("sbc-qs-content-" + sectionId);
    var loading = modal ? modal.querySelector(".sbc-qs-modal__loading") : null;
    var closeBtn = modal ? modal.querySelector(".sbc-qs-modal__close") : null;

    function openModal() {
      if (overlay) overlay.classList.add("is-active");
      if (modal) modal.classList.add("is-active");
      document.body.style.overflow = "hidden";
    }
    function closeModal() {
      if (overlay) overlay.classList.remove("is-active");
      if (modal) modal.classList.remove("is-active");
      document.body.style.overflow = "";
    }
    if (closeBtn) closeBtn.addEventListener("click", closeModal);
    if (overlay) overlay.addEventListener("click", closeModal);
    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape" && modal && modal.classList.contains("is-active")) closeModal();
    });

    function formatMoney(cents) {
      try {
        if (window.Shopify && Shopify.formatMoney) {
          return Shopify.formatMoney(cents, Shopify.money_format);
        }
      } catch (e) {}
      return "£" + (Math.round(cents) / 100).toFixed(2);
    }

    section.querySelectorAll("[data-quickshop-url]").forEach(function (btn) {
      btn.addEventListener("click", function (e) {
        e.preventDefault();
        e.stopPropagation();
        var url = btn.getAttribute("data-quickshop-url");
        if (!url) return;

        if (content) { content.innerHTML = ""; content.classList.remove("is-loaded"); }
        if (loading) loading.classList.remove("is-hidden");
        openModal();

        fetch(url + ".js")
          .then(function (r) { return r.ok ? r.json() : null; })
          .then(function (product) {
            if (!product) throw new Error("no product");

            var variantById = {};
            product.variants.forEach(function (v) { variantById[v.id] = v; });

            /* Images */
            var images = (product.images || []).slice(0, 6);
            var imagesHtml = '<div class="sbc-qs__images">';
            if (images.length) {
              imagesHtml += '<img class="sbc-qs__main-img" src="' + images[0] + '" alt="' + product.title + '">';
              if (images.length > 1) {
                imagesHtml += '<div class="sbc-qs__thumbs">';
                images.forEach(function (src, i) {
                  imagesHtml += '<img class="sbc-qs__thumb' + (i === 0 ? ' is-active' : '') + '" src="' + src + '" alt="thumb">';
                });
                imagesHtml += '</div>';
              }
            }
            imagesHtml += '</div>';

            /* Options */
            var colorIdx = -1;
            (product.options || []).forEach(function (o, i) {
              var name = typeof o === "string" ? o : (o && o.name) || "";
              if (/colou?r/i.test(name)) colorIdx = i;
            });

            var optionsHtml = "";
            var hasSingleDefault = product.options && product.options.length === 1 &&
              (product.options[0] === "Title" || (product.options[0] && product.options[0].name === "Title"));

            if (!hasSingleDefault) {
              (product.options || []).forEach(function (opt, oi) {
                var optName = typeof opt === "string" ? opt : (opt && opt.name) || ("Option " + (oi + 1));
                var values = [];
                product.variants.forEach(function (v) {
                  var val = v.options[oi];
                  if (val && values.indexOf(val) === -1) values.push(val);
                });
                optionsHtml += '<div class="sbc-qs__option-group" data-option-index="' + oi + '">';
                optionsHtml += '<div class="sbc-qs__option-label">' + optName + '</div>';
                if (oi === colorIdx) {
                  optionsHtml += '<div class="sbc-qs__swatches">';
                  values.forEach(function (val, vi) {
                    var handle = val.toLowerCase().replace(/\s+/g, "-");
                    optionsHtml += '<button type="button" class="sbc-qs__swatch-btn' + (vi === 0 ? ' is-selected' : '') +
                      '" data-option-value="' + val + '" data-swatch-color="' + handle +
                      '" style="background-color:' + handle + ';" title="' + val + '"></button>';
                  });
                  optionsHtml += '</div>';
                } else {
                  optionsHtml += '<select class="sbc-qs__select">';
                  values.forEach(function (val) {
                    optionsHtml += '<option value="' + val + '">' + val + '</option>';
                  });
                  optionsHtml += '</select>';
                }
                optionsHtml += '</div>';
              });
            }

            var firstVariant = product.variants[0];
            var details = '<div class="sbc-qs__details">';
            details += '<h2 class="sbc-qs__title">' + product.title + '</h2>';
            details += '<div class="sbc-qs__price">' + formatMoney(firstVariant.price) + '</div>';
            details += optionsHtml;
            details += '<div class="sbc-qs__quantity-row">';
            details += '<div class="sbc-qs__qty"><button type="button" class="sbc-qs-minus">&minus;</button><input type="number" class="sbc-qs-qty-input" value="1" min="1" max="99"><button type="button" class="sbc-qs-plus">&plus;</button></div>';
            details += '<button type="button" class="sbc-qs__atc" data-variant-id="' + firstVariant.id + '">Add to cart</button>';
            details += '</div>';
            details += '<a href="' + url + '" class="sbc-qs__view-full">View full details</a>';
            details += '</div>';

            if (content) {
              content.innerHTML = imagesHtml + details;
              content.classList.add("is-loaded");
            }
            if (loading) loading.classList.add("is-hidden");

            var mainImg = content.querySelector(".sbc-qs__main-img");
            var priceEl = content.querySelector(".sbc-qs__price");
            var atcBtn = content.querySelector(".sbc-qs__atc");

            function currentSelection() {
              var vals = [];
              (product.options || []).forEach(function (opt, oi) {
                var group = content.querySelector('.sbc-qs__option-group[data-option-index="' + oi + '"]');
                if (!group) { vals[oi] = firstVariant.options[oi]; return; }
                var sw = group.querySelector(".sbc-qs__swatch-btn.is-selected");
                var sel = group.querySelector(".sbc-qs__select");
                vals[oi] = sw ? sw.getAttribute("data-option-value") : (sel ? sel.value : null);
              });
              return vals;
            }

            function matchVariant() {
              if (hasSingleDefault) return firstVariant;
              var sel = currentSelection();
              for (var i = 0; i < product.variants.length; i++) {
                var v = product.variants[i];
                var ok = true;
                for (var j = 0; j < sel.length; j++) {
                  if (sel[j] != null && String(v.options[j]).toLowerCase() !== String(sel[j]).toLowerCase()) { ok = false; break; }
                }
                if (ok) return v;
              }
              return null;
            }

            function updateSelection() {
              var v = matchVariant();
              if (!v) return;
              if (priceEl) priceEl.textContent = formatMoney(v.price);
              if (atcBtn) atcBtn.setAttribute("data-variant-id", v.id);
              if (mainImg && v.featured_image && v.featured_image.src) mainImg.src = v.featured_image.src;
            }

            content.querySelectorAll(".sbc-qs__swatch-btn").forEach(function (b) {
              b.addEventListener("click", function () {
                b.closest(".sbc-qs__swatches").querySelectorAll(".sbc-qs__swatch-btn").forEach(function (s) { s.classList.remove("is-selected"); });
                b.classList.add("is-selected");
                updateSelection();
              });
            });
            content.querySelectorAll(".sbc-qs__select").forEach(function (s) {
              s.addEventListener("change", updateSelection);
            });
            content.querySelectorAll(".sbc-qs__thumb").forEach(function (t) {
              t.addEventListener("click", function () {
                if (mainImg) mainImg.src = t.src;
                content.querySelectorAll(".sbc-qs__thumb").forEach(function (x) { x.classList.remove("is-active"); });
                t.classList.add("is-active");
              });
            });

            var qtyInput = content.querySelector(".sbc-qs-qty-input");
            var minus = content.querySelector(".sbc-qs-minus");
            var plus = content.querySelector(".sbc-qs-plus");
            if (minus) minus.addEventListener("click", function () {
              var v = parseInt(qtyInput.value) || 1; if (v > 1) qtyInput.value = v - 1;
            });
            if (plus) plus.addEventListener("click", function () {
              qtyInput.value = (parseInt(qtyInput.value) || 1) + 1;
            });

            if (atcBtn) atcBtn.addEventListener("click", function () {
              var vid = atcBtn.getAttribute("data-variant-id");
              var qty = parseInt(qtyInput ? qtyInput.value : 1) || 1;
              if (!vid) { alert("Please select a variant."); return; }
              atcBtn.disabled = true;
              atcBtn.textContent = "Adding...";
              fetch("/cart/add.js", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ id: parseInt(vid), quantity: qty })
              })
                .then(function (r) { return r.json(); })
                .then(function (data) {
                  if (data.status === 422) {
                    atcBtn.textContent = data.description || "Unavailable";
                    setTimeout(function () { atcBtn.textContent = "Add to cart"; atcBtn.disabled = false; }, 2000);
                  } else {
                    atcBtn.textContent = "Added!";
                    setTimeout(function () {
                      atcBtn.textContent = "Add to cart";
                      atcBtn.disabled = false;
                      closeModal();
                      fetch("/cart.js").then(function (r) { return r.json(); }).then(function (cart) {
                        document.querySelectorAll("[data-cart-count], .cart-count-bubble span, .cart-count").forEach(function (el) {
                          el.textContent = cart.item_count;
                        });
                      });
                    }, 900);
                  }
                })
                .catch(function () {
                  atcBtn.textContent = "Error - try again";
                  setTimeout(function () { atcBtn.textContent = "Add to cart"; atcBtn.disabled = false; }, 2000);
                });
            });

            updateSelection();
          })
          .catch(function () {
            if (loading) loading.classList.add("is-hidden");
            if (content) {
              content.innerHTML = '<div style="padding:40px;text-align:center;grid-column:1/-1;"><p>Could not load product. <a href="' + url + '">View product page</a></p></div>';
              content.classList.add("is-loaded");
            }
          });
      });
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
})();
</script>

