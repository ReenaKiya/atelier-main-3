  align-items: center;
  justify-content: center;
  min-height: 300px;
}
.sbc-qs-modal__loading.is-hidden { display: none; }
.sbc-qs-spinner { width: 40px; height: 40px; }

.sbc-qs-modal__content { display: none; }
.sbc-qs-modal__content.is-loaded {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
}

.sbc-qs__images {
  padding: 20px;
  background: #fafafa;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.sbc-qs__images img {
  width: 100%;
  max-width: 400px;
  height: auto;
  object-fit: contain;
